---
// Shared site header (SOW-010 V3). Brand + flat nav + light/dark toggle + sign-in, in the V3 design
// language (classes from gbti-v3.css). Token-driven, so it works in both themes. Replaces the legacy
// dark mega-menu. The icon sprite is rendered once in BaseLayout.
const nav = [
  { label: 'Products', href: '/products/' },
  { label: 'Prompts', href: '/prompts/' },
  { label: 'Revenue Model', href: '/revenue-model/' },
  { label: 'Blog', href: '/articles/' },
  { label: 'Get Extension', href: '/extension/' },
];
---
<header class="site-head" id="top">
  <div class="wrap head-inner">
    <a class="brand" href="/" aria-label="GBTI Network home">
      <span class="brand-mark" aria-hidden="true"></span>
      <span class="brand-word">GBTI</span>
    </a>

    <nav class="nav" aria-label="Primary">
      {nav.map((i) => <a href={i.href}>{i.label}</a>)}
    </nav>

    <div class="head-cta">
      <button type="button" class="theme-toggle" data-theme-toggle aria-label="Toggle dark mode" data-tooltip="Toggle dark mode" data-tooltip-pos="below">
        <svg class="ico-moon" viewBox="0 0 24 24" aria-hidden="true"><use href="#ico-moon" /></svg>
        <svg class="ico-sun" viewBox="0 0 24 24" aria-hidden="true"><use href="#ico-sun" /></svg>
      </button>
      <a href="/membership/" class="btn-gh" data-signin><svg viewBox="0 0 24 24" width="18" height="18" aria-hidden="true"><use href="#ico-github" /></svg> Sign in</a>
      {/* SOW-030/036: shown only when the GBTI extension stamps a signed-in member signal (presentation only). The
          avatar is a menu button; its items deep-link into the extension's management pages via the content-script
          relay (the site cannot link to chrome-extension:// directly). */}
      <div class="head-me-wrap" data-head-me-wrap hidden>
        <button type="button" class="head-me" data-head-me aria-haspopup="true" aria-expanded="false" aria-label="Account menu">
          <img class="head-me-av" data-head-me-av alt="" width="26" height="26" decoding="async" />
          <span class="head-me-name" data-head-me-name></span>
          <svg class="head-me-caret" viewBox="0 0 16 16" width="13" height="13" aria-hidden="true"><path d="M4 6l4 4 4-4" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" /></svg>
        </button>
        <div class="head-menu" data-head-menu role="menu" hidden>
          <a class="hm-item" role="menuitem" data-head-me-profile href="/members/">My profile</a>
          <div class="hm-sep" role="separator"></div>
          {/* SOW: shown only in the hint-only state (signed up, extension not installed yet) -> nudge the download. */}
          <a class="hm-item hm-download" role="menuitem" href="/extension/" hidden>Get the extension to continue &rarr;</a>
          <button class="hm-item" role="menuitem" type="button" data-open="workspace.html">My workspace</button>
          <button class="hm-item" role="menuitem" type="button" data-open="workspace.html" data-hash="tab=post">My articles</button>
          <button class="hm-item" role="menuitem" type="button" data-open="workspace.html" data-hash="tab=prompt">My prompts</button>
          <button class="hm-item" role="menuitem" type="button" data-open="workspace.html" data-hash="tab=product">My products</button>
          <button class="hm-item" role="menuitem" type="button" data-open="workspace.html" data-hash="tab=prs">My pull requests</button>
          <button class="hm-item" role="menuitem" type="button" data-open="workspace.html" data-hash="tab=saved">Saved</button>
          <button class="hm-item" role="menuitem" type="button" data-open="workspace.html" data-hash="tab=subs">Subscriptions</button>
          <button class="hm-item" role="menuitem" type="button" data-open="newtab.html">Browse the network</button>
          <button class="hm-item" role="menuitem" type="button" data-open="account.html">Settings</button>
          <button class="hm-item hm-admin" role="menuitem" type="button" data-open="admin.html" data-role-min hidden>Admin tools</button>
          <div class="hm-sep" role="separator"></div>
          <button class="hm-item hm-signout" role="menuitem" type="button" data-head-signout>Sign out</button>
        </div>
      </div>
      <button type="button" class="head-burger" data-mobile-toggle aria-label="Open menu" aria-expanded="false">
        <span></span><span></span><span></span>
      </button>
    </div>
  </div>

  <nav class="head-mobile" data-mobile-menu hidden aria-label="Mobile">
    <div class="wrap">
      {nav.map((i) => <a href={i.href}>{i.label}</a>)}
      <a href="/membership/" class="m-join">Sign in / Join</a>
    </div>
  </nav>
</header>

<style>
  /* Mobile menu + burger. The full nav scales to fit down to 650px (gbti-v3.css); the burger + mobile
     menu only take over below 650px. */
  .head-burger { display: none; flex-direction: column; gap: 5px; width: 40px; height: 38px;
    align-items: center; justify-content: center; background: transparent; border: 0; cursor: pointer; }
  .head-burger span { display: block; width: 22px; height: 2px; background: var(--fg-soft); border-radius: 2px; }
  .head-mobile { border-top: 1px solid var(--line); background: var(--paper); }
  .head-mobile .wrap { display: flex; flex-direction: column; padding-top: 10px; padding-bottom: 14px; }
  .head-mobile a { padding: 11px 0; font-weight: 500; color: var(--fg-soft); border-bottom: 1px solid var(--line); }
  .head-mobile a:last-child { border-bottom: 0; }
  .head-mobile .m-join { color: var(--green-700); font-weight: 600; }
  /* SOW-030/036: the signed-in account control (avatar + @login + caret) and its dropdown menu. Hidden until the
     extension signal arrives; when shown it replaces the "Sign in" button (toggled in the script below). */
  .head-me-wrap { position: relative; }
  .head-me-wrap[hidden] { display: none; }
  .head-me { display: inline-flex; align-items: center; gap: 7px; padding: 4px 10px 4px 4px;
    border: 1px solid var(--line-2); border-radius: var(--r-pill); font-weight: 600; font-size: 14px;
    color: var(--fg); background: var(--paper); cursor: pointer; font-family: inherit; }
  .head-me:hover { border-color: var(--green); }
  .head-me-av { width: 26px; height: 26px; border-radius: 50%; background: var(--line); object-fit: cover; }
  .head-me-caret { color: var(--fg-mute); transition: transform .15s ease; }
  .head-me[aria-expanded="true"] .head-me-caret { transform: rotate(180deg); }
  /* The dropdown panel. Token-driven so it works in both themes. */
  .head-menu { position: absolute; top: calc(100% + 8px); right: 0; min-width: 210px; z-index: 60;
    background: var(--paper); border: 1px solid var(--line-2); border-radius: var(--r-lg);
    box-shadow: 0 12px 30px -12px rgba(0,0,0,.32); padding: 6px; display: flex; flex-direction: column; }
  .head-menu[hidden] { display: none; }
  .hm-item { display: block; width: 100%; text-align: left; padding: 8px 12px; border: 0; border-radius: var(--r);
    background: transparent; color: var(--fg); font: inherit; font-size: 14px; font-weight: 500; cursor: pointer;
    text-decoration: none; }
  .hm-item:hover, .hm-item:focus-visible { background: var(--green-tint); color: var(--green-700); outline: none; }
  .hm-signout { color: var(--fg-soft); }
  .hm-sep { height: 1px; background: var(--line); margin: 5px 4px; }
  @media (max-width: 650px) {
    .head-cta .btn-gh { display: none; }
    .head-me-name { display: none; }
    .head-burger { display: flex; }
  }
  @media (min-width: 651px) { .head-mobile { display: none; } }
</style>

<script>
  import { readMemberSignal, onMemberSignal } from '../lib/member-signal';

  // SOW-030/036: reflect the extension's signed-in signal into the header. When a member signal is present we show
  // the avatar account menu and hide the "Sign in" button; otherwise the header stays in its logged-out state.
  // Presentation only (the signal is untrusted; authoritative checks stay server-side). The menu's management
  // items deep-link into the extension's pages via the content-script relay (gbti:open); the site cannot link to
  // chrome-extension:// directly. Avatars come from GitHub by login, with a brand fallback on error.
  const RANK = { member: 0, moderator: 1, admin: 2, superadmin: 3 };
  const signin = document.querySelector('[data-signin]');
  const wrap = document.querySelector('[data-head-me-wrap]');
  const me = document.querySelector('[data-head-me]');
  const meAv = document.querySelector('[data-head-me-av]');
  const meName = document.querySelector('[data-head-me-name]');
  const meProfile = document.querySelector('[data-head-me-profile]');
  const headMenu = document.querySelector('[data-head-menu]');
  const adminItem = document.querySelector('.hm-admin');

  function closeMenu() {
    if (!headMenu || !me) return;
    headMenu.hidden = true;
    me.setAttribute('aria-expanded', 'false');
  }
  function openMenu() {
    if (!headMenu || !me) return;
    headMenu.hidden = false;
    me.setAttribute('aria-expanded', 'true');
    // Focus the first item for keyboard users.
    headMenu.querySelector('.hm-item')?.focus();
  }

  // SOW: a DISPLAY-ONLY signed-in hint for the window between trial signup and installing the extension. The signup
  // redirect carries ?u=<github_login> (the PUBLIC login, NOT auth); we stash it in localStorage and show the avatar
  // so the header reflects "signed in". The real extension signal (once installed) always overrides the hint.
  function readHint() {
    let login = null;
    try {
      const u = new URLSearchParams(location.search).get('u');
      if (u) { localStorage.setItem('gbti_hello', u); login = u; }
      else login = localStorage.getItem('gbti_hello');
    } catch { /* no storage */ }
    return login ? { login, hintOnly: true } : null;
  }
  function setMenuMode(hintOnly) {
    // The extension-relay items + Sign out only work with the extension installed; in the hint-only state we hide
    // them and surface a "get the extension" item instead.
    headMenu?.querySelectorAll('[data-open],[data-head-signout]').forEach((el) => { el.hidden = Boolean(hintOnly); });
    const dl = headMenu?.querySelector('.hm-download');
    if (dl) dl.hidden = !hintOnly;
  }
  function applyHeaderIdentity(s) {
    if (!wrap || !signin) return;
    const eff = (s && s.login) ? s : readHint(); // the extension signal wins; else the display-only signup hint
    const login = eff && eff.login;
    if (login) {
      const folder = eff.username || login;
      if (meName) meName.textContent = '@' + login;
      if (meAv) { meAv.src = 'https://github.com/' + encodeURIComponent(login) + '.png?size=52'; meAv.alt = '@' + login; }
      if (meProfile) meProfile.href = '/members/' + encodeURIComponent(folder) + '/';
      if (adminItem) adminItem.hidden = (RANK[eff.role] ?? 0) < RANK.moderator;
      setMenuMode(Boolean(eff.hintOnly));
      wrap.hidden = false;
      signin.style.display = 'none';
    } else {
      closeMenu();
      wrap.hidden = true;
      signin.style.display = '';
    }
  }
  meAv?.addEventListener('error', () => { if (meAv) meAv.src = '/favicon-32x32.png'; });
  applyHeaderIdentity(readMemberSignal());
  onMemberSignal(applyHeaderIdentity);

  // Toggle the dropdown; close on Esc, on outside-click, and after choosing an item.
  me?.addEventListener('click', (e) => {
    e.stopPropagation();
    headMenu?.hidden ? openMenu() : closeMenu();
  });
  document.addEventListener('click', (e) => { if (!headMenu?.hidden && !wrap?.contains(e.target)) closeMenu(); });
  document.addEventListener('keydown', (e) => { if (e.key === 'Escape' && !headMenu?.hidden) { closeMenu(); me?.focus(); } });

  // Management items: relay to the extension (which opens the in-extension page in a new tab). The plain-link
  // items (My profile) navigate the site normally and are not handled here.
  headMenu?.querySelectorAll('[data-open]').forEach((b) => {
    b.addEventListener('click', () => {
      document.dispatchEvent(new CustomEvent('gbti:open', { detail: { page: b.dataset.open, hash: b.dataset.hash || '' } }));
      closeMenu();
    });
  });
  document.querySelector('[data-head-signout]')?.addEventListener('click', () => {
    document.dispatchEvent(new CustomEvent('gbti:request-signout'));
    closeMenu();
  });

  // Light/dark toggle: flip data-theme on <html>, persist to localStorage. The no-FOUC initial theme is
  // set in BaseLayout's <head> before paint; this only handles the click + persistence.
  const root = document.documentElement;
  document.querySelector('[data-theme-toggle]')?.addEventListener('click', () => {
    const next = root.getAttribute('data-theme') === 'dark' ? 'light' : 'dark';
    root.setAttribute('data-theme', next);
    try { localStorage.setItem('gbti-theme', next); } catch {}
  });

  // Mobile menu.
  const burger = document.querySelector('[data-mobile-toggle]');
  const menu = document.querySelector('[data-mobile-menu]');
  burger?.addEventListener('click', () => {
    const open = menu?.toggleAttribute('hidden');
    burger.setAttribute('aria-expanded', String(open === false));
  });
</script>
