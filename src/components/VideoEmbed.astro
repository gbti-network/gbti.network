---
// Renders a responsive YouTube/Vimeo embed from a URL or bare ID (the `video` content field).
// Video is embed-only on this site (never self-hosted); see content-schemas.md media handling.
interface Props {
  video: string;
  title?: string;
}
import { embedUrl } from '../../client/src/video-embed.mjs'; // SOW-062 5d: the ONE shared YouTube/Vimeo extractor
const { video, title = 'Embedded video' } = Astro.props;
const src = embedUrl(video);
---
{src && (
  <div class="aspect-video w-full overflow-hidden" style="border-radius:var(--r-lg);background:var(--ink)">
    <iframe
      src={src}
      title={title}
      loading="lazy"
      class="h-full w-full"
      allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
      allowfullscreen
    ></iframe>
  </div>
)}
