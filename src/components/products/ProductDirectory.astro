---
// Shared product directory: search + category filters + count + grid/list toggle, with a compact
// list view as the default ("compact mode"). Used full on /products/ and limited (e.g. 12) on the
// home page so both render the exact same directory experience. Glyph defs are emitted here so any
// later section on the same page (recently-created, featured) can reference them.
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';
import Avatar from '../Avatar.astro';
import { isStub, catalogHref } from '../../lib/content';
import { leafLabel } from '../../lib/taxonomy';
import { authorDisplay, authorHref, authorAvatar, formatDate } from '../../lib/authors';
import FavoriteButton from '../FavoriteButton.astro';
import { favoriteCount } from '../../lib/favorites';

interface Props {
  products: any[];
  limit?: number;
  pageSize?: number; // when set, the compact list paginates client-side (page 2+ loads the rest)
}
const { products: allProducts, limit, pageSize } = Astro.props;
const products = typeof limit === 'number' ? allProducts.slice(0, limit) : allProducts;

// Author profiles, so attribution shows the real avatar and links only when a profile page exists.
const profileByUser = new Map((await getCollection('profile')).map((p) => [p.data.username, p.data]));

// Map a product's taxonomy LEAF to the design's four directory categories (colour + glyph + chip).
const DESIGN_CAT: Record<string, { key: string; label: string; cls: string; g: string }> = {
  wordpress: { key: 'wp', label: 'WordPress', cls: 'c-wp', g: 'g-wp' },
  'ide-plugins': { key: 'ide', label: 'IDE Plugins', cls: 'c-ide', g: 'g-ide' },
  mods: { key: 'mod', label: 'Mods', cls: 'c-mod', g: 'g-mod' },
  utilities: { key: 'util', label: 'Utilities', cls: 'c-util', g: 'g-util' },
};
const leafKeyOf = (p: any) => p.data.categories?.[p.data.categories.length - 1] ?? '';
const catOf = (p: any) =>
  DESIGN_CAT[leafKeyOf(p)] ?? { key: 'other', label: leafLabel(p.data.categories) || 'Product', cls: 'c-util', g: 'g-util' };

// Toolbar filters: only the design categories actually present (in the shown set), in a stable order.
const ORDER = ['wp', 'ide', 'mod', 'util'];
const present = new Set(products.map((p) => catOf(p).key));
const filters = [{ key: 'all', label: 'All', g: 'g-grid' }, ...ORDER.filter((k) => present.has(k)).map((k) => {
  const c = Object.values(DESIGN_CAT).find((d) => d.key === k)!;
  return { key: k, label: c.label, g: c.g };
})];

const paidOf = (p: any) => p.data.pricing && p.data.pricing !== 'free';
const desc = (p: any) => p.data.shortDescription ?? '';
---
<!-- glyph defs used by the directory (and reused by sibling product sections on the same page) -->
<svg width="0" height="0" style="position:absolute" aria-hidden="true"><defs>
  <g id="g-wp"><path d="M9 8l-4 4 4 4M15 8l4 4-4 4" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></g>
  <g id="g-ide"><path d="M6 8l4 4-4 4M13 16h5" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></g>
  <g id="g-mod"><path d="M12 3l8 4.5v9L12 21l-8-4.5v-9L12 3z" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linejoin="round"/><path d="M12 3v9m0 0l8-4.5M12 12l-8-4.5" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/></g>
  <g id="g-util"><path d="M12 3l2.1 6.6L21 12l-6.9 2.4L12 21l-2.1-6.6L3 12l6.9-2.4z" fill="currentColor"/></g>
  <g id="g-arrow"><path d="M5 12h13M13 6l6 6-6 6" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></g>
  <g id="g-search"><circle cx="11" cy="11" r="7" fill="none" stroke="currentColor" stroke-width="2"/><path d="M20.5 20.5l-4.2-4.2" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></g>
  <g id="g-grid"><rect x="4" y="4" width="7" height="7" rx="1.5" fill="currentColor"/><rect x="13" y="4" width="7" height="7" rx="1.5" fill="currentColor"/><rect x="4" y="13" width="7" height="7" rx="1.5" fill="currentColor"/><rect x="13" y="13" width="7" height="7" rx="1.5" fill="currentColor"/></g>
  <g id="g-list"><rect x="4" y="5" width="16" height="3" rx="1.5" fill="currentColor"/><rect x="4" y="10.5" width="16" height="3" rx="1.5" fill="currentColor"/><rect x="4" y="16" width="16" height="3" rx="1.5" fill="currentColor"/></g>
</defs></svg>

<div class="wrap browse" data-page-size={pageSize ?? ''}>
  <div class="toolbar">
    <div class="tsearch"><svg viewBox="0 0 24 24"><use href="#g-search"/></svg><input data-search type="text" placeholder="Search products" aria-label="Search products" /></div>
    <div class="tfilters">
      {filters.map((f, i) => (
        <button class:list={['tfilter', i === 0 && 'on']} data-filter={f.key}><svg viewBox="0 0 24 24" aria-hidden="true"><use href={`#${f.g}`}/></svg>{f.label}</button>
      ))}
    </div>
    <div class="tspacer"></div>
    <span class="tcount" data-count></span>
    <div class="ttoggle">
      <button data-view="grid" aria-label="Grid view"><svg viewBox="0 0 24 24"><use href="#g-grid"/></svg></button>
      <button class="on" data-view="list" aria-label="List view"><svg viewBox="0 0 24 24"><use href="#g-list"/></svg></button>
    </div>
  </div>

  <div class="plist" data-items>
    {products.map((p) => {
      const c = catOf(p);
      return (
        <article class="prow card card-hover" data-cat={c.key} data-name={`${p.data.title} ${desc(p)}`.toLowerCase()}>
          <div class="prow-icons">
            <span class:list={['pico', c.cls]} aria-hidden="true"><svg viewBox="0 0 24 24"><use href={`#${c.g}`}/></svg></span>
            <Image class="prow-icon" src={p.data.icon} width={50} height={50} alt={`${p.data.title} icon`} />
          </div>
          <div class="prow-main">
            <div class="prow-head">
              <h3 class="prow-name"><a href={catalogHref(p)}>{p.data.title}</a></h3>
              <span class:list={['pchip', c.cls]}>{c.label}</span>
              {paidOf(p) && <span class="pchip-paid">Paid</span>}
              {isStub(p) && (
                <span class="pchip-paid" style="display:inline-flex;align-items:center;gap:4px">
                  <svg viewBox="0 0 24 24" width="11" height="11"><use href="#ico-lock"/></svg>Members only
                </span>
              )}
            </div>
            <p class="prow-desc">{desc(p)}</p>
          </div>
          <div class="prow-author">
            <div class="author-hover">
              <Avatar item={{ name: authorDisplay(p.data.author), avatar: authorAvatar(p.data.author, profileByUser.get(p.data.author)?.avatar) }} class="prow-av" size={44} />
              <div class="author-pop card" role="tooltip">
                <div class="author-pop-top">
                  <Avatar item={{ name: profileByUser.get(p.data.author)?.displayName ?? authorDisplay(p.data.author), avatar: authorAvatar(p.data.author, profileByUser.get(p.data.author)?.avatar) }} class="apop-av" size={46} />
                  <div>
                    <span class="author-pop-name">{profileByUser.get(p.data.author)?.displayName ?? authorDisplay(p.data.author)}</span>
                    {profileByUser.get(p.data.author)?.headline && <span class="author-pop-head">{profileByUser.get(p.data.author)?.headline}</span>}
                  </div>
                </div>
                {profileByUser.has(p.data.author) && (
                  <a href={authorHref(p.data.author)} class="link author-pop-link">View profile <svg class="ar" viewBox="0 0 24 24" width="14" height="14"><use href="#g-arrow"/></svg></a>
                )}
              </div>
            </div>
            <div class="prow-author-meta">
              {profileByUser.has(p.data.author)
                ? <a href={authorHref(p.data.author)}>{authorDisplay(p.data.author)}</a>
                : <span class="prow-author-name">{authorDisplay(p.data.author)}</span>}
              {p.data.publishedAt && <span class="prow-sub">Submitted {formatDate(p.data.publishedAt)}</span>}
            </div>
            <FavoriteButton targetType="product" targetSlug={p.data.slug} count={favoriteCount('product', p.data.slug)} size="sm" />
          </div>
        </article>
      );
    })}
  </div>
  {pageSize && <nav class="ppage" data-ppage aria-label="Product directory pages" hidden></nav>}
</div>

<style>
  /* ---- product directory (ported from the /products/ page; shared by home + products) ---- */
  .c-wp   { --ca:#2f63c0; --cb:#5a8de0; --ct:#eef3fc; --cl:#bcd0f0; }
  .c-ide  { --ca:#6b4fb0; --cb:#9277d4; --ct:#f2eefb; --cl:#d6c9ee; }
  .c-mod  { --ca:#b3791f; --cb:#d8a847; --ct:#fbf3e3; --cl:#ecd9ad; }
  .c-util { --ca:#138178; --cb:#3bb0a4; --ct:#e7f5f3; --cl:#b6e0da; }

  .pico { border-radius: 11px; flex: none; display: flex; align-items: center; justify-content: center; color: #fff;
    background: linear-gradient(145deg, var(--cb), var(--ca)); box-shadow: 0 4px 12px rgba(37,35,43,.14); }
  .pico svg { width: 52%; height: 52%; }
  .pchip { display: inline-flex; align-items: center; font-family: var(--f-mono); font-size: 11px; font-weight: 500; letter-spacing: .02em;
    padding: 4px 9px; border-radius: 4px; border: 1.5px solid var(--cl); color: var(--ca); background: var(--ct); white-space: nowrap; }
  .pchip-paid { display: inline-flex; align-items: center; font-family: var(--f-mono); font-size: 11px; font-weight: 600; padding: 4px 9px; border-radius: 4px; border: 1.5px solid var(--green); color: var(--green-700); background: var(--green-tint); }

  .prow-author { display: flex; align-items: center; gap: 9px; font-size: 13px; color: var(--fg-mute); flex-wrap: wrap; min-width: 0; }
  .prow-author-meta { display: flex; flex-direction: column; line-height: 1.3; min-width: 0; }
  .prow-author-meta a, .prow-author-name { color: var(--fg-soft); font-weight: 600; }
  .prow-sub { font-family: var(--f-mono); font-size: 11px; color: var(--fg-mute); font-weight: 400; }
  /* Avatar renders in its own component scope, so the circle must be :global to reach it. */
  :global(.prow-av), :global(.apop-av) { border-radius: 50%; flex: none; }
  .author-hover { position: relative; display: inline-flex; }
  .author-pop { position: absolute; bottom: calc(100% + 10px); right: 0; left: auto; width: 244px; padding: 16px; z-index: 30;
    opacity: 0; visibility: hidden; pointer-events: none; transform: translateY(6px); transition: opacity .15s ease, transform .15s ease;
    white-space: normal; box-shadow: var(--sh); }
  .author-hover:hover .author-pop, .author-hover:focus-within .author-pop { opacity: 1; visibility: visible; pointer-events: auto; transform: translateY(0); }
  .author-pop-top { display: flex; align-items: center; gap: 11px; }
  .apop-av { border-radius: 50%; flex: none; }
  .author-pop-name { font-family: var(--f-display); font-weight: 700; font-size: 15px; color: var(--fg); display: block; }
  .author-pop-head { font-size: 12.5px; color: var(--fg-mute); display: block; margin-top: 2px; }
  .author-pop-link { font-size: 13px; margin-top: 12px; display: inline-flex; }

  /* toolbar */
  .toolbar { display: flex; align-items: center; gap: 14px; flex-wrap: wrap; margin-bottom: 26px; }
  .tsearch { display: flex; align-items: center; gap: 9px; flex: 1; min-width: 220px; max-width: 340px;
    background: var(--paper); border: 1.5px solid var(--line); border-radius: var(--r); padding: 10px 14px; box-shadow: var(--sh-sm); }
  .tsearch svg { width: 17px; height: 17px; color: var(--fg-mute); flex: none; }
  .tsearch input { border: 0; outline: 0; font-family: var(--f-sans); font-size: 14.5px; color: var(--fg); width: 100%; background: transparent; }
  .tfilters { display: flex; gap: 8px; flex-wrap: wrap; }
  .tfilter { display: inline-flex; align-items: center; gap: 7px; cursor: pointer; font-family: var(--f-mono); font-size: 12px; font-weight: 500; padding: 8px 13px; border-radius: var(--r);
    border: 1.5px solid var(--line-2); color: var(--fg-soft); background: var(--paper); transition: all .15s; white-space: nowrap; }
  .tfilter svg { width: 15px; height: 15px; flex: none; }
  .tfilter:hover { border-color: var(--ink); color: var(--ink); }
  .tfilter.on { border-color: var(--green); color: var(--green-700); background: var(--green-tint); }
  .tcount { font-family: var(--f-mono); font-size: 12.5px; color: var(--fg-mute); white-space: nowrap; }
  .tspacer { flex: 1; }
  .ttoggle { display: flex; border: 1.5px solid var(--line-2); border-radius: var(--r); overflow: hidden; background: var(--paper); }
  .ttoggle button { width: 34px; height: 34px; display: flex; align-items: center; justify-content: center; border: 0; background: transparent; cursor: pointer; color: var(--fg-mute); }
  .ttoggle button.on { background: var(--ink); color: var(--paper); }
  .ttoggle button svg { width: 16px; height: 16px; }

  /* directory list — sizes scale fluidly in the 680px..1080px band so the inline 3-column row
     stays intact (it only reflows below 680px). clamp() lets bigger phones/tablets read larger. */
  .plist { display: flex; flex-direction: column; gap: clamp(10px, 1.2vw, 12px); }
  .prow { display: grid; grid-template-columns: auto 1fr auto; align-items: center;
    gap: clamp(12px, calc(2.5vw - 5px), 22px); padding: clamp(13px, calc(1.25vw + 4.5px), 18px) clamp(15px, calc(1.75vw + 3px), 22px); }
  .prow-icons { display: flex; align-items: center; gap: clamp(8px, calc(1vw + 1px), 12px); flex: none; }
  .prow .pico { width: clamp(40px, calc(2.5vw + 23px), 50px); height: clamp(40px, calc(2.5vw + 23px), 50px); }
  .prow-icon { width: clamp(40px, calc(2.5vw + 23px), 50px); height: clamp(40px, calc(2.5vw + 23px), 50px); border-radius: 11px; object-fit: contain; background: var(--tint); border: 1.5px solid var(--line); flex: none; }
  .prow-main { min-width: 0; }
  .prow-head { display: flex; align-items: center; gap: clamp(7px, 1vw, 12px); min-width: 0; flex-wrap: wrap; }
  .prow-name { font-family: var(--f-display); font-weight: 700; font-size: clamp(14.5px, calc(0.625vw + 10.25px), 17px); color: var(--fg); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; min-width: 0; }
  .prow-name a { color: var(--fg); transition: color .15s ease; }
  .prow:hover .prow-name a, .prow-name a:hover { color: var(--green-700); }
  .prow-desc { font-size: clamp(12.5px, calc(0.375vw + 9.95px), 14px); line-height: 1.5; color: var(--fg-soft); margin-top: 5px; max-width: 560px; overflow: hidden; text-overflow: ellipsis; display: -webkit-box; -webkit-line-clamp: 1; -webkit-box-orient: vertical; }

  /* grid view (toggle): same rows re-laid out as cards */
  .plist.is-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(290px, 1fr)); gap: 14px; }
  .plist.is-grid .prow { display: flex; flex-direction: column; align-items: flex-start; gap: 12px; }
  .plist.is-grid .prow-name { white-space: normal; }

  .empty { text-align: center; padding: 40px; color: var(--fg-mute); font-family: var(--f-mono); font-size: 13px; }

  /* pagination (only when a pageSize is provided) */
  .ppage { display: flex; justify-content: center; align-items: center; gap: 8px; margin-top: 30px; flex-wrap: wrap; }
  .ppage[hidden] { display: none; }
  .ppage button { min-width: 38px; height: 38px; padding: 0 12px; border-radius: var(--r); border: 1.5px solid var(--line-2);
    background: var(--paper); color: var(--fg-soft); font-family: var(--f-mono); font-size: 13px; cursor: pointer; transition: all .15s; }
  .ppage button:hover:not(:disabled):not(.on) { border-color: var(--ink); color: var(--ink); }
  .ppage button.on { border-color: var(--green); color: var(--green-700); background: var(--green-tint); }
  .ppage button:disabled { opacity: .4; cursor: default; }
  .ppage .ppage-ar svg { width: 15px; height: 15px; display: block; }
  .ppage .ppage-prev svg { transform: rotate(180deg); }

  /* Keep the inline 3-column row down to 680px (the sizes above scale fluidly via clamp). Below 680px
     the row crowds, so reflow to a mobile-native card: icons + main on top, author meta on its own line. */
  @media (max-width: 680px) {
    .prow { grid-template-columns: auto 1fr; gap: 14px; }
    .prow-author { grid-column: 1 / -1; justify-content: flex-start; margin-top: 4px; padding-top: 12px; border-top: 1.5px solid var(--line); }
    .author-pop { right: auto; left: 0; } /* author column is left-aligned here; open rightward */
  }
  /* The author hover-card has no use on touch (no hover) and its 244px absolute box spills past a narrow
     viewport (horizontal scroll). Hide it there; the avatar itself stays a tappable link to the profile. */
  @media (hover: none), (max-width: 560px) {
    .author-pop { display: none; }
  }
</style>

<script>
  // Directory: search + category filter + count + grid/list view toggle (rows are server-rendered).
  // Scoped per .browse root so multiple directories on one page (or across pages) work independently.
  document.querySelectorAll<HTMLElement>('.browse').forEach((scope) => {
    const items = scope.querySelector('[data-items]') as HTMLElement;
    if (!items) return;
    const plist = items;
    const btns = Array.from(scope.querySelectorAll<HTMLButtonElement>('[data-filter]'));
    const search = scope.querySelector<HTMLInputElement>('[data-search]')!;
    const count = scope.querySelector('[data-count]') as HTMLElement;
    const cards = Array.from(items.querySelectorAll<HTMLElement>('[data-cat]'));
    const pageSize = parseInt(scope.getAttribute('data-page-size') || '', 10) || 0; // 0 => no pagination
    const pageNav = scope.querySelector<HTMLElement>('[data-ppage]');
    let page = 0;

    const renderPages = (pages: number) => {
      if (!pageNav) return;
      if (pages <= 1) { pageNav.hidden = true; pageNav.innerHTML = ''; return; }
      pageNav.hidden = false;
      const mk = (text: string, aria: string, cls: string, disabled: boolean, target: number, on = false) =>
        `<button class="${cls}${on ? ' on' : ''}" data-page="${target}"${disabled ? ' disabled' : ''} aria-label="${aria}"${on ? ' aria-current="page"' : ''}>${text}</button>`;
      const arrow = '<svg viewBox="0 0 24 24"><use href="#g-arrow"/></svg>';
      let html = mk(arrow, 'Previous page', 'ppage-ar ppage-prev', page <= 0, page - 1);
      for (let i = 0; i < pages; i++) html += mk(String(i + 1), `Page ${i + 1}`, 'ppage-num', false, i, i === page);
      html += mk(arrow, 'Next page', 'ppage-ar ppage-next', page >= pages - 1, page + 1);
      pageNav.innerHTML = html;
      pageNav.querySelectorAll<HTMLButtonElement>('[data-page]').forEach((b) => b.addEventListener('click', () => {
        const t = parseInt(b.dataset.page || '0', 10);
        if (t === page || b.disabled) return;
        page = t;
        apply();
        scope.querySelector('.toolbar')?.scrollIntoView({ behavior: 'smooth', block: 'start' });
      }));
    };

    const apply = () => {
      const active = (scope.querySelector('.tfilter.on') as HTMLElement)?.dataset.filter ?? 'all';
      const q = (search?.value || '').trim().toLowerCase();
      const matched = cards.filter((c) => (active === 'all' || c.dataset.cat === active) && (!q || (c.dataset.name || '').includes(q)));
      if (count) count.textContent = matched.length + (matched.length === 1 ? ' product' : ' products');

      let visible = matched;
      if (pageSize > 0) {
        const pages = Math.max(1, Math.ceil(matched.length / pageSize));
        if (page > pages - 1) page = pages - 1;
        if (page < 0) page = 0;
        visible = matched.slice(page * pageSize, (page + 1) * pageSize);
        renderPages(pages);
      }
      const show = new Set(visible);
      cards.forEach((c) => { c.style.display = show.has(c) ? '' : 'none'; });

      let e = scope.querySelector('.empty');
      if (matched.length === 0) { if (!e) { e = document.createElement('div'); e.className = 'empty'; e.textContent = 'No products match.'; plist.after(e); } }
      else if (e) e.remove();
    };

    const reset = () => { page = 0; apply(); };
    btns.forEach((b) => b.addEventListener('click', () => { btns.forEach((x) => x.classList.remove('on')); b.classList.add('on'); reset(); }));
    search?.addEventListener('input', reset);
    scope.querySelectorAll<HTMLButtonElement>('[data-view]').forEach((v) => v.addEventListener('click', () => {
      scope.querySelectorAll('[data-view]').forEach((x) => x.classList.remove('on'));
      v.classList.add('on');
      plist.classList.toggle('is-grid', v.dataset.view === 'grid');
    }));
    apply();
  });
</script>
