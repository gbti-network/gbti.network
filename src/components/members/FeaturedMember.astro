---
import Container from '../Container.astro';
import type { CollectionEntry } from 'astro:content';

interface Props {
  profile: CollectionEntry<'profile'>;
}
const { profile } = Astro.props;
const d = profile.data;
---
<section class="band tint">
  <Container>
    <div class="sec-head center" style="margin-bottom:36px">
      <p class="eyebrow">Featured network member</p>
      <h2 class="h2 mt12">Meet a member of the co-op.</h2>
    </div>
    <div class="flex col items-center tcenter g16">
      <div class="av" style="width:120px;height:120px;display:grid;place-items:center;overflow:hidden;border-width:3px;border-color:var(--green)">
        {d.avatar ? (
          <img src={d.avatar} alt={d.displayName} style="width:100%;height:100%;object-fit:cover;border-radius:50%" />
        ) : (
          <span class="h2" style="color:var(--green-700)">{d.displayName.charAt(0)}</span>
        )}
      </div>
      <h3 class="h3">{d.displayName}</h3>
      {d.headline && <p class="lead" style="max-width:36rem">{d.headline}</p>}
      <a href={`/members/${d.username}/`} class="btn btn-primary mt8">View profile <svg class="ar" viewBox="0 0 24 24" width="18" height="18"><use href="#ico-arrow"/></svg></a>
    </div>
  </Container>
</section>
