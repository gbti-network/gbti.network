---
import Container from '../Container.astro';
import type { CollectionEntry } from 'astro:content';
import { ICON_PATHS } from '../../lib/social';

interface Props {
  profile: CollectionEntry<'profile'>;
}
const { profile } = Astro.props;
const d = profile.data;

const socials = Object.entries(d.links ?? {})
  .filter(([k, v]) => ICON_PATHS[k] && typeof v === 'string' && /^https?:\/\//.test(v)) as [string, string][];
---
<header class="band-sm dark relative overflow-hidden">
  <Container class="relative flex flex-col items-center gap-8 sm:flex-row sm:items-start sm:gap-12">
    <div class="shrink-0">
      {d.avatar ? (
        <img src={d.avatar} alt={d.displayName} class="h-48 w-48 object-cover sm:h-[300px] sm:w-[300px]" style="border-radius:var(--r-lg);border:4px solid var(--paper);box-shadow:var(--sh-lg)" />
      ) : (
        <div class="grid h-48 w-48 place-items-center sm:h-[300px] sm:w-[300px]" style="border-radius:var(--r-lg);border:4px solid var(--paper);background:var(--ink-2);box-shadow:var(--sh-lg)">
          <span class="h1" style="color:#fff">{d.displayName.charAt(0)}</span>
        </div>
      )}
    </div>
    <div class="flex flex-col gap-3 text-center sm:pt-10 sm:text-left">
      <div class="flex flex-wrap items-center justify-center gap-3 sm:justify-start">
        <h1 class="h1" style="color:#fff">{d.displayName}</h1>
        <span class="chip chip-green">member</span>
      </div>
      {d.headline && <p class="lead">{d.headline}</p>}
      <slot />
      {socials.length > 0 && (
        <div class="mt-2 flex flex-wrap justify-center gap-3 sm:justify-start">
          {socials.map(([k, v]) => (
            <a href={v} target="_blank" rel="noopener noreferrer" data-tooltip={k} class="grid h-11 w-11 place-items-center transition hover:-translate-y-0.5" style="border-radius:var(--r);border:1.5px solid var(--line-dark-2);color:var(--on-dark-soft)">
              <svg viewBox="0 0 24 24" class="h-5 w-5" fill="currentColor" aria-hidden="true"><path d={ICON_PATHS[k]} /></svg>
              <span class="sr-only">{k}</span>
            </a>
          ))}
        </div>
      )}
    </div>
  </Container>
</header>
