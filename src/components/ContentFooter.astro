---
// SOW-050: the unified closing block shared by every content detail page (articles / products / prompts) so the
// discussion + author region reads the same everywhere: the member-aware Community Invite, then the "Written by"
// AuthorBox, then the Comments thread (same centered reading width on all three — the prompt page drops its old
// `wide`). Post-only extras (OpenHistory / RelatedPosts / ContributionCredits) stay on the article page, after
// this block.
import CommunityInvite from './CommunityInvite.astro';
import Comments from './blog/Comments.astro';
import AuthorBox from './blog/AuthorBox.astro';
import type { ShareType } from '../lib/share';

interface Props {
  type: ShareType; // 'post' | 'product' | 'prompt'
  slug: string;
  author: string;
  publishedAt?: Date;
  via?: string; // referral attribution tag; defaults to "<type>:<slug>"
  wide?: boolean; // span the full content-column width (e.g. inside the prompt main column) instead of the centered reading column
  hideAuthor?: boolean; // skip the "Written by" box when the page already shows the author elsewhere (e.g. the prompt sidebar Author card)
}
const { type, slug, author, publishedAt, via, wide = false, hideAuthor = false, aliases = [] } = Astro.props;
const viaTag = via ?? `${type}:${slug}`;
---
<CommunityInvite author={author} via={viaTag} />
{!hideAuthor && <AuthorBox author={author} publishedAt={publishedAt} />}
<Comments targetType={type} targetSlug={slug} author={author} wide={wide} aliases={aliases} />
