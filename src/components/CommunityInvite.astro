---
import { authorDisplay } from '../lib/authors';
import { refCodeForAuthor, REF_COOKIE, REF_VIA_COOKIE, REF_COOKIE_DAYS } from '../lib/referral';

interface Props {
  /** Content author username. Resolved to the author's immutable github_id referral code. */
  author: string;
  /** Where the invite is shown, recorded for attribution, e.g. "post:my-slug". */
  via?: string;
}
const { author, via } = Astro.props;
const display = authorDisplay(author);

// Join CTA carries the author's ref CODE (their immutable github_id) so a converting reader credits this
// content's author. refCode is undefined for house content and unknown authors, so the CTA omits ?ref.
const refCode = refCodeForAuthor(author);
const params = new URLSearchParams();
if (refCode) params.set('ref', refCode);
if (via) params.set('via', via);
const query = params.toString();
const joinHref = query ? `/membership/?${query}` : '/membership/';

const perks = [
  'Publish your profile, blog posts, products, and prompts',
  'Share in co-op profits',
  'Join weekly coaching calls with the community',
];
const isMemberAuthored = author !== 'gbti';
---
<section class="dark" style="max-width:820px;margin:48px auto 0;border-radius:var(--r-lg);overflow:hidden;padding:40px">
  <div class="chip" style="display:inline-flex"><span class="chip-dot"></span> A creator co-op, powered by Git</div>
  <h2 class="h2 mt16" style="color:#fff">Join the GBTI Network</h2>
  <p class="lead mt12">
    The GBTI Network is a creator co-op. Members showcase their work, write articles, share in co-op
    profits, and meet in weekly coaching calls with the community.
  </p>
  <div class="flex col g14 mt24">
    {perks.map((p) => (
      <div class="flex items-center g12">
        <svg viewBox="0 0 24 24" width="20" height="20" style="color:var(--green-mint);flex:none"><use href="#ico-check"/></svg>
        <span style="color:#fff;font-weight:600">{p}</span>
      </div>
    ))}
  </div>
  <p class="lead mt24">
    A 90-day limited-access trial lets you evaluate the community before you pay. Paid membership is $150 per year
    and unlocks your public presence on the network: your profile, blog, products, and prompts.
  </p>
  <div class="flex wrap-w items-center g20 mt28">
    <a href={joinHref} class="btn btn-primary">Become a member <svg class="ar" viewBox="0 0 24 24" width="18" height="18"><use href="#ico-arrow"/></svg></a>
    {isMemberAuthored && (
      <span class="body-sm" style="color:var(--on-dark-mute)">You are reading {display}'s work. Joining from this page credits {display}.</span>
    )}
  </div>
</section>
{refCode && (
  <script
    define:vars={{ refCode, via: via ?? '', cookie: REF_COOKIE, viaCookie: REF_VIA_COOKIE, days: REF_COOKIE_DAYS }}
  >
    // First-touch referral: set the cookie ONLY if it is not already present, so the FIRST member whose
    // content a visitor lands on wins the attribution across the rest of their visit. Self-referral is
    // rejected server-side at signup (the Worker drops a ref equal to the new member's own github_id),
    // so we do not need to know who is viewing here.
    (function () {
      try {
        var has = document.cookie.split('; ').some(function (c) { return c.indexOf(cookie + '=') === 0; });
        if (has) return;
        var maxAge = 60 * 60 * 24 * days;
        document.cookie = cookie + '=' + encodeURIComponent(refCode) + '; path=/; max-age=' + maxAge + '; SameSite=Lax';
        if (via) {
          document.cookie = viaCookie + '=' + encodeURIComponent(via) + '; path=/; max-age=' + maxAge + '; SameSite=Lax';
        }
      } catch (e) { /* cookies disabled: attribution simply does not persist, no error surfaced */ }
    })();
  </script>
)}
