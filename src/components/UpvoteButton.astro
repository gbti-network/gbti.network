---
// UpvoteButton (SOW-057 P4) — forward-compatible, UNWIRED. Shares are extension-only today, so this component is
// not placed on any public page yet; it ships the same inert/upgrade pattern as FavoriteButton so a future public
// Share page can drop it in. A plain visitor sees an up-arrow + count; the light-DOM button is [data-signin], so
// clicking opens the sign-in modal (upvoting needs a GitHub identity, and the threshold trigger is paid-gated).
// When a member's client/extension loads @gbti/client-ui, <gbti-upvote> upgrades into a working toggle that writes
// the deletable edge store (KV), NOT git. The count comes from house/upvote-counts.yml via src/lib/upvotes.ts.
import { upvoteCount } from '../lib/upvotes';
interface Props {
  targetSlug: string; // "<author>/<id>"
  size?: 'sm' | 'md';
}
const { targetSlug, size = 'md' } = Astro.props;
const count = upvoteCount(targetSlug);
---
<gbti-upvote
  data-gbti-target-type="share"
  data-gbti-target-slug={targetSlug}
  data-gbti-count={count}
  data-gbti-region="upvote"
  class:list={['gbti-upvote', size === 'sm' && 'up-sm']}
>
  <button type="button" class="up-pill" data-signin aria-label={`Upvote this share${count > 0 ? `, ${count} so far` : ''}`}>
    <svg viewBox="0 0 24 24" width="16" height="16" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 19V5M5 12l7-7 7 7" /></svg>
    {/* owner QA 2026-07-22: the bare arrow read as meaningless; the full-size pill says what it does. */}
    {size === 'md' && <span class="up-label">Upvote</span>}
    {count > 0 && <span class="up-count">{count}</span>}
  </button>
</gbti-upvote>
<style is:global>
  /* The light-DOM pill is the public (inert) display; when <gbti-upvote> upgrades, its Shadow DOM covers it. */
  gbti-upvote { display: inline-flex; }
  .up-pill {
    display: inline-flex; align-items: center; gap: 6px; cursor: pointer;
    font-family: var(--f-mono); font-size: 12.5px; font-weight: 600; color: var(--fg-mute);
    background: var(--paper); border: 1.5px solid var(--line-2); border-radius: var(--r-pill);
    padding: 5px 11px; transition: color .15s ease, border-color .15s ease;
  }
  .up-pill:hover { color: var(--green-700); border-color: var(--green); }
  .up-pill svg { flex: none; }
  .up-sm .up-pill { padding: 4px 9px; font-size: 12px; }
  [data-theme="dark"] .up-pill { background: transparent; border-color: var(--line-dark-2); color: var(--on-dark-soft); }
  [data-theme="dark"] .up-pill:hover { color: var(--green-mint); border-color: var(--green); }
</style>
