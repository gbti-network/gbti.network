---
// LockedBody (SOW-016): the INERT gated-content placeholder. It ships in the public static build carrying ONLY
// the repo-relative path to the AES-256-GCM .enc body envelope (data-gbti-enc) — never the key, never the
// plaintext. A plain visitor sees the locked notice below. When a member's client (the Chrome extension or the
// npm host) loads @gbti/client-ui, the <gbti-locked-content> custom element upgrades, fetches the .enc, POSTs it
// to the Worker /membership/decrypt (the key never leaves the Worker), renders the returned markdown, and
// replaces this notice. "The code is there but does nothing without the client." Obfuscation for perks, not
// absolute secrecy (see SOW-016).
interface Props {
  encPath?: string; // repo-relative path to the .enc envelope (same convention as EditHooks data-gbti-path)
  kind?: 'body' | 'section' | 'comment' | 'share';
  label?: string;
  readerPath?: string; // SOW-112 QA: the parent item's index.md path; a signed-in PAID member gets an
  // open-in-the-extension CTA deep-linking the reader (newtab.html#tab=<type>&read=<path>) via the
  // gbti:open relay instead of the become-a-member nudge. Presentation only (html.is-gbti-paid, untrusted).
  readerType?: string;
}
const { encPath, kind = 'body', label, readerPath, readerType } = Astro.props;
const readerHash = readerPath && readerType ? `tab=${readerType}&read=${encodeURIComponent(readerPath)}` : null;
const HEADINGS = { comment: 'Members-only comment', section: 'Members-only section', share: 'Members-only Share', body: 'Members-only content' } as const;
const heading = label ?? HEADINGS[kind];
const noun = kind === 'comment' ? 'comment' : kind === 'share' ? 'Share' : 'content';
---
{encPath && (
  <gbti-locked-content data-gbti-enc={encPath} data-gbti-kind={kind} data-gbti-region="locked">
    <div class="locked-notice">
      <svg viewBox="0 0 24 24" width="20" height="20" aria-hidden="true"><use href="#ico-lock" /></svg>
      <div>
        <p class="locked-title">{heading}</p>
        <p class="locked-sub for-visitor">This {noun} is for members. <a href="/membership/">Become a member</a>, then open it in the GBTI client to unlock.</p>
        <p class="locked-sub for-paid">
          You are signed in as a member — this {noun} unlocks in the GBTI extension.
          {readerHash && <button type="button" class="open-ext" data-gbti-open-reader data-hash={readerHash}>Open in the extension</button>}
        </p>
      </div>
    </div>
  </gbti-locked-content>
)}
<style>
  /* The notice is the default visible child for a plain visitor. The client upgrades the element and replaces
     its contents with the decrypted, rendered markdown, so no display toggle is needed. */
  gbti-locked-content { display: block; }
  .locked-notice {
    display: flex; gap: 12px; align-items: flex-start;
    padding: 18px 20px; border: 1.5px dashed var(--line); border-radius: var(--r);
    background: var(--green-tint);
  }
  .locked-notice > svg { flex: none; margin-top: 2px; color: var(--green-700); }
  .locked-title { font-family: var(--f-display); font-weight: 700; }
  .locked-sub { font-size: 14px; color: var(--fg-soft); margin-top: 2px; }
  .locked-sub a { color: var(--green-700); font-weight: 600; }
  /* SOW-112 QA: the paid-member alternative swaps in via the SOW-030 identity classes on <html>. */
  .locked-sub.for-paid { display: none; }
  :global(html.is-gbti-paid) .locked-sub.for-paid { display: block; }
  :global(html.is-gbti-paid) .locked-sub.for-visitor { display: none; }
  .open-ext { font: inherit; font-size: 13px; font-weight: 700; color: var(--green-700); background: none; border: 1.5px solid var(--green-700); border-radius: 8px; padding: 3px 12px; margin-left: 8px; cursor: pointer; }
  .open-ext:hover { background: var(--green-tint); }
</style>

<script>
  // SOW-112 QA: relay the reader deep link to the extension (SOW-036 gbti:open; the content script forwards
  // it to the background, which opens the new-tab reader with the hash). Delegated once (Astro dedupes this script).
  // The content script ACKS a handled relay; without an ack (an older loaded extension that does not know
  // the reader page, or none at all) the button says what to do instead of silently doing nothing.
  let acked = false;
  document.addEventListener('gbti:open-ack', () => { acked = true; });
  document.addEventListener('click', (e) => {
    const b = (e.target as HTMLElement | null)?.closest?.('[data-gbti-open-reader]') as HTMLElement | null;
    if (!b) return;
    acked = false;
    document.dispatchEvent(new CustomEvent('gbti:open', { detail: { page: 'newtab.html', hash: b.dataset.hash || '' } }));
    setTimeout(() => {
      if (!acked) b.textContent = 'Update or reload the GBTI extension, then try again';
    }, 600);
  });
</script>
