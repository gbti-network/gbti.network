---
// A "Subscribe to activity" button (SOW-023). The INERT control: it ships in the public static build as
// `<gbti-subscribe data-gbti-username=..>` wrapping a button + a membership-gated dialog (the visitor path).
// On the static site there is no auth context, so a click opens the dialog with a join CTA. When a member's
// client/extension loads @gbti/client-ui, <gbti-subscribe> upgrades into a real follow toggle for effective-paid
// members (its Shadow DOM covers this light-DOM fallback); a trial/visitor falls back to the membership route.
// The followed `username` may be omitted at build (the prompts directory sets data-gbti-username from JS).
interface Props {
  name?: string; // who you would be subscribing to, for the dialog copy
  username?: string; // the followee's member username (the follow target); set dynamically when absent
  variant?: 'primary' | 'ghost' | 'white';
}
const { name = 'this member', username, variant = 'primary' } = Astro.props;
---
<gbti-subscribe class="subscribe-wrap" data-gbti-region="subscribe" data-gbti-username={username} style="display:inline-flex">
  <button type="button" class={`btn btn-${variant} subscribe-btn`} data-subscribe>
    <svg viewBox="0 0 24 24" width="16" height="16" style="margin-right:6px"><use href="#ico-mega"/></svg>
    Subscribe to activity
  </button>
  <dialog class="subscribe-modal" data-subscribe-modal aria-label="Subscribe to member activity">
    <div class="sm-card">
      {/* State 1 (default): no identity at all -> the become-a-member/join-trial nudge. */}
      <div data-sub-state="join">
        <p class="eyebrow" style="color:var(--green-700)">Member feature</p>
        <h3 class="h3 mt8" data-subscribe-title>Subscribe to {name}</h3>
        <p class="body mt12" style="color:var(--fg-soft)">
          Activity subscriptions are available to GBTI Network members. Join to follow members and get
          their latest posts, products, prompts, and shares in your feed.
        </p>
        <div class="sm-actions mt24">
          <a href="/membership/" class="btn btn-primary">Start your free trial</a>
          <a href="/extension/" class="btn btn-ghost">Already a member? Sign in</a>
          <button type="button" class="btn btn-ghost" data-subscribe-close>Maybe later</button>
        </div>
      </div>
      {/* State 2: a signed-in identity (or the signup hint) but the control never upgraded, meaning
          the GBTI extension is missing here -> the get-the-extension nudge. */}
      <div data-sub-state="extension" hidden>
        <p class="eyebrow" style="color:var(--green-700)">Extension required</p>
        <h3 class="h3 mt8">Follow from the GBTI extension</h3>
        <p class="body mt12" style="color:var(--fg-soft)">
          Follows work from the GBTI browser extension. Install it and sign in, and this button becomes
          a working follow toggle.
        </p>
        <div class="sm-actions mt24">
          <a href="/extension/" class="btn btn-primary">Get the extension</a>
          <button type="button" class="btn btn-ghost" data-subscribe-close>Maybe later</button>
        </div>
      </div>
    </div>
  </dialog>
</gbti-subscribe>

<style>
  /* margin:auto + fit-content height re-centers the modal: Tailwind preflight resets margin:0 on every
     element, which clobbers the UA dialog centering and pins it top-left. */
  .subscribe-modal { border: 0; padding: 0; border-radius: var(--r-lg); max-width: 440px; width: calc(100vw - 32px); background: transparent; margin: auto; height: fit-content; max-height: calc(100dvh - 32px); }
  .subscribe-modal::backdrop { background: rgba(15, 14, 18, .55); backdrop-filter: blur(2px); }
  .subscribe-modal .sm-card { background: var(--paper); color: var(--fg); border: 1px solid var(--line); border-radius: var(--r-lg); padding: 28px; box-shadow: var(--sh-lg); }
  .subscribe-modal .sm-actions { display: flex; flex-wrap: wrap; gap: 12px; }
</style>

<script>
  // One handler set, shared across every SubscribeButton instance on the page. The dialog picks its
  // state AT OPEN TIME (owner directive, 2026-07-21): a visitor with no identity gets the join/trial
  // nudge; an identity (the SOW-030 signal or the signup hint) whose control never upgraded means the
  // extension is missing here, so they get the get-the-extension nudge. When the extension is present
  // and signed in, <gbti-subscribe> upgrades into the real toggle and this dialog never opens.
  function hasIdentity(): boolean {
    if (document.documentElement.dataset.gbtiMember) return true;
    try { return !!localStorage.getItem('gbti_hello'); } catch { return false; }
  }
  document.querySelectorAll('.subscribe-wrap').forEach((wrap) => {
    const btn = wrap.querySelector('[data-subscribe]');
    const dlg = wrap.querySelector('[data-subscribe-modal]') as HTMLDialogElement | null;
    if (!btn || !dlg) return;
    btn.addEventListener('click', () => {
      // Owner QA 2026-07-22: with the extension installed AND a signed-in member, never show the
      // dialog; relay into the extension's follow surface (the workspace Subscriptions tab) instead.
      // (The upgraded shadow toggle normally covers this path; this is the fallback when it has not.)
      const de = document.documentElement.dataset;
      if (de.gbtiExtension && de.gbtiMember) {
        document.dispatchEvent(new CustomEvent('gbti:open', { detail: { page: 'workspace.html', hash: 'tab=subs' } }));
        return;
      }
      const extensionNeeded = hasIdentity();
      dlg.querySelectorAll('[data-sub-state]').forEach((s) => {
        (s as HTMLElement).hidden = s.getAttribute('data-sub-state') !== (extensionNeeded ? 'extension' : 'join');
      });
      dlg.showModal();
    });
    dlg.querySelectorAll('[data-subscribe-close]').forEach((c) => c.addEventListener('click', () => dlg.close()));
    // Click on the backdrop (outside the card) closes the dialog.
    dlg.addEventListener('click', (e) => { if (e.target === dlg) dlg.close(); });
  });
</script>
