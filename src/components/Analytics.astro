---
// GA4 analytics (SOW-024, consent-gated). Wires Google Analytics 4 to the CookieConsent hook so the gtag
// snippet loads ONLY after analytics consent (EU/EEA/UK) or implicitly outside the consent regions. It is
// never loaded unconditionally. The component defines window.gbtiLoadAnalytics (which CookieConsent calls when
// analytics is allowed) AND listens for the gbti:analytics-consent event, so it loads whether the banner fires
// the function or the event, and regardless of which script ran first. Rendered in <head> from BaseLayout,
// ahead of the CookieConsent module so the hook exists when the consent decision resolves.
//
// Property: G-PNM0XPQ6ZB (the GBTI Network GA4 property carried over from the WordPress site). IP
// anonymization is on (GA4 default plus an explicit config). No analytics cookie is set until load() runs.
const GA_ID = 'G-PNM0XPQ6ZB';
---
<script is:inline define:vars={{ GA_ID }}>
  (function () {
    var loaded = false;
    function load() {
      if (loaded || !GA_ID) return;
      loaded = true;
      var s = document.createElement('script');
      s.async = true;
      s.src = 'https://www.googletagmanager.com/gtag/js?id=' + GA_ID;
      document.head.appendChild(s);
      window.dataLayer = window.dataLayer || [];
      function gtag() { window.dataLayer.push(arguments); }
      window.gtag = gtag;
      gtag('js', new Date());
      gtag('config', GA_ID, { anonymize_ip: true });
    }
    // CookieConsent calls this directly when analytics is allowed (granted, or a non-consent-region visitor).
    window.gbtiLoadAnalytics = load;
    // Also load on the consent event, covering any ordering race between this inline head script and the
    // consent banner module (the banner dispatches the event in the same fireAnalytics() path).
    document.addEventListener('gbti:analytics-consent', load);
  })();
</script>
