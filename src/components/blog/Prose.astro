---
// Article body styling — reproduces the legacy blog post-content look
// (source: .data/ops/design-ops/legacy-css/portfolio-lite-child__post.css):
// ~1.2em body, deep-green blockquotes, monospace figcaptions, rounded media.
---
<div class="prose-gbti">
  <slot />
</div>

<style is:global>
  .prose-gbti {
    color: var(--fg-soft);
    font-size: 1.15rem;
    line-height: 1.75;
  }
  .prose-gbti > :first-child { margin-top: 0; }
  .prose-gbti p { margin: 1.1em 0; }
  .prose-gbti h2,
  .prose-gbti h3,
  .prose-gbti h4 {
    font-family: var(--f-display);
    font-weight: 800;
    color: var(--fg);
    line-height: 1.25;
    margin: 1.6em 0 0.5em;
  }
  .prose-gbti h2 { font-size: 1.9rem; }
  .prose-gbti h3 { font-size: 1.5rem; }
  .prose-gbti h4 { font-size: 1.2rem; }
  .prose-gbti a { color: var(--green-700); text-decoration: underline; text-underline-offset: 2px; }
  .prose-gbti a:hover { color: var(--green-600); }
  .prose-gbti ul, .prose-gbti ol { margin: 1.25em 0; padding-left: 1.5em; }
  .prose-gbti li { margin: 0.4em 0; }
  .prose-gbti ul li { list-style: disc; }
  .prose-gbti ol li { list-style: decimal; }
  .prose-gbti blockquote {
    border-left: 9px solid var(--green);
    margin: 1.5em 0;
    padding: 0.2em 0 0.2em 20px;
  }
  .prose-gbti blockquote p { color: var(--fg); font-style: italic; }
  .prose-gbti blockquote cite { display: block; margin-top: 0.5em; color: var(--green-700); font-style: normal; font-size: 0.95rem; }
  .prose-gbti img { border-radius: 10px; margin: 1.5em auto; max-width: 100%; height: auto; }
  .prose-gbti figure { margin: 1.5em auto; text-align: center; }
  .prose-gbti figcaption { font-family: var(--f-mono); background: var(--tint); color: var(--fg-mute); font-size: 0.85rem; padding: 4px 8px; text-align: left; }
  .prose-gbti :not(pre) > code { background: var(--tint); color: var(--fg); padding: 0.15em 0.4em; border-radius: 4px; font-size: 0.9em; }
  .prose-gbti pre { background: var(--ink-2); color: var(--on-dark); padding: 1em; border-radius: 8px; overflow-x: auto; margin: 1.5em 0; }
  .prose-gbti pre code { background: none; padding: 0; }
  /* Code cards: the enhancer script wraps each pre in a .code-card with a header bar (language + a working
     Copy button), mirroring the extension reader's codecard so the two surfaces match. 7px house radius. */
  .prose-gbti .code-card { margin: 1.5em 0; border-radius: 7px; overflow: hidden; border: 1px solid var(--line); }
  .prose-gbti .code-card pre { margin: 0; border-radius: 0; }
  .prose-gbti .code-bar { display: flex; align-items: center; justify-content: space-between; gap: 10px;
    background: var(--ink); color: var(--on-dark); padding: 6px 12px; }
  .prose-gbti .code-lang { font-family: var(--f-mono); font-size: 11px; letter-spacing: .04em; text-transform: uppercase; opacity: .7; }
  .prose-gbti .code-copy { font-family: var(--f-sans); font-size: 11.5px; font-weight: 600; color: var(--on-dark);
    background: transparent; border: 1px solid rgba(255,255,255,.25); border-radius: 6px; padding: 2px 10px; cursor: pointer;
    transition: border-color .15s, color .15s; }
  .prose-gbti .code-copy:hover { border-color: var(--green); color: var(--green); }
  .prose-gbti hr { border: 0; border-top: 1px solid var(--line); margin: 2em 0; }
  .prose-gbti iframe { width: 100%; max-width: 100%; aspect-ratio: 16 / 9; margin: 1.5em 0; border-radius: 10px; }
  /* SOW-062 5d: body callout + embed blocks (rendered by remark-content-blocks.mjs) */
  .prose-gbti .callout { margin: 1.4em 0; border: 1.5px solid var(--line); border-radius: 12px; padding: 14px 16px 14px 46px; position: relative; background: var(--tint, rgba(0,0,0,.02)); }
  .prose-gbti .callout::before { content: ""; position: absolute; left: 16px; top: 17px; width: 18px; height: 18px; border-radius: 50%; }
  .prose-gbti .callout-info { border-color: rgba(63,116,214,.4); background: rgba(63,116,214,.08); }
  .prose-gbti .callout-info::before { background: #3f74d6; }
  .prose-gbti .callout-note::before { background: var(--fg-mute, #888); }
  .prose-gbti .callout-warning { border-color: rgba(216,144,26,.4); background: rgba(224,163,61,.1); }
  .prose-gbti .callout-warning::before { background: #d8901a; }
  .prose-gbti .callout-tip { border-color: rgba(69,192,141,.4); background: rgba(69,192,141,.1); }
  .prose-gbti .callout-tip::before { background: var(--green, #45c08d); }
  .prose-gbti .embed-wrap { position: relative; margin: 1.5em 0; aspect-ratio: 16 / 9; border-radius: 10px; overflow: hidden; background: var(--ink, #000); }
  .prose-gbti .embed-wrap iframe { width: 100%; height: 100%; margin: 0; border: 0; }
  /* GFM footnotes (remark-gfm): superscript refs in the body; the generated end section gets a rule +
     smaller muted type (its own "Footnotes" h2 ships sr-only, so the separation must come from us). */
  .prose-gbti sup a { text-decoration: none; font-weight: 700; padding: 0 1px; }
  .prose-gbti section[data-footnotes] { margin-top: 2.5em; padding-top: 1.2em; border-top: 1px solid var(--line); font-size: 0.9rem; color: var(--fg-mute); }
  .prose-gbti section[data-footnotes] p { margin: 0 0 0.5em; }
  .prose-gbti section[data-footnotes] p:last-child { margin: 0; }
  .prose-gbti section[data-footnotes] li { margin: 0.5em 0; }
  .prose-gbti .data-footnote-backref { text-decoration: none; margin-left: 4px; }
</style>

<script>
  // Code cards: upgrade every fenced code block in rendered prose into a card with a language tag + a
  // working Copy button (the same enhancement the extension reader applies, so the two surfaces match).
  // Runs once per page; shiki emits data-language on the <pre>.
  (() => {
    document.querySelectorAll('.prose-gbti pre').forEach((pre) => {
      if (pre.closest('.code-card')) return; // already enhanced (defensive against double-run)
      const code = pre.querySelector('code');
      const card = document.createElement('div');
      card.className = 'code-card';
      const bar = document.createElement('div');
      bar.className = 'code-bar';
      const tag = document.createElement('span');
      tag.className = 'code-lang';
      tag.textContent = pre.getAttribute('data-language') || 'code';
      const btn = document.createElement('button');
      btn.type = 'button';
      btn.className = 'code-copy';
      btn.textContent = 'Copy';
      btn.addEventListener('click', async () => {
        try {
          await navigator.clipboard.writeText(code ? code.innerText : pre.innerText);
          btn.textContent = 'Copied';
        } catch {
          btn.textContent = 'Copy failed';
        }
        setTimeout(() => { btn.textContent = 'Copy'; }, 1200);
      });
      bar.append(tag, btn);
      pre.replaceWith(card);
      card.append(bar, pre);
    });
  })();
</script>
