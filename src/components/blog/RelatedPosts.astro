---
import { getCollection } from 'astro:content';
import type { CollectionEntry } from 'astro:content';
import { isPublic } from '../../lib/content';
import ArticleCard from './ArticleCard.astro';

interface Props {
  post: CollectionEntry<'post'>;
}
const { post } = Astro.props;

// Related = most shared categories/tags (build-time), like the legacy ".related-posts" block.
const cats = new Set(post.data.categories);
const tags = new Set(post.data.tags);
const related = (await getCollection('post'))
  .filter(isPublic)
  .filter((p) => p.id !== post.id)
  .map((p) => {
    const score =
      p.data.categories.filter((c) => cats.has(c)).length +
      p.data.tags.filter((t) => tags.has(t)).length;
    return { p, score };
  })
  .filter((x) => x.score > 0)
  .sort((a, b) => b.score - a.score || (b.p.data.publishedAt?.valueOf() ?? 0) - (a.p.data.publishedAt?.valueOf() ?? 0))
  .slice(0, 3)
  .map((x) => x.p);
---
{related.length > 0 && (
  <section class="mx-auto" style="max-width:1100px;margin-top:64px">
    <div class="sec-head center">
      <h2 class="h2">Related posts</h2>
    </div>
    <div class="grid gap-8 sm:grid-cols-2 lg:grid-cols-3">
      {related.map((p) => <ArticleCard post={p} />)}
    </div>
  </section>
)}
