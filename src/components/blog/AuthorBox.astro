---
// Compact author box shown at the foot of a post, above the contribution history. The article's author
// (avatar + name + headline + published date) with a link to their member profile.
import { getCollection } from 'astro:content';
import { authorDisplay, authorHref, formatDate } from '../../lib/authors';
import { buildAvatarIndex } from '../../lib/avatars';
import Avatar from '../Avatar.astro';

interface Props {
  author: string;
  publishedAt?: Date;
}
const { author, publishedAt } = Astro.props;
const profiles = await getCollection('profile');
const prof = profiles.find((p) => p.data.username === author)?.data;
const index = buildAvatarIndex(profiles);
const item = index.byUsername.get(author);
const name = prof?.displayName ?? authorDisplay(author);
const headline = prof?.headline;
const href = authorHref(author);
---
<div class="author-box mx-auto">
  <a href={href} class="ab-av" aria-label={name}><Avatar item={{ name, avatar: item?.avatar }} size={46} class="rounded-full" /></a>
  <div class="ab-info">
    <p class="ab-eyebrow">Written by</p>
    <a href={href} class="ab-name">{name}</a>
    {(headline || publishedAt) && (
      <p class="ab-meta">
        {headline && <span>{headline}</span>}
        {headline && publishedAt && <span class="ab-sep" aria-hidden="true">·</span>}
        {publishedAt && <span>Published {formatDate(publishedAt)}</span>}
      </p>
    )}
  </div>
  <a href={href} class="ab-link">View profile <svg class="ar" viewBox="0 0 24 24" width="15" height="15"><use href="#ico-arrow"/></svg></a>
</div>

<style>
  .author-box { max-width: 820px; display: flex; align-items: center; gap: 15px; margin-top: 40px; padding: 16px 20px; border: 1.5px solid var(--line); border-radius: var(--r-lg); background: var(--paper); box-shadow: var(--sh-sm); }
  .ab-av { flex: none; }
  .ab-info { flex: 1 1 auto; min-width: 0; }
  .ab-eyebrow { font-family: var(--f-mono); font-size: 10.5px; font-weight: 600; letter-spacing: .14em; text-transform: uppercase; color: var(--fg-mute); margin-bottom: 1px; }
  .ab-name { display: inline-block; font-family: var(--f-display); font-weight: 700; font-size: 16.5px; letter-spacing: -0.01em; color: var(--fg); }
  .ab-name:hover { color: var(--green-700); }
  .ab-meta { display: flex; flex-wrap: wrap; align-items: center; gap: 7px; margin-top: 2px; font-size: 13px; color: var(--fg-mute); }
  .ab-sep { opacity: .55; }
  .ab-link { flex: none; display: inline-flex; align-items: center; gap: 6px; font-size: 13.5px; font-weight: 600; color: var(--green-700); white-space: nowrap; }
  .ab-link .ar { transition: transform .2s ease; }
  .ab-link:hover { color: var(--green-600); }
  .ab-link:hover .ar { transform: translateX(3px); }
  @media (max-width: 560px) {
    .author-box { flex-wrap: wrap; }
    .ab-link { width: 100%; margin-left: 61px; }
  }
</style>
