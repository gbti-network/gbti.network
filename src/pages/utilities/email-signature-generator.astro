---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CommunityInvite from '../../components/CommunityInvite.astro';
import LatestContent from '../../components/LatestContent.astro';
---
<BaseLayout title="Email Signature Generator" description="Build a professional email signature with live preview and export.">
  <section class="band">
    <div class="wrap">
      <a href="/utilities/" class="link" style="margin-bottom:20px">Back to utilities</a>
      <p class="eyebrow mt16">Free developer tools</p>
      <h1 class="h1 mt12">Email Signature Generator</h1>
      <p class="lead mt16" style="max-width:640px">Build a professional email signature with live preview, multiple templates, and one-click export.</p>
      <CommunityInvite author="gbti" via="applet:email-signature-generator" />
      <iframe
        src="/tools/email-signature-generator/index.html"
        title="Email Signature Generator"
        class="card"
        style="width:100%;height:900px;margin-top:32px;border:0"
        data-autoresize
      ></iframe>
    </div>
  </section>
  <LatestContent />
  <script>
    // Continuously size the same-origin tool iframe to its content height so the tool's own
    // background never shows as whitespace and the page grows/shrinks with the tool state.
    const f = document.querySelector<HTMLIFrameElement>('iframe[data-autoresize]');
    if (f) {
      let last = 0;
      const fit = () => {
        try {
          const doc = f.contentWindow?.document;
          if (!doc) return;
          const h = Math.max(doc.documentElement.scrollHeight, doc.body.scrollHeight);
          if (h > 0 && Math.abs(h - last) > 1) {
            last = h;
            f.style.height = `${h}px`;
          }
        } catch {
          /* same-origin only; ignore */
        }
      };
      f.addEventListener('load', () => {
        fit();
        try {
          const doc = f.contentWindow!.document;
          // Body size changes (template switch, social rows, preview render) and DOM additions re-fit.
          new ResizeObserver(fit).observe(doc.documentElement);
          new ResizeObserver(fit).observe(doc.body);
          new MutationObserver(fit).observe(doc.body, { childList: true, subtree: true, attributes: true });
          // Capture-phase load catches every <img>/media finishing inside the tool.
          doc.addEventListener('load', fit, true);
          doc.addEventListener('transitionend', fit, true);
          f.contentWindow!.addEventListener('resize', fit);
        } catch {
          /* same-origin only; ignore */
        }
        // Poll fallback guarantees the frame tracks any late/async tool change the observers miss.
        setInterval(fit, 250);
      });
    }
  </script>
</BaseLayout>
