---
import BaseLayout from '../../layouts/BaseLayout.astro';

const tools = [
  { title: 'Email Signature Generator', href: '/utilities/email-signature-generator/', desc: 'Build a professional email signature with live preview, multiple templates, and one-click export.' },
  { title: 'JS Animate Hue', href: '/utilities/js-animate-hue/', desc: 'Create colorful hue-shift animations from any image, then export the result.' },
];
---
<BaseLayout title="Utilities" description="Free developer tools from the GBTI Network.">
  <section class="band tint">
    <div class="wrap">
      <div class="sec-head center">
        <p class="eyebrow">Free developer tools</p>
        <h1 class="h1 mt12">Utilities</h1>
        <p class="lead">Free tools from the GBTI Network.</p>
      </div>
      <div class="grid g24" style="grid-template-columns:repeat(auto-fit,minmax(280px,1fr))">
        {tools.map((t) => (
          <a href={t.href} class="card card-hover" style="padding:30px;display:flex;flex-direction:column">
            <h2 class="h3" style="color:var(--fg)">{t.title}</h2>
            <p class="body-sm muted mt12" style="flex:1">{t.desc}</p>
            <span class="link mt20">Open the tool <svg class="ar" viewBox="0 0 24 24" width="18" height="18"><use href="#ico-arrow"/></svg></span>
          </a>
        ))}
        <a href="/membership/" class="card card-hover" style="padding:30px;display:flex;flex-direction:column">
          <span class="chip chip-green">More coming</span>
          <h2 class="h3 mt12" style="color:var(--fg)">Built by the network</h2>
          <p class="body-sm muted mt12" style="flex:1">The GBTI Network builds free developer tools. Join the network to help shape what comes next.</p>
          <span class="link mt20">Become a member <svg class="ar" viewBox="0 0 24 24" width="18" height="18"><use href="#ico-arrow"/></svg></span>
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
