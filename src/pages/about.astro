---
import BaseLayout from '../layouts/BaseLayout.astro';
import TierTable from '../components/TierTable.astro';
import { MEMBERSHIP_PRICE_LABEL, BILLING_PERIOD, TRIAL_DAYS_SITE, REFERRAL_PCT, CONTRIBUTION_PCT, COMMENT_PCT, HOLD_DAYS } from '../lib/membership';

// SOW-010: the "how a creator co-op works" explainer. Static copy, every number single-sourced from
// lib/membership so it tracks the real referral + distribution config.
const flywheel = [
  { n: '01', icon: 'pencil', title: 'You publish', body: 'Write articles, list products, share prompts. Everything lives in a public Git repo and renders on your profile.' },
  { n: '02', icon: 'globe', title: 'Work gets discovered', body: 'Your work reaches developers across the network and the open web, carrying your referral code.' },
  { n: '03', icon: 'users', title: 'A reader joins', body: 'When someone becomes a member because of your work, they join the network as a member too.' },
  { n: '04', icon: 'coin', title: 'You earn a share', body: `You earn ${REFERRAL_PCT} of that member's revenue, for as long as they stay a member.` },
  { n: '05', icon: 'spark', title: 'The network grows', body: 'More members fund more tools, sessions, and shared revenue. The flywheel turns again.' },
];

const git = [
  { icon: 'git', title: 'The repo is the database', body: 'All content lives in one public Git repository. No hidden CMS, no lock-in. What you see is what is committed.' },
  { icon: 'puzzle', title: 'Pull requests are how you publish', body: 'Members author through pull requests. Paid members auto-merge inside their own folder; every change is reviewable.' },
  { icon: 'globe', title: 'The site is the read-view', body: 'The static site is a published view of the repo, rebuilt on every change and served at near-zero cost.' },
  { icon: 'bot', title: 'The client is your authoring node', body: 'A local client lets you and your AI agents draft, preview, and publish through the same gated flow.' },
];

const splits = [
  { pct: REFERRAL_PCT, title: 'Referral share', body: `Earn ${REFERRAL_PCT} of the membership revenue from every member your work brings in, for the life of their membership, paid after a ${HOLD_DAYS}-day hold.` },
  { pct: CONTRIBUTION_PCT, title: 'Contribution pool', body: `Up to ${CONTRIBUTION_PCT} of an item's share is split with the members who improved it through accepted contributions.` },
  { pct: COMMENT_PCT, title: 'Commenter pool', body: `Up to ${COMMENT_PCT} is split with the members whose comments add to the discussion on a piece of work.` },
];
---
<BaseLayout
  title="About GBTI Network"
  description={`About GBTI Network: a creator network built on Git, where the work you publish earns you ${REFERRAL_PCT} of every member it brings in.`}
>
  <!-- ============ HERO ============ -->
  <section class="band tcenter">
    <div class="wrap">
      <div class="chip" style="display:inline-flex"><span class="chip-dot"></span> About</div>
      <h1 class="h1 mt20">A creator network, powered by Git</h1>
      <p class="lead" style="max-width:660px;margin:18px auto 0">
        GBTI is a developer network. Members publish their work, the network helps it get found,
        and the revenue it brings in is shared back with the people who made it.
      </p>
      <div class="hero-c-cta">
        <a href="/membership/" class="btn btn-primary btn-lg">See membership</a>
        <span class="mono muted" style="font-size:13px">{MEMBERSHIP_PRICE_LABEL} a {BILLING_PERIOD}, {TRIAL_DAYS_SITE}-day no-card trial</span>
      </div>
    </div>
  </section>

  <!-- ============ FLYWHEEL ============ -->
  <section class="band tint">
    <div class="wrap">
      <div class="sec-head center">
        <p class="eyebrow">The flywheel</p>
        <h2 class="h2 mt12">How it compounds</h2>
        <p class="lead mt16" style="max-width:600px;margin-left:auto;margin-right:auto">Every member who publishes makes the network more valuable to the next one.</p>
      </div>
      <ol class="flow mt32">
        {flywheel.map((s) => (
          <li class="card flow-step">
            <span class="itile"><svg viewBox="0 0 24 24"><use href={`#ico-${s.icon}`}/></svg></span>
            <span class="flow-num">{s.n}</span>
            <h3 class="h4 mt8">{s.title}</h3>
            <p class="body-sm muted mt8">{s.body}</p>
          </li>
        ))}
      </ol>
    </div>
  </section>

  <!-- ============ BUILT ON GIT ============ -->
  <section class="band">
    <div class="wrap">
      <div class="sec-head center">
        <p class="eyebrow">Local-first, powered by Git</p>
        <h2 class="h2 mt12">Everything runs on Git</h2>
      </div>
      <div class="git-grid2 mt32">
        {git.map((g) => (
          <div class="card inc-tile">
            <span class="itile"><svg viewBox="0 0 24 24"><use href={`#ico-${g.icon}`}/></svg></span>
            <h3 class="h4">{g.title}</h3>
            <p class="body-sm muted mt8">{g.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ============ WHERE THE MONEY GOES ============ -->
  <section class="band tint">
    <div class="wrap">
      <div class="sec-head center">
        <p class="eyebrow">Share the revenue</p>
        <h2 class="h2 mt12">Where the money goes</h2>
        <p class="lead mt16" style="max-width:620px;margin-left:auto;margin-right:auto">The work you publish can pay you back three ways, all flowing to the members who created the value.</p>
      </div>
      <div class="split-grid mt32">
        {splits.map((s) => (
          <div class="card split-card">
            <div class="split-pct">{s.pct}</div>
            <h3 class="h4 mt8">{s.title}</h3>
            <p class="body-sm muted mt8">{s.body}</p>
          </div>
        ))}
      </div>
      <p class="body-sm muted tcenter mt24" style="max-width:620px;margin-left:auto;margin-right:auto">
        Payouts run through Stripe Connect after the {HOLD_DAYS}-day hold. Shares are capped so the original
        author always keeps the majority of what their work earns.
      </p>
    </div>
  </section>

  <!-- ============ COMPARE TIERS ============ -->
  <section class="band">
    <div class="wrap">
      <div class="sec-head center">
        <p class="eyebrow">Who can do what</p>
        <h2 class="h2 mt12">Visitor, trial, and paid</h2>
      </div>
      <div class="tbl mt32" style="max-width:860px;margin-left:auto;margin-right:auto">
        <TierTable />
      </div>
    </div>
  </section>

  <!-- ============ CTA ============ -->
  <section class="band dark tcenter">
    <div class="wrap">
      <h2 class="h2" style="color:#fff">Publish your work. Share in what it earns.</h2>
      <p class="lead" style="max-width:560px;margin:16px auto 0">Start with a {TRIAL_DAYS_SITE}-day, no-card trial of the community.</p>
      <div class="hero-c-cta">
        <a href="/membership/" class="btn btn-primary btn-lg">See membership</a>
        <a href="/products/" class="btn btn-ghost btn-lg">Browse member work</a>
      </div>
    </div>
  </section>

  <style>
    /* Flywheel: numbered step cards, centered flex so 5 steps wrap cleanly (no orphan slot). */
    .flow { list-style: none; padding: 0; margin: 0; display: flex; flex-wrap: wrap; justify-content: center; gap: 20px; }
    .flow-step { flex: 1 1 200px; max-width: 232px; padding: 26px 22px; position: relative; }
    .flow-num { font-family: var(--f-mono); font-size: 12px; font-weight: 700; color: var(--green-600); position: absolute; top: 20px; right: 22px; }
    .dark .flow-num { color: var(--green-mint); }
    @media (max-width: 760px) { .flow-step { flex-basis: 100%; max-width: none; } }

    /* Built-on-Git: 2 x 2 on desktop, 1 col on mobile. */
    .git-grid2 { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; max-width: 900px; margin-left: auto; margin-right: auto; }
    @media (max-width: 760px) { .git-grid2 { grid-template-columns: 1fr; } }

    /* Revenue splits: 3 cards with a big percentage. */
    .split-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px; }
    .split-card { padding: 30px; text-align: center; }
    .split-pct { font-family: var(--f-display); font-weight: 800; font-size: 48px; line-height: 1; letter-spacing: -0.02em; color: var(--green-600); }
    .dark .split-pct { color: var(--green-mint); }
    @media (max-width: 760px) { .split-grid { grid-template-columns: 1fr; } }
  </style>
</BaseLayout>
