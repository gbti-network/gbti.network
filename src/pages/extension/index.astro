---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { EXTENSION, extensionZipUrl } from '../../lib/extension';

// SOW-019: the extension install/download page (design "GBTI Extension Install — Guided", claude.ai/design
// handoff). A guided walkthrough: hero + download, a what-it-does trio, the five unpacked-install steps as a
// vertical timeline each paired with a faithful chrome://extensions mockup, a trust note, and an FAQ. Numbers
// single-sourced from lib/extension. Reuses the V3 globals (band/wrap/eyebrow/card/itile); the chrome mockups
// are pinned light in both themes for recognizability. The "Get the extension" CTAs site-wide point here.
const feats = [
  { icon: 'i-gh', title: 'Sign in with GitHub', body: 'Click the GBTI icon in your toolbar and sign in. Your GitHub credentials stay on your own machine, not on our servers.' },
  { icon: 'i-pencil', title: 'Edit in place', body: 'Open any page you can edit and change it where it lives. No separate dashboard, no copy-paste between tabs.' },
  { icon: 'i-publish', title: 'Publish through the network', body: 'Save a draft or publish straight to the network. Your changes go through the same review flow as everyone else.' },
];
const faqs = [
  { q: 'How do I update it?', a: 'While it is an unpacked extension, download the latest ZIP, unzip it over the old folder, and click Reload on the extensions page. Once the Chrome Web Store listing is live, updates happen on their own.' },
  { q: 'Is my GitHub sign-in safe?', a: 'Yes. Sign-in happens between your browser and GitHub. Your token is stored locally by the extension and never sent to GBTI servers.' },
  { q: 'It did not load, what went wrong?', a: 'Two things to check: Developer mode needs to be on, and you need to select the unzipped folder, not the ZIP file itself. If the folder has a manifest.json at its top level, you picked the right one.' },
  { q: 'Do I need to be a member?', a: 'The extension is free to install and use. Publishing to the network goes through network membership, which is where the review and revenue-share flow lives.' },
  { q: 'Can my AI agent publish for me?', a: 'Yes. The extension folder ships a GBTI MCP server, so an agent like Claude Code can draft, publish, and maintain your content through the same gated flow. Publishing still requires an active paid membership.' },
];

// The recommended prompt a member pastes into Claude Code to wire it up to the GBTI MCP server. Built as a
// line array (not a template literal) so the tool names and the <placeholder> read cleanly without escaping.
const mcpPrompt = [
  'Set up the GBTI Network MCP server in Claude Code so you can publish and maintain my GBTI content.',
  '',
  '1. Register it as an MCP server. If I have the GBTI Chrome extension installed, run the copy that ships in its folder:',
  '     claude mcp add gbti-network -- node <path-to-the-unzipped-extension>/mcp/gbti-network-mcp.mjs',
  '   Otherwise run it straight from npm:',
  '     claude mcp add gbti-network -- npx gbti-network-mcp',
  '',
  '2. Sign me in: call the login tool, give me the GitHub device URL and code, and after I authorize, call login_confirm. Confirm with whoami.',
  '',
  '3. Show what I can work on with list_my_content, then use publish_content to publish or update a post, product, or prompt.',
  '',
  'Important: publishing is a members-only feature of GBTI. publish_content only works when my GitHub account is an active paid member. Without the right privileges the gate rejects the change, so do not attempt to bypass it.',
].join('\n');
---
<BaseLayout
  title="Install the GBTI extension"
  description="Download the GBTI Network browser extension and load it as an unpacked extension to sign in, edit your work in place, and publish through the network."
>
  <svg width="0" height="0" style="position:absolute" aria-hidden="true"><defs>
    <g id="i-dl"><path d="M12 3v12m0 0l-4.5-4.5M12 15l4.5-4.5M5 19h14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></g>
    <g id="i-lock"><rect x="5" y="11" width="14" height="9" rx="2" fill="none" stroke="currentColor" stroke-width="1.8"/><path d="M8 11V8a4 4 0 0 1 8 0v3" fill="none" stroke="currentColor" stroke-width="1.8"/></g>
    <g id="i-gh"><path fill="currentColor" fill-rule="evenodd" clip-rule="evenodd" d="M12 1.6a10.4 10.4 0 0 0-3.29 20.27c.52.1.71-.22.71-.5l-.01-1.75c-2.9.63-3.51-1.4-3.51-1.4-.47-1.2-1.16-1.52-1.16-1.52-.95-.65.07-.64.07-.64 1.05.08 1.6 1.08 1.6 1.08.93 1.6 2.44 1.13 3.04.87.09-.68.36-1.13.66-1.39-2.31-.26-4.74-1.16-4.74-5.14 0-1.14.4-2.06 1.07-2.79-.11-.27-.46-1.32.1-2.76 0 0 .87-.28 2.85 1.06a9.8 9.8 0 0 1 5.19 0c1.98-1.34 2.85-1.06 2.85-1.06.57 1.44.21 2.49.1 2.76.67.73 1.07 1.65 1.07 2.79 0 3.99-2.43 4.87-4.75 5.13.38.32.71.95.71 1.92l-.01 2.85c0 .28.19.61.72.5A10.4 10.4 0 0 0 12 1.6Z"/></g>
    <g id="i-pencil"><path d="M4 20h4L19 9a2 2 0 0 0-3-3L5 17v3z" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linejoin="round"/><path d="M14 7l3 3" fill="none" stroke="currentColor" stroke-width="1.8"/></g>
    <g id="i-publish"><path d="M12 19V8m0 0l-4 4m4-4l4 4M5 5h14" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></g>
    <g id="i-plus"><path d="M12 5v14M5 12h14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></g>
    <g id="i-term"><rect x="3" y="5" width="18" height="14" rx="2" fill="none" stroke="currentColor" stroke-width="1.8"/><path d="M7 10l3 2.5L7 15M12.5 15H16" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></g>
    <g id="i-bot"><rect x="5" y="8" width="14" height="11" rx="3" fill="none" stroke="currentColor" stroke-width="1.8"/><path d="M12 8V4.5M12 4.5h-1.5M9 13h.01M15 13h.01M9.5 16.5h5" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/></g>
  </defs></svg>

  <!-- ============ HERO (download in the header) ============ -->
  <section class="ext-hero">
    <div class="wrap">
      <span class="chip chip-green"><span class="chip-dot"></span> Free · v{EXTENSION.version}</span>
      <h1 class="h1 mt20">Install the GBTI extension</h1>
      <p class="lead">The extension is how you sign in, edit your work in place, and publish through the network. It runs in your browser and keeps your GitHub sign-in on your own machine.</p>
      <div class="dl-row">
        <a class="btn btn-primary btn-lg" href={extensionZipUrl} download><svg viewBox="0 0 24 24" width="19" height="19"><use href="#i-dl"/></svg> Download the extension</a>
        <span class="dl-sub">ZIP · load unpacked</span>
      </div>
      <div class="browsers hero-browsers">
        <span class="bchip"><span class="blogo blogo-chrome"></span> Chrome</span>
        <span class="bchip">
          <span class="blogo"><svg viewBox="0 0 48 48" aria-hidden="true">
            <defs>
              <linearGradient id="edgeA" x1="8" y1="36" x2="40" y2="36" gradientUnits="userSpaceOnUse"><stop offset="0" stop-color="#0c59a4"/><stop offset="1" stop-color="#114a8b"/></linearGradient>
              <linearGradient id="edgeB" x1="12" y1="10" x2="40" y2="34" gradientUnits="userSpaceOnUse"><stop offset="0" stop-color="#35c1f1"/><stop offset=".5" stop-color="#258fb6"/><stop offset="1" stop-color="#2aac4e"/></linearGradient>
            </defs>
            <path fill="url(#edgeA)" d="M41 33c-3 6-9 9-16 9-10 0-18-7-18-17 0-4 1-7 3-10-3 10 4 17 13 17 6 0 11-2 14-6z"/>
            <path fill="url(#edgeB)" d="M24 6c11 0 17 7 17 15 0 4-3 7-7 7-4 0-6-3-10-3-8 0-13 7-7 14-8-3-11-10-11-16C6 14 14 6 24 6z"/>
          </svg></span> Edge</span>
        <span class="bchip">
          <span class="blogo"><svg viewBox="0 0 48 48" aria-hidden="true">
            <path fill="#f8521e" d="M24 4l9 3 3-2 5 5-1.6 4 2.6 7-18 15L6 21l2.6-7L7 10l5-5 3 2z"/>
            <path fill="#fff" d="M24 13l5.5 2.6-1.2 7.4 3 3-7.3 5-7.3-5 3-3-1.2-7.4z" opacity=".96"/>
            <path fill="#f8521e" d="M24 22l2.2 3.2-2.2 1.6-2.2-1.6z"/>
          </svg></span> Brave</span>
        <span class="bchip soon"><span class="d"></span> Chrome Web Store soon</span>
      </div>
    </div>
  </section>

  <!-- ============ EXTENSION MOCKUP (under the header) ============ -->
  <section class="ext-mockwrap">
    <div class="wrap">
      <div class="bw ext-mock">
        <div class="bw-bar">
          <span class="bw-dots"><i></i><i></i><i></i></span>
          <span class="bw-url"><svg viewBox="0 0 24 24"><use href="#i-lock"/></svg> gbti.network/blog/my-article</span>
          <span class="bw-toolbar"><span class="tb-ico"></span><span class="tb-ico tb-gbti">G</span></span>
        </div>
        <div class="ext-stage">
          <!-- the GBTI in-page edit bar the extension injects onto your own pages -->
          <div class="ie-bar">
            <span class="ie-brand"><span class="ie-logo">G</span> GBTI</span>
            <span class="ie-user"><span class="ie-av">A</span> @atwellpub <span class="ie-tag">Paid member</span></span>
            <span class="ie-acts">
              <span class="ie-btn">Save draft</span>
              <span class="ie-btn ie-btn-primary"><svg viewBox="0 0 24 24"><use href="#i-publish"/></svg> Publish</span>
            </span>
          </div>
          <!-- your live article, edited where it lives -->
          <div class="ie-doc">
            <div class="ie-kicker"><span class="ie-dot"></span> Editing in place</div>
            <div class="ie-title">How I shipped my plugin in a weekend</div>
            <div class="ie-byline"><span class="ie-av sm">A</span> by @atwellpub · Article</div>
            <div class="ie-block ie-active">
              <div class="ie-fmt"><span>B</span><span><i>I</i></span><span>H2</span><span class="ie-fmt-link">Link</span></div>
              <p>Change the words right where they live, then publish through the network<span class="ie-caret"></span></p>
            </div>
            <div class="ie-line w92"></div>
            <div class="ie-line w76"></div>
          </div>
        </div>
      </div>
      <p class="ext-mock-cap">Edit your published work right on the page, then publish through the network. No dashboard, no copy-paste.</p>
    </div>
  </section>

  <!-- ============ INSTALL WALKTHROUGH ============ -->
  <section class="band tint" id="install">
    <div class="wrap">
      <div class="sec-head center">
        <p class="eyebrow">Install · about a minute</p>
        <h2 class="h2 mt12">Load it as an unpacked extension</h2>
        <p class="lead">You do this once. The extension keeps working after that. When the Chrome Web Store listing is live, updates become automatic and these steps go away.</p>
      </div>

      <div class="steps mt40">
        <!-- step 1 -->
        <div class="step">
          <div class="step-rail"><span class="step-num">1</span><span class="step-line"></span></div>
          <div class="step-body">
            <h3>Download and unzip</h3>
            <p>Download the ZIP, then unzip it. Keep the unzipped folder somewhere you will not delete it. The browser loads the extension from that folder.</p>
            <div class="step-shot">
              <a class="btn btn-primary" href={extensionZipUrl} download><svg viewBox="0 0 24 24" width="18" height="18"><use href="#i-dl"/></svg> Download the extension</a>
            </div>
          </div>
        </div>
        <!-- step 2 -->
        <div class="step">
          <div class="step-rail"><span class="step-num">2</span><span class="step-line"></span></div>
          <div class="step-body">
            <h3>Open the extensions page</h3>
            <p>In the address bar, type <span class="kbd">chrome://extensions</span> and press Enter. On Edge it is <span class="kbd">edge://extensions</span>; on Brave, <span class="kbd">brave://extensions</span>.</p>
            <div class="step-shot bw">
              <div class="bw-bar">
                <span class="bw-dots"><i></i><i></i><i></i></span>
                <span class="bw-url"><svg viewBox="0 0 24 24"><use href="#i-lock"/></svg> chrome://extensions</span>
              </div>
            </div>
          </div>
        </div>
        <!-- step 3 -->
        <div class="step">
          <div class="step-rail"><span class="step-num">3</span><span class="step-line"></span></div>
          <div class="step-body">
            <h3>Turn on Developer mode</h3>
            <p>Flip the <b>Developer mode</b> toggle in the top-right corner. This is what lets you load an extension from a folder.</p>
            <div class="step-shot bw">
              <div class="bw-page">
                <div class="xp-head">
                  <span class="xp-title"><span class="xp-burger"><i></i><i></i><i></i></span> Extensions</span>
                  <span class="xp-dev">Developer mode <span class="xp-toggle"></span></span>
                </div>
              </div>
            </div>
          </div>
        </div>
        <!-- step 4 -->
        <div class="step">
          <div class="step-rail"><span class="step-num">4</span><span class="step-line"></span></div>
          <div class="step-body">
            <h3>Click Load unpacked</h3>
            <p>A row of buttons appears under the header. Click <b>Load unpacked</b>.</p>
            <div class="step-shot bw">
              <div class="bw-page">
                <div class="xp-head">
                  <span class="xp-title"><span class="xp-burger"><i></i><i></i><i></i></span> Extensions</span>
                  <span class="xp-dev">Developer mode <span class="xp-toggle"></span></span>
                </div>
                <div class="xp-tools">
                  <span class="xp-btn primary"><svg viewBox="0 0 24 24" style="width:14px;height:14px"><use href="#i-plus"/></svg> Load unpacked</span>
                  <span class="xp-btn">Pack extension</span>
                  <span class="xp-btn">Update</span>
                </div>
              </div>
            </div>
          </div>
        </div>
        <!-- step 5 -->
        <div class="step">
          <div class="step-rail"><span class="step-num">5</span><span class="step-line"></span></div>
          <div class="step-body">
            <h3>Select the unzipped folder</h3>
            <p>Pick the folder you unzipped in step 1. The GBTI Network extension shows up in your list and its icon appears in the toolbar. That is it.</p>
            <div class="step-shot bw">
              <div class="bw-page">
                <div class="xp-card">
                  <span class="xp-ico">G</span>
                  <span class="xp-meta">
                    <span class="xp-name">GBTI Network</span>
                    <span class="xp-desc">Edit and publish your work in place.</span>
                    <span class="xp-ver">v{EXTENSION.version}</span>
                  </span>
                  <span class="xp-on">● On</span>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- trust -->
      <div class="trust mt40">
        <span class="itile"><svg viewBox="0 0 24 24"><use href="#i-lock"/></svg></span>
        <div class="t">
          <h3>Your GitHub sign-in stays on your machine</h3>
          <p>The extension talks to GitHub directly from your browser. We never see or store your token, and you can sign out or remove the extension at any time.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ============ WHAT IT DOES ============ -->
  <section class="band-sm">
    <div class="wrap">
      <div class="sec-head center">
        <p class="eyebrow">What it does</p>
        <h2 class="h2 mt12">Three things, once it is installed</h2>
      </div>
      <div class="feat-grid mt32">
        {feats.map((f) => (
          <div class="card feat-card">
            <span class="itile"><svg viewBox="0 0 24 24"><use href={`#${f.icon}`}/></svg></span>
            <h3>{f.title}</h3>
            <p>{f.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ============ MCP / AGENTIC PUBLISHING ============ -->
  <section class="band tint" id="mcp">
    <div class="wrap">
      <div class="sec-head center">
        <p class="eyebrow">Publish with your AI agent</p>
        <h2 class="h2 mt12">It ships with a GBTI MCP server</h2>
        <p class="lead">The extension folder also carries a GBTI MCP server. Connect it to Claude Code or any MCP client and your agent can publish new content and maintain what you have already shipped, through the same gated flow you use in the browser.</p>
      </div>

      <div class="mcp-grid mt40">
        <div class="mcp-copy">
          <ul class="mcp-list">
            <li>
              <span class="mcp-ic"><svg viewBox="0 0 24 24"><use href="#i-publish"/></svg></span>
              <div><b>Author from your agent</b><p>Your agent can draft, validate, and publish posts, products, and prompts, and check the status of your pull requests, all through the managed GBTI tools.</p></div>
            </li>
            <li>
              <span class="mcp-ic"><svg viewBox="0 0 24 24"><use href="#i-gh"/></svg></span>
              <div><b>Signs in as you</b><p>A GitHub device-flow login signs the MCP server in as you. Your token stays on your own machine, the same as the browser extension.</p></div>
            </li>
            <li>
              <span class="mcp-ic"><svg viewBox="0 0 24 24"><use href="#i-bot"/></svg></span>
              <div><b>Same content, both ways</b><p>Edit in the browser or hand it to your agent. Both write to the same files and go through the same review, so nothing drifts.</p></div>
            </li>
          </ul>
          <p class="mcp-note">
            <svg viewBox="0 0 24 24"><use href="#i-lock"/></svg>
            <span>Publishing is a <b>members-only</b> feature of the extension. The MCP server signs in as you, but the gate still applies: <b>only active paid members can publish</b>. Without the right privileges the publish tools are rejected, so an agent cannot push content for a non-member.</span>
          </p>
        </div>

        <div class="mcp-prompt">
          <div class="cb-head"><svg viewBox="0 0 24 24"><use href="#i-term"/></svg> Paste this into Claude Code</div>
          <pre class="codeblock"><code>{mcpPrompt}</code></pre>
        </div>
      </div>
    </div>
  </section>

  <!-- ============ FAQ ============ -->
  <section class="band-sm">
    <div class="wrap">
      <div class="sec-head center">
        <p class="eyebrow">Questions</p>
        <h2 class="h2 mt12">Good to know</h2>
      </div>
      <div class="faq mt24">
        {faqs.map((f, i) => (
          <details class="faq-item" open={i === 0}>
            <summary class="faq-q">{f.q}<svg class="pm" viewBox="0 0 24 24"><use href="#i-plus"/></svg></summary>
            <div class="faq-a"><div>{f.a}</div></div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- ============ CTA ============ -->
  <section class="band dark tcenter">
    <div class="wrap">
      <h2 class="h2" style="color:#fff">Edit and publish your work in place</h2>
      <p class="lead" style="max-width:560px;margin:16px auto 0">Install the free extension, then sign in to start drafting and publishing through the GBTI Network.</p>
      <div class="hero-c-cta">
        <a class="btn btn-primary btn-lg" href={extensionZipUrl} download>Download the extension</a>
        <a class="btn btn-ghost btn-lg" href="/membership/">See membership</a>
      </div>
    </div>
  </section>

  <style>
    /* ---- hero ---- */
    .ext-hero { padding: 72px 0 80px; text-align: center; background: radial-gradient(120% 120% at 50% -20%, var(--paper) 0%, var(--paper-2) 70%); }
    .ext-hero .wrap { max-width: 880px; }
    .ext-hero .lead { max-width: 600px; margin: 18px auto 0; }
    .dl-row { display: inline-flex; flex-direction: column; align-items: center; gap: 12px; margin-top: 32px; }
    .dl-sub { font-family: var(--f-mono); font-size: 13px; color: var(--fg-mute); }
    .hero-browsers { margin-top: 40px; justify-content: center; }

    /* ---- browser support chips ---- */
    .browsers { display: flex; flex-wrap: wrap; gap: 10px 14px; align-items: center; }
    .bchip { display: inline-flex; align-items: center; gap: 9px; padding: 9px 15px; border-radius: var(--r-pill); border: 1.5px solid var(--line-2); background: var(--paper); font-size: 14px; font-weight: 600; color: var(--fg-soft); }
    .bchip .d { width: 8px; height: 8px; border-radius: 50%; background: var(--green); flex: none; }
    .bchip.soon { color: var(--fg-mute); }
    .bchip.soon .d { background: var(--line-2); }
    /* browser logos (Chrome via gradient, Edge + Brave inline SVG) */
    .blogo { width: 18px; height: 18px; flex: none; display: inline-flex; align-items: center; justify-content: center; }
    .blogo svg { width: 18px; height: 18px; display: block; }
    .blogo-chrome { border-radius: 50%; background:
      radial-gradient(circle at 50% 50%, #1a73e8 0 30%, #fff 30% 41%, rgba(255,255,255,0) 41%),
      conic-gradient(from 60deg, #fbbc05 0 120deg, #34a853 120deg 240deg, #ea4335 240deg 360deg); }

    /* ---- extension mockup (pinned light, sits under the hero) ---- */
    .ext-mockwrap { background: var(--paper-2); }
    .ext-mock { max-width: 760px; margin: -56px auto 0; position: relative; z-index: 3; }
    .bw-toolbar { display: inline-flex; align-items: center; gap: 10px; flex: none; margin-left: 4px; }
    .tb-ico { width: 22px; height: 22px; border-radius: 50%; background: #e8eaed; flex: none; }
    .tb-gbti { background: var(--green); color: #fff; display: inline-flex; align-items: center; justify-content: center; font-family: var(--f-display); font-weight: 800; font-size: 13px; box-shadow: 0 0 0 2px #d7f0e2; }
    .ext-stage { position: relative; background: #fff; }
    /* the in-page edit bar the extension injects on your own pages */
    .ie-bar { display: flex; align-items: center; gap: 12px; flex-wrap: wrap; padding: 11px 16px; background: #fff; border-bottom: 1px solid #e8eaed; }
    .ie-brand { display: inline-flex; align-items: center; gap: 7px; font-family: var(--f-display); font-weight: 800; font-size: 14px; color: #202124; }
    .ie-logo { width: 22px; height: 22px; border-radius: 6px; background: var(--green); color: #fff; display: inline-flex; align-items: center; justify-content: center; font-size: 13px; flex: none; }
    .ie-user { display: inline-flex; align-items: center; gap: 7px; font-size: 12.5px; color: #5f6368; }
    .ie-av { width: 22px; height: 22px; border-radius: 50%; background: #1f9e5f; color: #fff; display: inline-flex; align-items: center; justify-content: center; font-family: var(--f-display); font-weight: 700; font-size: 11px; flex: none; }
    .ie-av.sm { width: 20px; height: 20px; font-size: 10px; }
    .ie-tag { background: #e8f6ef; color: #137a48; font-size: 10.5px; font-weight: 600; padding: 2px 7px; border-radius: 999px; }
    .ie-acts { margin-left: auto; display: inline-flex; gap: 8px; }
    .ie-btn { display: inline-flex; align-items: center; gap: 7px; font-size: 12.5px; font-weight: 600; color: #3c4043; border: 1px solid #dadce0; border-radius: 8px; padding: 7px 12px; background: #fff; }
    .ie-btn svg { width: 15px; height: 15px; flex: none; }
    .ie-btn-primary { background: var(--green); border-color: var(--green); color: #fff; }
    .ie-doc { padding: 22px 26px 28px; }
    .ie-kicker { display: inline-flex; align-items: center; gap: 7px; font-family: var(--f-mono); font-size: 11px; letter-spacing: .09em; text-transform: uppercase; color: #1e8e3e; }
    .ie-dot { width: 7px; height: 7px; border-radius: 50%; background: #1e8e3e; flex: none; }
