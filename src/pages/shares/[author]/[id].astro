---
// sow-094 (owner-directed, 2026-07-21): the public share's own deep-linked expanded view, mirroring
// the extension's share reader. PUBLIC shares ONLY (published + visibility:public, the fail-closed
// isPublicShare); a members-only or draft share gets NO page (the check-build-secrets guard proves
// dist/shares/ carries nothing else). The page leads with the external "Read on <domain>" CTA
// (noopener nofollow) and mounts the member discussion, which renders GATED (share comments are
// always members-only + encrypted, SOW-044; visitors see locked placeholders + the join nudge).
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Avatar from '../../../components/Avatar.astro';
import UpvoteButton from '../../../components/UpvoteButton.astro';
import SubscribeButton from '../../../components/SubscribeButton.astro';
import Comments from '../../../components/blog/Comments.astro';
import { getCollection } from 'astro:content';
import { authorDisplay, authorHref, formatDate, authorAvatar } from '../../../lib/authors';
import { isPublicShare, decodeEntities } from '../../../lib/home-feed.mjs';

export async function getStaticPaths() {
  const shares = (await getCollection('share')).filter((s) => isPublicShare(s.data));
  return shares.map((s) => ({ params: { author: s.data.author, id: s.data.id }, props: { share: s } }));
}

const { share } = Astro.props;
const d = share.data;
const slug = `${d.author}/${d.id}`;
const title = decodeEntities(d.title ?? d.shortDescription ?? 'A member share');
const desc = d.title && d.shortDescription ? decodeEntities(d.shortDescription) : undefined;
let srcDomain: string | undefined;
try { srcDomain = d.url ? new URL(d.url).hostname.replace(/^www\./, '') : undefined; } catch { srcDomain = undefined; }
const profiles = await getCollection('profile');
const profile = profiles.find((p) => p.data.username === d.author);
const avatar = authorAvatar(d.author, profile?.data.avatar);
const headline = profile?.data.headline;
const body = (share.rendered?.html ?? '').trim();
---
<BaseLayout title={title} description={desc ?? `A link ${authorDisplay(d.author)} shared with the GBTI Network.`} ogImage={typeof d.image === 'string' && d.image ? d.image : undefined} ogType="article">
  <div class="wrap detail-page">
    <nav class="share-crumb"><a href="/feeds/shares/" class="link">&larr; Shares feed</a></nav>
    <div class="detail-grid">
    <div class="detail-main">
    <article>
      <div class="feed-meta" style="margin-bottom:14px">
        <a href={authorHref(d.author)}><Avatar item={{ name: authorDisplay(d.author), avatar }} class="av" size={34} /></a>
        <span class="tmeta"><a class="who" href={authorHref(d.author)}>{authorDisplay(d.author)}</a><span class="dotsep"></span>{formatDate(d.createdAt)}</span>
        <span class="kind-tag kt-share">shared{srcDomain ? ` · ${srcDomain}` : ''}</span>
      </div>

      <h1 class="h1 share-title">{title}</h1>
      {desc && <p class="lead" style="margin-top:14px">{desc}</p>}

      {typeof d.image === 'string' && d.image && (
        <a href={d.url} target="_blank" rel="noopener nofollow" class="share-hero" aria-hidden="true" tabindex="-1"><img src={d.image} alt="" loading="lazy" decoding="async" /></a>
      )}

      {body && <div class="cmt-rich share-note" set:html={body} />}

      <div class="share-actions">
        {d.url && <a href={d.url} target="_blank" rel="noopener nofollow" class="btn btn-primary">Read on {srcDomain ?? 'the source'} <svg class="ar" viewBox="0 0 24 24" width="18" height="18"><use href="#ico-arrow"/></svg></a>}
        <UpvoteButton targetSlug={slug} />
      </div>

      {d.tags?.length > 0 && (
        <div class="tags" style="margin-top:22px">
          {d.tags.map((t: string) => <a class="tag" href={`/feeds/?tag=${encodeURIComponent(String(t).toLowerCase())}`}>#{String(t).toLowerCase()}</a>)}
        </div>
      )}
    </article>

    {/* The member discussion: share comments are members-only + encrypted (SOW-044), so the thread
        renders locked placeholders for visitors with the become-a-member nudge, and upgrades in the
        extension for members. */}
    <Comments targetType="share" targetSlug={slug} author={d.author} wide={true} />
    </div>

    {/* The extension-style right sidebar (owner QA, 2026-07-21): the member card + the source card. */}
    <aside class="detail-side">
      <div class="card side-author-card">
        <a href={authorHref(d.author)} class="sac-head">
          <Avatar item={{ name: authorDisplay(d.author), avatar }} class="av" size={52} />
          <span class="sac-info">
            <span class="sac-name">{authorDisplay(d.author)}</span>
            {headline && <span class="sac-role">{headline}</span>}
          </span>
        </a>
        <SubscribeButton name={authorDisplay(d.author)} username={d.author} variant="ghost" />
      </div>
      {srcDomain && (
        <div class="card news-source-card">
          <img class="nsc-fav" alt="" width="40" height="40" src={`https://www.google.com/s2/favicons?domain=${encodeURIComponent(srcDomain)}&sz=64`} onerror="this.remove()" />
          <div class="nsc-info">
            <div class="nsc-name">{srcDomain}</div>
            <div class="nsc-desc">The source {authorDisplay(d.author)} shared this from.</div>
          </div>
          {d.url && <a href={d.url} target="_blank" rel="noopener nofollow" class="btn btn-ghost nsc-follow">Visit</a>}
        </div>
      )}
    </aside>
    </div>
  </div>
</BaseLayout>
