<script is:inline>
  // The contribution heatmap is server-rendered from real publish dates. The filter chips below need
  // client behavior, scoped per section so the directories and the "Recent Activity" row do not clash.
  (function () {
    // "Recent Activity" chips filter the grid by content type. Each top-level card in .works-grid
    // carries a data-type (Article | Product | Prompt); each chip a data-filter ("all" or a type).
    var row = document.querySelector('.filter-row');
    var grid = document.querySelector('.works-grid');
    if (row && grid) {
      var rowChips = row.querySelectorAll('.filter');
      var cards = grid.querySelectorAll('[data-type]');
      function applyFilter(type) {
        cards.forEach(function (c) {
          var show = type === 'all' || c.getAttribute('data-type') === type;
          // Inline display beats the .work-* { display:flex } class rules; hidden is for a11y.
          c.style.display = show ? '' : 'none';
          c.hidden = !show;
        });
      }
      rowChips.forEach(function (f) {
        f.addEventListener('click', function () {
          rowChips.forEach(function (x) { x.classList.remove('on'); x.setAttribute('aria-pressed', 'false'); });
          f.classList.add('on');
          f.setAttribute('aria-pressed', 'true');
          applyFilter(f.getAttribute('data-filter') || 'all');
        });
      });
    }
  })();
</script>
