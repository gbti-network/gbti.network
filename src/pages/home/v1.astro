---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';
import Avatar from '../../components/Avatar.astro';
import { isPublic, byNewest } from '../../lib/content';
import { authorDisplay, authorHref, formatDate } from '../../lib/authors';
import { buildAvatarIndex, authorItem } from '../../lib/avatars';
import { TRIAL_DAYS_SITE, FIRST_TOUCH_PCT, LAST_TOUCH_PCT, COLLAB_POOL_PCT, INVITE_PCT } from '../../lib/membership';
import TierTable from '../../components/TierTable.astro';
import { extensionInstallUrl } from '../../lib/extension';
import ampPublishOnce from '../../assets/amp-publish-once.webp';

// Real content drives the dynamic sections (hero members, activity, what-members-ship).
const posts = (await getCollection('post')).filter(isPublic).sort(byNewest);
// SOW-022: applets list among products (their cards link via catalogHref to the running tool).
const products = [...(await getCollection('product')), ...(await getCollection('applet'))].filter(isPublic).sort(byNewest);
const prompts = (await getCollection('prompt')).filter(isPublic).sort(byNewest);
const members = (await getCollection('profile')).filter(isPublic).filter((p) => p.data.username !== 'gbti');
const avatarIndex = buildAvatarIndex(members);

// Hero: real member count + member avatars (up to 50, the rest are summed in "& growing").
const memberCount = members.length;
const heroMembers = members.slice(0, 50);

// "What members ship": a featured post (left), two products stacked (right column), and recent
// prompts + articles as minis. Prompts come first, then articles (each article mini shows its cover).
const featured = posts[0];
const featuredProducts = products.slice(0, 2);
const promptMinis = prompts.map((p) => ({ kind: 'Prompt', title: p.data.title, href: `/prompts/${p.data.slug}/`, img: undefined, desc: p.data.shortDescription, author: p.data.author, date: p.data.publishedAt }));
const articleMinis = posts.slice(1).map((p) => ({ kind: 'Article', title: p.data.title, href: `/articles/${p.data.slug}/`, img: p.data.coverImage, desc: undefined as string | undefined, author: p.data.author, date: p.data.publishedAt }));
const minis = [...promptMinis, ...articleMinis].slice(0, 6);

// Activity feed: the latest content across types, newest first.
const feed = [
  ...posts.map((p) => ({ kind: 'Article', title: p.data.title, href: `/articles/${p.data.slug}/`, author: p.data.author, date: p.data.publishedAt })),
  ...products.map((p) => ({ kind: 'Product', title: p.data.title, href: `/products/${p.data.slug}/`, author: p.data.author, date: p.data.publishedAt })),
]
  .sort((a, b) => Number(b.date ?? 0) - Number(a.date ?? 0))
  .slice(0, 5);

// Short relative time for the activity feed (build-time).
const NOW = Date.now();
function relTime(d?: Date): string {
  if (!d) return '';
  const days = Math.max(0, Math.floor((NOW - d.valueOf()) / 86400000));
  if (days < 1) return 'today';
  if (days < 30) return `${days}d`;
  if (days < 365) return `${Math.round(days / 30)}mo`;
  return `${Math.round(days / 365)}y`;
}

const stats = [
  { n: posts.length, l: posts.length === 1 ? 'article' : 'articles' },
  { n: products.length, l: products.length === 1 ? 'product' : 'products' },
  { n: memberCount, l: memberCount === 1 ? 'member' : 'members' },
];

// Contribution heatmap from REAL publishing activity: bucket every content publish date across the
// project's history into 126 cells (7 rows x 18 cols), coloured by volume (level 0..4).
const stamps = [...posts, ...products, ...prompts]
  .map((c) => c.data.publishedAt)
  .filter((d): d is Date => !!d)
  .map((d) => Number(d))
  .sort((a, b) => a - b);
let heat: number[] = new Array(126).fill(0);
if (stamps.length) {
  const min = stamps[0];
  const span = Math.max(1, stamps[stamps.length - 1] - min);
  const counts = new Array(126).fill(0);
  for (const t of stamps) counts[Math.min(125, Math.floor(((t - min) / span) * 126))]++;
  heat = counts.map((n) => (n === 0 ? 0 : Math.min(4, n)));
}

---
<!-- The v1 homepage, archived unindexed at /home/v1/ when the feed homepage replaced it (SOW-136). -->
<BaseLayout noindex={true} title="Publish your work. Build with peers. Share the revenue." description={`A creator network powered by Git. Publish articles, products, and prompts, build with peers, and earn from the members your work brings in: ${FIRST_TOUCH_PCT} for the first touch, ${LAST_TOUCH_PCT} for the last touch, plus a ${INVITE_PCT} invite lane. Start a ${TRIAL_DAYS_SITE}-day limited-access trial, no card required.`}>

<!-- ============ HERO (centered) ============ -->
<section class="hero hero-centered">
  <div class="wrap hero-c">
    <div class="chip"><span class="chip-dot"></span> A creator network, powered by Git</div>
    <h1 class="h-hero mt20">Publish your work. Build with peers. <span class="grn">Share the revenue.</span></h1>
    <p class="lead">The work you publish can earn up to {FIRST_TOUCH_PCT} of every member it helps bring in, for the life of their membership.</p>
    <div class="hero-c-cta">
      <a href="/membership/" class="btn btn-primary btn-lg">Start your {TRIAL_DAYS_SITE}-day limited-access trial</a>
      <a href="/revenue-model/" class="btn btn-ghost btn-lg">See how revenue sharing works <svg class="ar" viewBox="0 0 24 24" width="18" height="18"><use href="#ico-arrow"/></svg></a>
    </div>
    <p class="mono muted" style="font-size:13px;margin-top:14px">No card required</p>
    <div class="hero-c-members">
      <div class="lav-row">
        {heroMembers.map((m) => (
          <a href={authorHref(m.data.username)} data-tooltip={m.data.displayName} aria-label={m.data.displayName}>
            <Avatar item={{ name: m.data.displayName, avatar: m.data.avatar }} class="lav" size={42} />
          </a>
        ))}
      </div>
      <span class="body-sm muted"><strong style="color:var(--fg)">{memberCount} member{memberCount === 1 ? '' : 's'}</strong> &amp; growing</span>
    </div>
  </div>
</section>

<!-- ============ ACTIVITY ============ -->
<section class="band tint" id="activity">
  <div class="wrap">
    <div class="sec-head">
      <div>
        <p class="eyebrow">All network activity powered through Git</p>
      </div>
      <a href="https://github.com/gbti-network/gbti.network" class="link">View the public repo <svg class="ar" viewBox="0 0 24 24" width="18" height="18"><use href="#ico-arrow"/></svg></a>
    </div>
    <div class="act-grid">
      <!-- heatmap + stats -->
      <div class="card act-card">
        <p class="mono" style="font-size:11px;letter-spacing:.12em;text-transform:uppercase;color:var(--fg-mute);margin-bottom:16px">Publishing activity</p>
        <div class="heat" aria-hidden="true">{heat.map((lv) => <span class={lv ? `l${lv}` : undefined}></span>)}</div>
        <div class="heat-legend">
          <span>Less</span>
          <i style="background:var(--tint)"></i><i class="l1"></i><i class="l2"></i><i class="l3"></i><i class="l4"></i>
          <span>More</span>
        </div>
        <div class="act-stats">
          {stats.map((s) => <div class="stat"><div class="n">{s.n}</div><div class="l">{s.l}</div></div>)}
        </div>
      </div>
      <!-- recent published content -->
      <div class="card pr-card">
        <p class="pr-head">Latest published</p>
        {feed.map((it) => (
          <a class="pr-row" href={it.href} title={`${it.title} (${it.kind} by ${authorDisplay(it.author)}, ${formatDate(it.date)})`}>
            <span class="pr-status"><span class="pr-dot merged"></span><span class="chip chip-green" style="padding:2px 9px">published</span></span>
            <span class="pr-num">{it.kind}</span>
            <span class="pr-title">{it.title}</span>
            <Avatar item={authorItem(it.author, avatarIndex)} class="pr-av av" size={26} title={authorDisplay(it.author)} />
            <span class="pr-when">{formatDate(it.date)}</span>
          </a>
        ))}
        {feed.length === 0 && <div class="pr-row"><span class="pr-title muted">No published content yet.</span></div>}
      </div>
    </div>
  </div>
</section>

<!-- ============ WHAT MEMBERSHIP LETS YOU DO ============ -->
<section class="band" id="capability">
  <div class="wrap">
    <div class="sec-head">
      <div>
        <h2 class="h2">What network membership includes</h2>
        <p class="lead">One membership gives you a place to publish, build, and earn.</p>
      </div>
    </div>
    <div class="cap-grid">
      <div class="card cap-card">
        <span class="itile"><svg viewBox="0 0 24 24"><use href="#ico-pencil"/></svg></span>
        <h3 class="h3">Publish articles</h3>
        <p class="body-sm muted mt12">Share tutorials, essays, and field notes under your own name.</p>
      </div>
      <div class="card cap-card">
        <span class="itile"><svg viewBox="0 0 24 24"><use href="#ico-box"/></svg></span>
        <h3 class="h3">List your work</h3>
        <p class="body-sm muted mt12">Promote products, plugins, tools, and creative work in the directory.</p>
      </div>
      <div class="card cap-card">
        <span class="itile"><svg viewBox="0 0 24 24"><use href="#ico-users"/></svg></span>
        <h3 class="h3">Join builders</h3>
        <p class="body-sm muted mt12">Private Discord, weekly build sessions, and hands-on coaching.</p>
      </div>
      <div class="card cap-card">
        <span class="itile"><svg viewBox="0 0 24 24"><use href="#ico-chart"/></svg></span>
        <h3 class="h3">Grow visibly</h3>
        <p class="body-sm muted mt12">A public profile, real feedback, and proof of what you ship.</p>
      </div>
      <div class="card cap-card">
        <span class="itile"><svg viewBox="0 0 24 24"><use href="#ico-coin"/></svg></span>
        <h3 class="h3">Share revenue</h3>
        <p class="body-sm muted mt12">Earn when the work you publish brings new members in.</p>
      </div>
      <div class="card cap-cta">
        <svg class="cap-cta-bg" viewBox="0 0 640 512" aria-hidden="true" fill="currentColor"><path d="M72 88a56 56 0 1 1 112 0a56 56 0 1 1-112 0m-8 157.7c-10 11.2-16 26.1-16 42.3s6 31.1 16 42.3v-84.7zm144.4-49.3C178.7 222.7 160 261.2 160 304c0 34.3 12 65.8 32 90.5V416c0 17.7-14.3 32-32 32H96c-17.7 0-32-14.3-32-32v-26.8C26.2 371.2 0 332.7 0 288c0-61.9 50.1-112 112-112h32c24 0 46.2 7.5 64.4 20.3zM448 416v-21.5c20-24.7 32-56.2 32-90.5c0-42.8-18.7-81.3-48.4-107.7C449.8 183.5 472 176 496 176h32c61.9 0 112 50.1 112 112c0 44.7-26.2 83.2-64 101.2V416c0 17.7-14.3 32-32 32h-64c-17.7 0-32-14.3-32-32m8-328a56 56 0 1 1 112 0a56 56 0 1 1-112 0m120 157.7v84.7c10-11.3 16-26.1 16-42.3s-6-31.1-16-42.3zM320 32a64 64 0 1 1 0 128a64 64 0 1 1 0-128m-80 272c0 16.2 6 31 16 42.3v-84.7c-10 11.3-16 26.1-16 42.3zm144-42.3v84.7c10-11.3 16-26.1 16-42.3s-6-31.1-16-42.3zm64 42.3c0 44.7-26.2 83.2-64 101.2V448c0 17.7-14.3 32-32 32h-64c-17.7 0-32-14.3-32-32v-42.8c-37.8-18-64-56.5-64-101.2c0-61.9 50.1-112 112-112h32c61.9 0 112 50.1 112 112"/></svg>
        <div class="cap-cta-content">
          <h3 class="h3">One membership.<br/>Powerful community.</h3>
          <a href="/membership/" class="btn btn-primary" style="align-self:flex-start">Start your limited-access trial <svg class="ar" viewBox="0 0 24 24" width="18" height="18"><use href="#ico-arrow"/></svg></a>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ============ POWERED THROUGH GIT ============ -->
<section class="band gtint" id="git">
  <div class="wrap">
    <div class="git-grid">
      <div class="git-left">
        <p class="eyebrow">Built on Git</p>
        <h2 class="h2 mt12">The entire ecosystem is powered through Git.</h2>
        <p class="lead mt16">Every post, product, prompt, profile, and comment is a file in a public Git repository, but you never touch Git directly. All content management happens through a Chrome extension, MCP servers, or agent-ready publishing.</p>
        <div class="git-logo" aria-hidden="true">
          <svg viewBox="0 0 496 512" role="img" aria-label="GitHub"><path fill="currentColor" d="M165.9 397.4c0 2-2.3 3.6-5.2 3.6-3.3.3-5.6-1.3-5.6-3.6 0-2 2.3-3.6 5.2-3.6 3-.3 5.6 1.3 5.6 3.6zm-31.1-4.5c-.7 2 1.3 4.3 4.3 4.9 2.6 1 5.6 0 6.2-2s-1.3-4.3-4.3-5.2c-2.6-.7-5.5.3-6.2 2.3zm44.2-1.7c-2.9.7-4.9 2.6-4.6 4.9.3 2 2.9 3.3 5.9 2.6 2.9-.7 4.9-2.6 4.6-4.6-.3-1.9-3-3.2-5.9-2.9zM244.8 8C106.1 8 0 113.3 0 252c0 110.9 69.8 205.8 169.5 239.2 12.8 2.3 17.3-5.6 17.3-12.1 0-6.2-.3-40.4-.3-61.4 0 0-70 15-84.7-29.8 0 0-11.4-29.1-27.8-36.6 0 0-22.9-15.7 1.6-15.4 0 0 24.9 2 38.6 25.8 21.9 38.6 58.6 27.5 72.9 20.9 2.3-16 8.8-27.1 16-33.7-55.9-6.2-112.3-14.3-112.3-110.5 0-27.5 7.6-41.3 23.6-58.9-2.6-6.5-11.1-33.3 2.6-67.9 20.9-6.5 69 27 69 27 20-5.6 41.5-8.5 62.8-8.5s42.8 2.9 62.8 8.5c0 0 48.1-33.6 69-27 13.7 34.7 5.2 61.4 2.6 67.9 16 17.7 25.8 31.5 25.8 58.9 0 96.5-58.9 104.2-114.8 110.5 9.2 7.9 17 22.9 17 46.4 0 33.7-.3 75.4-.3 83.6 0 6.5 4.6 14.4 17.3 12.1C428.2 457.8 496 362.9 496 252 496 113.3 383.5 8 244.8 8zM97.2 352.9c-1.3 1-1 3.3.7 5.2 1.6 1.6 3.9 2.3 5.2 1 1.3-1 1-3.3-.7-5.2-1.6-1.6-3.9-2.3-5.2-1zm-10.8-8.1c-.7 1.3.3 2.9 2.3 3.9 1.6 1 3.6.7 4.3-.7.7-1.3-.3-2.9-2.3-3.9-2-.6-3.6-.3-4.3.7zm32.4 35.6c-1.6 1.3-1 4.3 1.3 6.2 2.3 2.3 5.2 2.6 6.5 1 1.3-1.3.7-4.3-1.3-6.2-2.2-2.3-5.2-2.6-6.5-1zm-11.4-14.7c-1.6 1-1.6 3.6 0 5.9 1.6 2.3 4.3 3.3 5.6 2.3 1.6-1.3 1.6-3.9 0-6.2-1.4-2.3-4-3.3-5.6-2z"/></svg>
        </div>
      </div>
      <div>
        <p class="git-stack-label">Three ways to manage your content</p>
        <div class="card git-card">
          <span class="itile"><svg viewBox="0 0 24 24"><use href="#ico-puzzle"/></svg></span>
          <div>
            <div class="flex items-center g12"><span class="num">01</span><h3 class="h3">Chrome extension</h3></div>
            <p class="body-sm muted mt8">Manage all your content right in the browser: draft, edit, and submit articles, products, and prompts. No Git knowledge required.</p>
          </div>
        </div>
        <div class="card git-card">
          <span class="itile"><svg viewBox="0 0 24 24"><use href="#ico-terminal"/></svg></span>
          <div>
            <div class="flex items-center g12"><span class="num">02</span><h3 class="h3">MCP servers</h3></div>
            <p class="body-sm muted mt8">Connect your own tools and AI agents through Model Context Protocol endpoints to manage content programmatically.</p>
          </div>
        </div>
        <div class="card git-card">
          <span class="itile"><svg viewBox="0 0 24 24"><use href="#ico-bot"/></svg></span>
          <div>
            <div class="flex items-center g12"><span class="num">03</span><h3 class="h3">Agent-ready publishing</h3></div>
            <p class="body-sm muted mt8">Hand the workflow to your AI agents, and they open pull requests and publish on your behalf, end to end.</p>
          </div>
        </div>
        <a href="/membership/" class="link mt24">See the authoring model <svg class="ar" viewBox="0 0 24 24" width="18" height="18"><use href="#ico-arrow"/></svg></a>
      </div>
    </div>
  </div>
</section>

<!-- ============ NEW TAB EXTENSION ============ -->
<section class="band" id="newtab">
  <div class="wrap">
    <div class="newtab-grid">
      <div>
        <p class="eyebrow">Chrome extension</p>
        <h2 class="h2 mt12">Open a tab. Open the network.</h2>
        <p class="lead mt16">The GBTI Network extension brings the community straight into your daily browser. Optionally, it takes over your new tab page, so every time you open a tab you land on what members are shipping, writing, and discussing right now.</p>
        <div class="newtab-feats">
          <div class="newtab-feat">
            <span class="itile"><svg viewBox="0 0 24 24"><use href="#ico-globe"/></svg></span>
            <div><h3 class="h4">New-tab takeover</h3><p class="body-sm muted mt8">Replace the default new tab with your network home: live activity, members, and quick links.</p></div>
          </div>
          <div class="newtab-feat">
            <span class="itile"><svg viewBox="0 0 24 24"><use href="#ico-check"/></svg></span>
            <div><h3 class="h4">Always optional</h3><p class="body-sm muted mt8">Toggle it on or off anytime. The extension never gets in your way.</p></div>
          </div>
          <div class="newtab-feat">
            <span class="itile"><svg viewBox="0 0 24 24"><use href="#ico-spark"/></svg></span>
            <div><h3 class="h4">Right where you work</h3><p class="body-sm muted mt8">Pick up drafts, open pull requests, and unread discussion the moment you open your browser.</p></div>
          </div>
        </div>
        <a href={extensionInstallUrl} class="btn btn-primary">Add the extension <svg class="ar" viewBox="0 0 24 24" width="18" height="18"><use href="#ico-arrow"/></svg></a>
      </div>

      <!-- browser / new-tab mock -->
      <div class="nt-browser">
        <div class="nt-bar">
          <div class="nt-lights"><i></i><i></i><i></i></div>
          <div class="nt-tabs"><span class="nt-tab on">New Tab</span><span class="nt-tab">Docs</span></div>
          <div class="nt-omni">gbti.network</div>
        </div>
        <div class="nt-page">
          <div class="nt-top">
            <div class="flex items-center g10"><span class="brand-mark" style="width:28px;height:28px;font-size:17px;box-shadow:none">G</span><span style="font-family:var(--f-display);font-weight:700;font-size:17px">GBTI</span></div>
            <span class="mono muted" style="font-size:11.5px">Thursday · 9:24</span>
          </div>
          <h3 class="nt-greet">Good morning. Here is what is new in the network.</h3>
          <div class="nt-search"><svg viewBox="0 0 24 24" width="16" height="16" style="opacity:.5"><circle cx="11" cy="11" r="6.5" fill="none" stroke="currentColor" stroke-width="1.8"/><path d="M16 16l4 4" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/></svg> Search the network…</div>
          <div class="nt-tiles">
            <div class="nt-tile"><span class="itile"><svg viewBox="0 0 24 24"><use href="#ico-pencil"/></svg></span>Articles</div>
            <div class="nt-tile"><span class="itile"><svg viewBox="0 0 24 24"><use href="#ico-box"/></svg></span>Products</div>
            <div class="nt-tile"><span class="itile"><svg viewBox="0 0 24 24"><use href="#ico-spark"/></svg></span>Prompts</div>
            <div class="nt-tile"><span class="itile"><svg viewBox="0 0 24 24"><use href="#ico-mega"/></svg></span>Shares</div>
          </div>
          <div class="nt-feed">
            <div class="nt-feed-head">Latest activity</div>
            {feed.slice(0, 3).map((it) => {
              const a = authorItem(it.author, avatarIndex);
              return (
                <div class="nt-fr">
                  <Avatar item={a} class="av" size={26} />
                  <span class="t">{a.name} {it.kind === 'Article' ? 'published' : 'shipped'} “{it.title}”</span>
                  <span class="w">{relTime(it.date)}</span>
                </div>
              );
            })}
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ============ WHAT MEMBERS SHIP ============ -->
<section class="band tint" id="works">
  <div class="wrap">
    <div class="sec-head">
      <div>
        <h2 class="h2">Recent Activity</h2>
        <p class="lead">Articles, products, plugins, and prompts from across the membership.</p>
      </div>
      <a href="/articles/" class="link">Browse everything <svg class="ar" viewBox="0 0 24 24" width="18" height="18"><use href="#ico-arrow"/></svg></a>
    </div>
    <div class="filter-row">
      <button type="button" class="chip filter on" aria-pressed="true" data-filter="all">All</button>
      <button type="button" class="chip filter" aria-pressed="false" data-filter="Article">Articles</button>
      <button type="button" class="chip filter" aria-pressed="false" data-filter="Product">Products</button>
      <button type="button" class="chip filter" aria-pressed="false" data-filter="Prompt">Prompts</button>
    </div>
    <div class="works-grid">
      {featured && (
        <article class="card card-hover work-feat" data-type="Article">
          <a href={`/articles/${featured.data.slug}/`} class="cover" aria-label={featured.data.title}>
            {featured.data.coverImage
              ? <Image src={featured.data.coverImage} width={620} height={420} alt="" />
              : <span class="cover-fallback"></span>}
          </a>
          <div class="body">
            <span class="chip chip-green" style="align-self:flex-start">Article{featured.data.categories?.[0] ? ` · ${featured.data.categories[0]}` : ''}</span>
            <h3 class="h3 mt16"><a href={`/articles/${featured.data.slug}/`}>{featured.data.title}</a></h3>
            {featured.data.excerpt && <p class="body-sm muted mt12" style="flex:1">{featured.data.excerpt}</p>}
            <div class="byline mt20">
              <Avatar item={authorItem(featured.data.author, avatarIndex)} class="av" size={32} />
              <span class="body-sm"><strong>{authorDisplay(featured.data.author)}</strong> <span class="muted">· {formatDate(featured.data.publishedAt)}</span></span>
            </div>
          </div>
        </article>
      )}
      {featuredProducts.length > 0 && (
        <div class="work-col" data-type="Product">
          {featuredProducts.map((fp) => (
            <article class="card card-hover work-card">
              <Image src={fp.data.icon} width={152} height={152} alt="" class="work-icon" style="object-fit:cover;border-radius:8px" />
              <span class="chip" style="align-self:flex-start">Product</span>
              <h3 class="h4 mt12"><a href={`/products/${fp.data.slug}/`} style="color:var(--fg)">{fp.data.title}</a></h3>
              <p class="body-sm muted mt8" style="flex:1">{fp.data.shortDescription}</p>
              <div class="byline mt16">
                <Avatar item={authorItem(fp.data.author, avatarIndex)} class="av" size={28} />
                <span class="body-sm"><strong>{authorDisplay(fp.data.author)}</strong></span>
              </div>
            </article>
          ))}
        </div>
      )}
      {minis.map((m) => (
        m.kind === 'Article' ? (
          <a class="card card-hover work-mini work-mini-img" href={m.href} data-type={m.kind}>
            {m.img ? (
              <Image src={m.img} width={400} height={220} alt="" class="work-mini-cover" />
            ) : (
              <div class="work-mini-cover" style="background:linear-gradient(140deg,var(--green-tint),var(--tint))"></div>
            )}
            <div class="work-mini-meta"><span class="chip" style="padding:3px 9px">{m.kind}</span><p class="body-sm mt8" style="font-weight:600;color:var(--fg)">{m.title}</p><div class="mini-byline"><Avatar item={authorItem(m.author, avatarIndex)} class="mini-av" size={22} /><span><strong>{authorDisplay(m.author)}</strong> · {formatDate(m.date)}</span></div></div>
          </a>
        ) : (
          <a class="card card-hover work-mini work-mini-img" href={m.href} data-type={m.kind}>
            <div class="work-mini-splash"><svg viewBox="0 0 640 512" aria-hidden="true"><path fill="currentColor" d="M320 0c17.7 0 32 14.3 32 32v64h120c39.8 0 72 32.2 72 72v272c0 39.8-32.2 72-72 72H168c-39.8 0-72-32.2-72-72V168c0-39.8 32.2-72 72-72h120V32c0-17.7 14.3-32 32-32M208 384c-8.8 0-16 7.2-16 16s7.2 16 16 16h32c8.8 0 16-7.2 16-16s-7.2-16-16-16zm96 0c-8.8 0-16 7.2-16 16s7.2 16 16 16h32c8.8 0 16-7.2 16-16s-7.2-16-16-16zm96 0c-8.8 0-16 7.2-16 16s7.2 16 16 16h32c8.8 0 16-7.2 16-16s-7.2-16-16-16zM264 256a40 40 0 1 0-80 0a40 40 0 1 0 80 0m152 40a40 40 0 1 0 0-80a40 40 0 1 0 0 80M48 224h16v192H48c-26.5 0-48-21.5-48-48v-96c0-26.5 21.5-48 48-48m544 0c26.5 0 48 21.5 48 48v96c0 26.5-21.5 48-48 48h-16V224z"/></svg></div>
            <div class="work-mini-meta"><span class="chip" style="padding:3px 9px">{m.kind === 'Prompt' ? 'AI Prompt' : m.kind}</span><p class="body-sm mt8" style="font-weight:600;color:var(--fg)">{m.title}</p>{m.desc && <p class="body-sm muted mt8" style="display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden">{m.desc}</p>}<div class="mini-byline"><Avatar item={authorItem(m.author, avatarIndex)} class="mini-av" size={22} /><span><strong>{authorDisplay(m.author)}</strong> · {formatDate(m.date)}</span></div></div>
          </a>
        )
      ))}
    </div>
  </div>
</section>

