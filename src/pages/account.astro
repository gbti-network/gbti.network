---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="Account" description="Your GBTI Network account." noindex={true}>
  <section class="band">
    <div class="wrap">
      <div class="sec-head center">
        <span class="itile"><svg viewBox="0 0 24 24"><use href="#ico-id"/></svg></span>
        <h1 class="h1 mt24">Your account</h1>
        <p class="lead">
          Welcome to GBTI Network. You manage your membership and author content from the GBTI browser
          extension, where you sign in with GitHub. Install it to get started, then join the community.
        </p>
        <a href="/membership/" class="btn btn-primary btn-lg mt24">See membership <svg class="ar" viewBox="0 0 24 24" width="18" height="18"><use href="#ico-arrow"/></svg></a>
      </div>
    </div>
  </section>
</BaseLayout>
