---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';
import Avatar from '../../components/Avatar.astro';
import ProductDirectory from '../../components/products/ProductDirectory.astro';
import FeaturedProduct from '../../components/products/FeaturedProduct.astro';
import { isPublic, isListed, catalogHref } from '../../lib/content';
import { leafLabel } from '../../lib/taxonomy';
import { authorDisplay, authorAvatar } from '../../lib/authors';

// GBTI Products directory (V3 "GBTI Products" design). Server-rendered from the real product collection.
// Per the owner: NO repo links in the directory (not all products have a repo, and we want clicks to land
// on the product page), so every action drives to /products/<slug>/.
// SOW-022: applets list AMONG products (their cards link via catalogHref to the running tool at /utilities/<slug>/).
// Mode B stubs show as locked cards (SOW-016).
const productEntries = (await getCollection('product')).filter(isListed);
const applets = (await getCollection('applet')).filter(isListed);
const products = [...productEntries, ...applets];

// Map a product's taxonomy LEAF to the design's four directory categories (colour + glyph + chip).
const DESIGN_CAT: Record<string, { key: string; label: string; cls: string; g: string }> = {
  wordpress: { key: 'wp', label: 'WordPress', cls: 'c-wp', g: 'g-wp' },
  'ide-plugins': { key: 'ide', label: 'IDE Plugins', cls: 'c-ide', g: 'g-ide' },
  mods: { key: 'mod', label: 'Mods', cls: 'c-mod', g: 'g-mod' },
  utilities: { key: 'util', label: 'Utilities', cls: 'c-util', g: 'g-util' },
};
const leafKeyOf = (p: any) => p.data.categories?.[p.data.categories.length - 1] ?? '';
const catOf = (p: any) =>
  DESIGN_CAT[leafKeyOf(p)] ?? { key: 'other', label: leafLabel(p.data.categories) || 'Product', cls: 'c-util', g: 'g-util' };

const byNewest = [...products].sort(
  (a, b) => (b.data.publishedAt?.valueOf() ?? 0) - (a.data.publishedAt?.valueOf() ?? 0),
);
const recent = byNewest.slice(0, 8); // "Recently created" carousel
// "Featured product" spotlight uses PRODUCTS only (applets have no required marquee featuredImage). Newest; owner can curate later.
const featured = [...productEntries].sort((a, b) => (b.data.publishedAt?.valueOf() ?? 0) - (a.data.publishedAt?.valueOf() ?? 0))[0];

// "Latest comments" is community discussion: real product comments EXCLUDING each owner's own intro
// (the from-the-author intro is a self-comment, SOW-014). Empty until members discuss => section omitted.
const ownerOf = new Map(products.map((p) => [p.data.slug, p.data.author]));
const discussion = (await getCollection('comment'))
  .filter(isPublic)
  .filter((c) => c.data.targetType === 'product' && ownerOf.has(c.data.targetSlug) && c.data.author !== ownerOf.get(c.data.targetSlug))
  .sort((a, b) => b.data.createdAt.valueOf() - a.data.createdAt.valueOf());

// Build-time relative timestamp for the carousel ("New" cards). Refreshes on each deploy.
const NOW = new Date();
function relTime(d?: Date): string {
  if (!d) return '';
  const days = Math.max(0, Math.floor((NOW.valueOf() - d.valueOf()) / 86400000));
  if (days <= 1) return 'just now';
  if (days < 14) return `${days} days ago`;
  if (days < 60) return `${Math.round(days / 7)} weeks ago`;
  if (days < 365) return `${Math.round(days / 30)} months ago`;
  return `${Math.round(days / 365)} years ago`;
}
const desc = (p: any) => p.data.shortDescription ?? '';
---
<BaseLayout title="Products" description="Every product in the directory is created and maintained by GBTI Network members.">
  <!-- ============ HERO ============ -->
  <section class="phero">
    <div class="wrap">
      <p class="eyebrow">From the co-op</p>
      <h1 class="h1 mt12">Products</h1>
      <p class="lead">Every product in the directory is created and maintained by GBTI Network members.</p>
    </div>
  </section>

  <!-- ============ DIRECTORY ============ -->
  <section class="browse-band">
    <ProductDirectory products={products} />
  </section>

  <!-- ============ RECENTLY CREATED ============ -->
  <section class="slider-band">
    <div class="wrap">
      <div class="slider-head">
        <div><p class="eyebrow">Fresh from the co-op</p><h2 class="h2 mt8">Recently created</h2></div>
        <div class="slider-nav">
          <button class="snav" data-snav="-1" aria-label="Previous"><svg viewBox="0 0 24 24"><use href="#g-arrow"/></svg></button>
          <button class="snav" data-snav="1" aria-label="Next"><svg viewBox="0 0 24 24"><use href="#g-arrow"/></svg></button>
        </div>
      </div>
      <div class="slider" data-slider>
        <div class="slider-track" data-track>
          {recent.map((p) => {
            const c = catOf(p);
            return (
              <article class:list={['scard', 'card', 'card-hover', c.cls]}>
                <div class="scard-media">
                  <span class="scard-new">New</span>
                  {p.data.banner
                    ? <Image class="scard-bg" src={p.data.banner} width={620} height={240} alt="" />
                    : <Image class="scard-icon" src={p.data.icon} width={64} height={64} alt={`${p.data.title} icon`} />}
                </div>
                <div class="scard-body">
                  <div class="flex items-center justify-between g12"><span class:list={['pchip', c.cls]}>{c.label}</span><span class="scard-when">{relTime(p.data.publishedAt)}</span></div>
                  <h3 class="scard-name mt12"><a href={catalogHref(p)}>{p.data.title}</a></h3>
                  <p class="scard-desc">{desc(p)}</p>
                  <div class="scard-foot"><a class="link" href={catalogHref(p)}>View details <svg class="ar" viewBox="0 0 24 24" width="16" height="16"><use href="#g-arrow"/></svg></a></div>
                </div>
              </article>
            );
          })}
        </div>
      </div>
    </div>
  </section>

  <!-- ============ FEATURED PRODUCT ============ -->
  {featured && <FeaturedProduct product={featured} />}

  <!-- ============ LATEST COMMENTS (omitted entirely until there is product discussion) ============ -->
  {discussion.length > 0 && (
    <section class="comments-band">
      <div class="wrap">
        <div class="slider-head"><div><p class="eyebrow">From the discussion</p><h2 class="h2 mt8">Latest comments</h2></div></div>
        <div class="cmt-grid" data-comments>
          {discussion.slice(0, 8).map((cm) => {
            const p = products.find((x) => x.data.slug === cm.data.targetSlug)!;
            const c = catOf(p);
            return (
              <article class="cmt card">
                <div class="cmt-head">
                  <Avatar item={{ name: authorDisplay(cm.data.author), avatar: authorAvatar(cm.data.author) }} class="cmt-av" size={40} />
                  <div class="cmt-who"><div class="cmt-name">{authorDisplay(cm.data.author)}</div>
                    <div class="cmt-meta"><span class="on">commented on</span> <a href={catalogHref(p)}>{p.data.title}</a></div></div>
                </div>
                <p class="cmt-body" set:html={cm.rendered?.html ?? ''} />
                <div class="cmt-prod"><span class:list={['pico', c.cls]}><svg viewBox="0 0 24 24"><use href={`#${c.g}`}/></svg></span><span class="nm">{c.label}</span></div>
              </article>
            );
          })}
        </div>
      </div>
    </section>
  )}

  <style>
    /* ---- GBTI Products page (directory + featured spotlight are now shared components) ---- */
    .phero { padding: 60px 0 0; text-align: center; }
    .phero .lead { max-width: 580px; margin: 16px auto 0; }
    .browse-band { padding: 40px 0 64px; }

    /* category palettes (used by the recently-created cards + comments chips) */
    .c-wp   { --ca:#2f63c0; --cb:#5a8de0; --ct:#eef3fc; --cl:#bcd0f0; }
    .c-ide  { --ca:#6b4fb0; --cb:#9277d4; --ct:#f2eefb; --cl:#d6c9ee; }
    .c-mod  { --ca:#b3791f; --cb:#d8a847; --ct:#fbf3e3; --cl:#ecd9ad; }
    .c-util { --ca:#138178; --cb:#3bb0a4; --ct:#e7f5f3; --cl:#b6e0da; }

    .pico { border-radius: 11px; flex: none; display: flex; align-items: center; justify-content: center; color: #fff;
      background: linear-gradient(145deg, var(--cb), var(--ca)); box-shadow: 0 4px 12px rgba(37,35,43,.14); }
    .pico svg { width: 52%; height: 52%; }
    .pchip { display: inline-flex; align-items: center; font-family: var(--f-mono); font-size: 11px; font-weight: 500; letter-spacing: .02em;
      padding: 4px 9px; border-radius: 4px; border: 1.5px solid var(--cl); color: var(--ca); background: var(--ct); white-space: nowrap; }
    /* Avatar renders in its own component scope, so the circle must be :global to reach it. */
    :global(.cmt-av) { border-radius: 50%; flex: none; }

    /* section heads */
    .slider-head { display: flex; align-items: flex-end; justify-content: space-between; gap: 20px; margin-bottom: 24px; }

    /* recently-created slider */
    .slider-band { padding: 8px 0 64px; }
    .slider-nav { display: flex; gap: 10px; }
    .snav { width: 42px; height: 42px; border-radius: 50%; border: 1.5px solid var(--line-2); background: var(--paper); cursor: pointer; display: flex; align-items: center; justify-content: center; color: var(--fg); transition: all .15s; box-shadow: var(--sh-sm); }
    .snav:hover { border-color: var(--ink); transform: translateY(-1px); box-shadow: var(--sh); }
    .snav[data-snav="-1"] svg { transform: rotate(180deg); }
    .snav svg { width: 18px; height: 18px; }
    .snav:disabled { opacity: .35; cursor: default; transform: none; box-shadow: var(--sh-sm); border-color: var(--line-2); }
    .slider { overflow: hidden; }
    .slider-track { display: flex; gap: 20px; padding: 6px 4px 18px; transition: transform .42s cubic-bezier(.4,0,.2,1); will-change: transform; }
    .scard { flex: 0 0 300px; padding: 0; overflow: hidden; display: flex; flex-direction: column; }
    .scard-media { height: 116px; display: flex; align-items: center; justify-content: center; background: linear-gradient(150deg, var(--cb), var(--ca)); position: relative; }
    .scard-icon { width: 64px; height: 64px; border-radius: 15px; object-fit: contain; background: rgba(255,255,255,.9); padding: 8px; }
    .scard-bg { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; }
    .scard-new { position: absolute; top: 12px; right: 12px; z-index: 2; font-family: var(--f-mono); font-size: 10px; font-weight: 700; letter-spacing: .08em; text-transform: uppercase; color: #fff; background: rgba(0,0,0,.32); padding: 4px 9px; border-radius: 999px; }
    .scard-body { padding: 18px 20px 20px; display: flex; flex-direction: column; flex: 1; }
    .scard-name { font-family: var(--f-display); font-weight: 700; font-size: 16.5px; line-height: 1.2; }
    .scard-name a { color: var(--fg); transition: color .15s ease; }
    .scard:hover .scard-name a { color: var(--green-700); }
    .scard-desc { font-size: 13.5px; line-height: 1.5; color: var(--fg-soft); margin-top: 10px; flex: 1; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }
    .scard-foot { display: flex; align-items: center; justify-content: space-between; margin-top: 16px; }
    .scard-when { font-family: var(--f-mono); font-size: 11px; color: var(--fg-mute); }

    /* latest comments */
    .comments-band { padding: 8px 0 80px; }
    .cmt-grid { display: grid; grid-template-columns: 1fr; gap: 14px; }
    .cmt { padding: 22px 24px; display: flex; flex-direction: column; }
    .cmt-head { display: flex; align-items: center; gap: 12px; }
    .cmt-av { width: 40px; height: 40px; flex: none; }
    .cmt-who { min-width: 0; flex: 1; }
    .cmt-name { font-weight: 700; font-size: 15px; color: var(--fg); }
    .cmt-meta { font-size: 12.5px; color: var(--fg-mute); margin-top: 2px; }
    .cmt-meta .on { color: var(--fg-soft); }
    .cmt-meta a { color: var(--green-700); font-weight: 600; }
    .cmt-body { font-size: 14.5px; line-height: 1.55; color: var(--fg-soft); margin-top: 14px; }
    .cmt-prod { display: flex; align-items: center; gap: 9px; margin-top: 16px; padding-top: 14px; border-top: 1.5px solid var(--line); }
    .cmt-prod .pico { width: 26px; height: 26px; border-radius: 6px; }
    .cmt-prod .pico svg { width: 14px; height: 14px; }
    .cmt-prod .nm { font-family: var(--f-mono); font-size: 12px; color: var(--fg-soft); }
  </style>

  <script>
    // Recently-created carousel.
    const viewport = document.querySelector<HTMLElement>('[data-slider]');
    const track = document.querySelector<HTMLElement>('[data-track]');
    if (viewport && track && track.children.length) {
      const navWrap = viewport.parentElement!.querySelector('.slider-nav')!;
      const prev = navWrap.querySelector<HTMLButtonElement>('[data-snav="-1"]')!;
      const next = navWrap.querySelector<HTMLButtonElement>('[data-snav="1"]')!;
      let index = 0;
      const cardEl = () => track.querySelector<HTMLElement>('.scard');
      const step = () => { const el = cardEl(); return el ? el.offsetWidth + 20 : 320; };
      const perView = () => Math.max(1, Math.floor((viewport.clientWidth + 20) / step()));
      const maxIndex = () => Math.max(0, track.children.length - perView());
      const render = () => {
        index = Math.min(Math.max(0, index), maxIndex());
        track.style.transform = `translateX(${-index * step()}px)`;
        prev.disabled = index <= 0;
        next.disabled = index >= maxIndex();
      };
      next.addEventListener('click', () => { index += perView(); render(); });
      prev.addEventListener('click', () => { index -= perView(); render(); });
      window.addEventListener('resize', render);
      setTimeout(render, 60);
    }
  </script>
</BaseLayout>
