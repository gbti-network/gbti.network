---
import { getCollection, render } from 'astro:content';
import { Image } from 'astro:assets';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Prose from '../../components/blog/Prose.astro';
import VideoEmbed from '../../components/VideoEmbed.astro';
import CommunityInvite from '../../components/CommunityInvite.astro';
import Comments from '../../components/blog/Comments.astro';
import EditHooks from '../../components/EditHooks.astro';
import LockedBody from '../../components/LockedBody.astro';
import { hasPublicPage, isStub } from '../../lib/content';
import { breadcrumb, leafLabel } from '../../lib/taxonomy';
import FavoriteButton from '../../components/FavoriteButton.astro';
import { favoriteCount } from '../../lib/favorites';

export async function getStaticPaths() {
  const products = (await getCollection('product')).filter(hasPublicPage);
  return products.map((product) => ({ params: { slug: product.data.slug }, props: { product } }));
}

const { product } = Astro.props;
const d = product.data;
const { Content } = await render(product);

// SOW-014: typed, visibility-tagged links. Public links are live; member-only links render INERT
// (locked) on the static site (open the GBTI client to unlock). This is not a confidentiality control.
const LINK_LABELS: Record<string, string> = {
  homepage: 'Homepage', repository: 'Repository', mirror: 'Mirror',
  download: 'Download', documentation: 'Documentation', support: 'Support',
};
const linkLabel = (l: { type: string; label?: string }) => l.label ?? LINK_LABELS[l.type] ?? l.type;
const links = d.links ?? [];
// The repository is surfaced by the single "View on GitHub" button below (pointing at the real repo),
// so it is not rendered as its own redundant button in the Get card.
const repoUrl = links.find((l) => l.type === 'repository')?.url ?? null;
const getLinks = links.filter((l) => l.type !== 'repository');
const cap = (s: string) => s.charAt(0).toUpperCase() + s.slice(1);
const meta = [
  ['Category', breadcrumb(d.categories).join(' › ')],
  ...(d.version ? [['Version', d.version]] : []),
  ...(d.platforms?.length ? [['Platforms', d.platforms.join(', ')]] : []),
  ...(d.pricing ? [['Pricing', cap(d.pricing)]] : []),
] as [string, string][];
---
<BaseLayout title={d.title} description={d.shortDescription} ogImage={(d.featuredImage ?? d.banner ?? d.icon)?.src}>
  <!-- Banner band (dark) -->
  <section class="band-sm dark">
    <div class="wrap">
      {d.banner && (
        <Image src={d.banner} alt={`${d.title} banner`} width={1200} height={400} class="card" style="width:100%;object-fit:cover;margin-bottom:32px" />
      )}
      <div class="flex items-center g24 wrap-w" style="text-align:center;justify-content:center;flex-direction:column">
        <Image src={d.icon} alt={`${d.title} icon`} width={96} height={96} class="card" style="width:96px;height:96px;flex:none;object-fit:contain;padding:8px;background:rgba(255,255,255,.08);border-radius:var(--r-lg)" />
        <div style="max-width:680px">
          <p class="eyebrow">{leafLabel(d.categories)}</p>
          <h1 data-gbti-region="title" class="h1 mt12" style="color:#fff">{d.title}</h1>
          <p class="lead mt16">{d.shortDescription}</p>
          <div class="mt20" style="display:flex;justify-content:center">
            <FavoriteButton targetType="product" targetSlug={d.slug} count={favoriteCount('product', d.slug)} />
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="band tint">
    <div class="wrap">
      <div class="pd-grid">
        <article class="card" style="padding:36px 40px" data-gbti-region="body">
          {isStub(product) ? (
            <LockedBody encPath={d.encryptedBody} kind="body" />
          ) : (
            <>
              {d.video && (
                <div class="pvideo">
                  <VideoEmbed video={d.video} title={`${d.title} demo`} />
                </div>
              )}
              <Prose>
                <Content />
              </Prose>
              {d.encryptedBody && <LockedBody encPath={d.encryptedBody} kind="section" />}
            </>
          )}
        </article>

        <aside class="flex col g24">
          <div class="card" style="padding:26px">
            <h2 class="h3">Get {d.title}</h2>
            <div class="flex col g12 mt16">
              {getLinks.map((l) => (
                l.visibility === 'members' ? (
                  <span class="btn btn-ghost" style="width:100%;cursor:not-allowed;opacity:.75" data-tooltip={l.encrypted ? 'Encrypted member content. Open in the GBTI client to unlock.' : 'Members only. Open in the GBTI client to unlock.'}>
                    <svg viewBox="0 0 24 24" width="16" height="16"><use href="#ico-lock"/></svg>
                    {linkLabel(l)} <span class="mono" style="font-size:11px;opacity:.8">{l.encrypted ? 'encrypted' : 'members'}</span>
                  </span>
                ) : (
                  <a href={l.url} rel="noopener" class:list={['btn', l.primary ? 'btn-primary' : 'btn-ghost']} style="width:100%">{linkLabel(l)}</a>
                )
              ))}
              {d.pricing && d.pricing !== 'free' && d.pricingUrl && (
                <a href={d.pricingUrl} rel="noopener" class="btn btn-ghost" style="width:100%">Pricing</a>
              )}
              {repoUrl && (
                <a href={repoUrl} rel="noopener" class="btn btn-ghost" style="width:100%">
                  <svg viewBox="0 0 24 24" width="18" height="18"><use href="#ico-github"/></svg>
                  View on GitHub
                </a>
              )}
            </div>
          </div>

          <div class="card" style="padding:26px">
            <p class="eyebrow">Details</p>
            <dl class="flex col g12 mt16">
              {meta.map(([k, v]) => (
                <div class="flex justify-between g16" style="border-top:1.5px solid var(--line);padding-top:12px">
                  <dt class="body-sm muted">{k}</dt>
                  <dd class="body-sm" style="text-align:right;font-weight:600;color:var(--fg)">{v}</dd>
                </div>
              ))}
            </dl>
          </div>
        </aside>
      </div>

      {!isStub(product) && d.gallery.length > 0 && (
        <div class="pgallery-wrap">
          <p class="eyebrow">Screenshots</p>
          <h2 class="h3 mt8">See {d.title} in action</h2>
          <div class="pgallery mt20">
            {d.gallery.map((img, i) => (
              <a href={img.src} target="_blank" rel="noopener" class="pgallery-item card" aria-label={`Open screenshot ${i + 1} of ${d.title}`}>
                <Image src={img} widths={[420, 840]} sizes="(max-width:700px) 100vw, 360px" alt={`${d.title} screenshot ${i + 1}`} />
              </a>
            ))}
          </div>
        </div>
      )}

      <Comments targetType="product" targetSlug={d.slug} author={d.author} />

      <CommunityInvite author={d.author} via={`product:${d.slug}`} />
    </div>
  </section>
  <EditHooks type="product" owner={d.author} slug={d.slug} />
</BaseLayout>

<style>
  .pvideo { margin-bottom: 28px; }
  /* Body + meta-sidebar. minmax(0,1fr) so the body never floors the track; stacks to one column on mobile
     (without this the 320px sidebar starved the body to ~100px, one word per line). */
  .pd-grid { display: grid; gap: 32px; grid-template-columns: minmax(0, 1fr) 320px; align-items: start; }
  @media (max-width: 900px) { .pd-grid { grid-template-columns: 1fr; } }
  .pgallery-wrap { margin-top: 44px; }
  .pgallery { display: grid; grid-template-columns: repeat(auto-fill, minmax(260px, 1fr)); gap: 16px; }
  .pgallery-item { display: block; padding: 0; overflow: hidden; line-height: 0; background: var(--ink-2, #1c1a22); transition: transform .15s ease, box-shadow .15s ease; }
  .pgallery-item:hover { transform: translateY(-3px); box-shadow: var(--sh); }
  .pgallery-item :global(img) { width: 100%; height: 188px; object-fit: cover; object-position: top; display: block; }
</style>
