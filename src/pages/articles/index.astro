---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import ArticleCard from '../../components/blog/ArticleCard.astro';
import { isListed, byNewest } from '../../lib/content';

const posts = (await getCollection('post')).filter(isListed).sort(byNewest);
const categories = [...new Set(posts.map((p) => p.data.categories?.[0]).filter(Boolean))].sort();
---
<BaseLayout title="Blog" description="Articles from the GBTI Network creator co-op.">
  <section class="band tint">
    <div class="wrap">
      <div class="sec-head center">
        <p class="eyebrow">From the co-op</p>
        <h1 class="h1 mt12">Blog</h1>
        <p class="lead">Writing from the GBTI Network co-op: tutorials, essays, and field notes from across the membership.</p>
      </div>

      <div class="filter-row" style="justify-content:center" role="tablist" aria-label="Filter by category">
        <button type="button" data-cat="all" class="chip filter cat-pill on" aria-selected="true">All</button>
        {categories.map((c) => <button type="button" data-cat={c} class="chip filter cat-pill" aria-selected="false">{c}</button>)}
      </div>

      <div id="post-grid" class="works-grid blog-grid">
        {posts.map((post) => <ArticleCard post={post} />)}
      </div>
    </div>
  </section>

  <style>
    /* Active styling comes from the global .filter.on (light + dark), not a per-page duplicate. */
    .cat-pill { text-transform: capitalize; }
    .blog-grid { grid-template-columns: repeat(3, 1fr); }
    @media (max-width: 1080px) { .blog-grid { grid-template-columns: 1fr 1fr; } }
    @media (max-width: 640px) { .blog-grid { grid-template-columns: 1fr; } }
  </style>

  <script>
    const pills = document.querySelectorAll<HTMLButtonElement>('.cat-pill');
    const cards = document.querySelectorAll<HTMLElement>('#post-grid .archive-card');
    pills.forEach((pill) => {
      pill.addEventListener('click', () => {
        const cat = pill.dataset.cat;
        pills.forEach((p) => { p.classList.remove('on'); p.setAttribute('aria-selected', 'false'); });
        pill.classList.add('on');
        pill.setAttribute('aria-selected', 'true');
        cards.forEach((card) => {
          card.style.display = cat === 'all' || card.dataset.category === cat ? '' : 'none';
        });
      });
    });
  </script>
</BaseLayout>
