---
import BaseLayout from '../layouts/BaseLayout.astro';
import TierTable from '../components/TierTable.astro';
import { getCollection } from 'astro:content';
import { isPublic } from '../lib/content';
import { REF_COOKIE, REF_VIA_COOKIE, REF_COOKIE_DAYS } from '../lib/referral';
import { MEMBERSHIP_PRICE_LABEL, BILLING_PERIOD, TRIAL_DAYS_SITE, FIRST_TOUCH_PCT, LAST_TOUCH_PCT, COLLAB_POOL_PCT, INVITE_PCT, HOLD_DAYS, TURNSTILE_SITE_KEY, SIGNUP_BASE } from '../lib/membership';

// SOW-002 signup CTA: the pricing card renders a Cloudflare Turnstile widget; on solve the button navigates
// to the signup Worker's /signup/start with the token + first-touch ref/via cookies. The Worker verifies the
// Turnstile token server-side before any OAuth or Stripe work. Live once the Worker is on signup.gbti.network.
const perks = [
  { icon: 'pencil', title: 'Share articles', body: 'Share tutorials, essays, and field notes under your own name.' },
  { icon: 'box', title: 'Promote your work', body: 'Promote products, plugins, tools, and creative work in the directory.' },
  { icon: 'users', title: 'Join community', body: 'Private Discord, weekly build sessions, and hands-on coaching.' },
  { icon: 'chart', title: 'Grow visibly', body: 'A public profile, real feedback, and proof of what you ship.' },
  { icon: 'coin', title: 'Share revenue', body: 'Earn when the work you publish brings new members in.' },
];

// Real trust numbers, from the published content collections (no hardcoded counts to drift).
const members = (await getCollection('profile')).filter(isPublic).filter((p) => p.data.username !== 'gbti');
const memberCount = members.length;
const productCount = (await getCollection('product')).filter(isPublic).length;
const postCount = (await getCollection('post')).filter(isPublic).length;

const included = [
  'Publish your profile, articles, products, and prompts',
  'Full Discord access plus weekly build sessions and coaching',
  `Revenue share when your content brings a member in (${FIRST_TOUCH_PCT} discovery, ${LAST_TOUCH_PCT} closing), plus a ${INVITE_PCT} lifetime invite commission`,
  'Author with humans or your own AI agents through the local client',
  'A vote in a creator network',
];

const faqs = [
  {
    q: 'Do I need a credit card to start?',
    a: `No. The ${TRIAL_DAYS_SITE}-day limited-access trial needs no card. You get community access while you evaluate the network.`,
  },
  {
    q: 'What does the trial include?',
    a: 'View-only access to the Discord community (read the channels) and the GBTI extension hub to follow news, member activity, and shares, plus the ability to author and stage drafts on your own fork. The weekly build sessions, publishing, your public profile and member directory listing, commenting, and member-only content are all paid-member only.',
  },
  {
    q: 'Can I publish while I am on the trial?',
    a: 'Not yet. On the trial you author and stage drafts on your own GitHub fork, but publishing to gbti.network is paid-only: a content pull request from a trial member is auto-rejected and closed, so nothing reaches the canonical repo. Nothing is lost. When you upgrade to a paid membership, your client publishes your staged drafts as a new pull request.',
  },
  {
    q: 'What happens when the trial ends?',
    a: 'You keep browsing the public site. To publish your profile, articles, products, and prompts, and to join the community with full access, upgrade to paid. Any drafts you staged stay on your own fork until you upgrade.',
  },
  {
    q: `How much is membership, and can I cancel?`,
    a: `${MEMBERSHIP_PRICE_LABEL} per ${BILLING_PERIOD}. It is an annual membership. You can cancel anytime and keep access through the end of your paid period.`,
  },
  {
    q: 'How does revenue share work?',
    a: `When someone joins, the network looks at the content that brought them in and the content that closed the signup. The first earns its author ${FIRST_TOUCH_PCT}, the last earns ${LAST_TOUCH_PCT}, and a fixed ${COLLAB_POOL_PCT} pool is shared by the members who improved or discussed those items. Separately, if you bring someone in with your personal invite link, you earn a flat ${INVITE_PCT} lifetime commission paid from the platform share, so it never reduces what content owners earn. All distributions pay out after a ${HOLD_DAYS}-day hold.`,
  },
  {
    q: 'Who runs GBTI?',
    a: 'It is a creator network. The whole site runs on a public Git repository. Members publish through pull requests and share in what the network earns.',
  },
];
---
<BaseLayout title="Membership" description={`Join the GBTI Network: ${MEMBERSHIP_PRICE_LABEL}/${BILLING_PERIOD}, with a ${TRIAL_DAYS_SITE}-day limited-access, no-card trial.`}>
  <!-- ============ HERO ============ -->
  <section class="band dark tcenter">
    <div class="wrap">
      <div class="chip" style="display:inline-flex"><span class="chip-dot"></span> Membership</div>
      <h1 class="h1 mt20" style="color:#fff">One membership. {MEMBERSHIP_PRICE_LABEL} a {BILLING_PERIOD}.</h1>
      <p class="lead" style="max-width:620px;margin:18px auto 0">
        Start with a {TRIAL_DAYS_SITE}-day, no-card trial of the community. Paid membership unlocks your public
        presence: profile, blog, products, and prompts.
      </p>
      <div class="hero-c-cta">
        <a href="#join" class="btn btn-primary btn-lg">Start your {TRIAL_DAYS_SITE}-day limited-access trial</a>
        <span class="mono muted" style="font-size:13px">No card required</span>
      </div>
      {memberCount > 0 && (
        <p class="body-sm mt16" style="color:var(--on-dark-soft)">
          Join <strong style="color:#fff">{memberCount} member{memberCount === 1 ? '' : 's'}</strong> who have shipped
          {' '}{productCount} product{productCount === 1 ? '' : 's'} and {postCount} article{postCount === 1 ? '' : 's'}, all public.
        </p>
      )}
    </div>
  </section>

  <!-- ============ WHAT YOU GET ============ -->
  <section class="band tint">
    <div class="wrap">
      <div class="sec-head center">
        <p class="eyebrow">What you get</p>
        <h2 class="h2 mt12">What network membership includes</h2>
        <p class="lead mt16" style="max-width:600px;margin-left:auto;margin-right:auto">One membership gives you a place to publish, build, and earn.</p>
      </div>
      <div class="perk-grid mt32">
        {perks.map((p) => (
          <div class="card cap-card">
            <span class="itile"><svg viewBox="0 0 24 24"><use href={`#ico-${p.icon}`}/></svg></span>
            <h3 class="h3">{p.title}</h3>
            <p class="body-sm muted mt12">{p.body}</p>
          </div>
        ))}
      </div>
      <p class="h3 tcenter mt32" style="color:var(--fg)">One membership. <span class="grn">Everything above.</span></p>
    </div>
  </section>

  <!-- ============ COMMUNITY ============ -->
  <section class="band" id="community">
    <div class="wrap">
      <div class="comm-grid">
        <img class="comm-shot card" src="/stock/weekly-build-session.jpg" alt="GBTI members on a weekly build call" width="1280" height="900" loading="lazy" decoding="async" style="display:block;width:100%;object-fit:cover" />
        <div>
          <h2 class="h2">Come for the opportunity.<br/>Stay for the coaching and networking.</h2>
          <div class="comm-pills">
            <div class="comm-pill"><span class="itile" style="width:44px;height:44px;border-radius:8px"><svg viewBox="0 0 24 24" style="width:22px;height:22px"><use href="#ico-chat"/></svg></span><div><h3 class="h4">Private Discord</h3><p class="body-sm muted">Meet and collaborate with builders.</p></div></div>
            <div class="comm-pill"><span class="itile" style="width:44px;height:44px;border-radius:8px"><svg viewBox="0 0 24 24" style="width:22px;height:22px"><use href="#ico-calendar"/></svg></span><div><h3 class="h4">Weekly build calls</h3><p class="body-sm muted">Two-hour sessions and hands-on coaching.</p></div></div>
            <div class="comm-pill"><span class="itile" style="width:44px;height:44px;border-radius:8px"><svg viewBox="0 0 24 24" style="width:22px;height:22px"><use href="#ico-heart"/></svg></span><div><h3 class="h4">Feedback &amp; networking</h3><p class="body-sm muted">A network of developers shipping real things together.</p></div></div>
          </div>
          <a href="#join" class="btn btn-primary">Join the community <svg class="ar" viewBox="0 0 24 24" width="18" height="18"><use href="#ico-arrow"/></svg></a>
        </div>
      </div>
    </div>
  </section>

  <!-- ============ COMPARE PLANS ============ -->
  <section class="band">
    <div class="wrap">
      <div class="sec-head center">
        <p class="eyebrow">Compare plans</p>
        <h2 class="h2 mt12">Free Tier, trial, and paid</h2>
        <p class="lead mt16" style="max-width:640px;margin-left:auto;margin-right:auto">Browsing is free for everyone. The {TRIAL_DAYS_SITE}-day trial lets you read the community and stage drafts. Publishing, your public profile and member directory listing, commenting, member-only content, the weekly sessions, and revenue share are all paid-member features.</p>
      </div>
      <div class="tbl mt32" style="max-width:940px;margin-left:auto;margin-right:auto">
        <TierTable detailed />
      </div>
    </div>
  </section>

  <!-- ============ PRICING CARD ============ -->
  <section id="join" class="band tint">
    <div class="wrap">
      <div class="price-card card">
        <p class="eyebrow tcenter">Paid membership</p>
        <div class="price-amount">
          <span class="price-num">{MEMBERSHIP_PRICE_LABEL}</span>
          <span class="price-per">/ {BILLING_PERIOD}</span>
        </div>
        <p class="body-sm muted tcenter">Start with a {TRIAL_DAYS_SITE}-day limited-access trial. No card required.</p>
        <ul class="price-list">
          {included.map((item) => (
            <li><svg viewBox="0 0 24 24" width="18" height="18" class="yes" aria-hidden="true"><use href="#ico-check"/></svg><span>{item}</span></li>
          ))}
        </ul>
        <div class="signup-cta">
          <div class="cf-turnstile" data-sitekey={TURNSTILE_SITE_KEY} data-callback="gbtiTurnstileOk" data-expired-callback="gbtiTurnstileReset" data-error-callback="gbtiTurnstileReset" data-theme="auto"></div>
          <button id="signup-go" type="button" class="btn btn-primary btn-lg" style="width:100%;margin-top:14px" disabled>Start your {TRIAL_DAYS_SITE}-day limited-access trial</button>
        </div>
        <p class="body-sm muted tcenter mt12" style="font-size:13px">Complete the check above to continue. No card required.</p>
      </div>
    </div>
  </section>

  <!-- ============ TRY IT FREE CTA ============ -->
  <section class="band gtint" id="cta">
    <div class="wrap">
      <div class="card cta-card">
        <div class="tcenter">
          <h2 class="h1">Try it free. Publish when you join.</h2>
          <p class="lead mt16" style="max-width:600px;margin-left:auto;margin-right:auto">Start a limited-access trial: create freely and look around the community. When you are ready to publish and earn, become a member.</p>
        </div>
        <div class="cta-cards">
          <!-- TRIAL -->
          <div class="card cta-col">
            <div class="flex items-center g12" style="margin-bottom:18px">
              <span class="chip">{TRIAL_DAYS_SITE}-day limited-access trial</span>
              <span class="mono muted" style="font-size:12px">free · no card</span>
            </div>
            <div class="flex col g14" style="flex:1">
              <div class="cta-feat"><svg class="ck" viewBox="0 0 24 24"><use href="#ico-check"/></svg><div><h3 class="h4">Create and draft on your own fork</h3><p class="body-sm muted mt8">Draft articles, products, and prompts with the full toolset, saved to your own fork.</p></div></div>
              <div class="cta-feat"><svg class="ck" viewBox="0 0 24 24"><use href="#ico-check"/></svg><div><h3 class="h4">Read-only Discord access</h3><p class="body-sm muted mt8">Look inside the community and see how members work.</p></div></div>
              <div class="cta-feat held"><svg class="ck" viewBox="0 0 24 24"><use href="#ico-lock"/></svg><div><h3 class="h4 muted">Publishing is paid-only</h3><p class="body-sm muted mt8">Your drafts stay on your own fork. They publish once you become a paid member.</p></div></div>
            </div>
            <a href="#join" class="btn btn-primary" style="margin-top:26px">Start your limited-access trial <svg class="ar" viewBox="0 0 24 24" width="18" height="18"><use href="#ico-arrow"/></svg></a>
          </div>
          <!-- MEMBERSHIP -->
          <div class="card cta-col member">
            <div class="flex items-center g12" style="margin-bottom:18px">
              <span class="chip chip-green">Membership</span>
              <span class="mono muted" style="font-size:12px">{MEMBERSHIP_PRICE_LABEL} / {BILLING_PERIOD}</span>
            </div>
            <p class="cta-unlock">everything unlocks ↓</p>
            <div class="flex col g12" style="flex:1">
              <div class="flex items-center g12"><svg viewBox="0 0 24 24" width="20" height="20" class="yes" style="color:var(--green-600);flex:none"><use href="#ico-check"/></svg><span style="font-weight:600">Publish everything you have created</span></div>
              <div class="flex items-center g12"><svg viewBox="0 0 24 24" width="20" height="20" style="color:var(--green-600);flex:none"><use href="#ico-check"/></svg><span style="font-weight:600">Full Discord + weekly build calls</span></div>
              <div class="flex items-center g12"><svg viewBox="0 0 24 24" width="20" height="20" style="color:var(--green-600);flex:none"><use href="#ico-check"/></svg><span style="font-weight:600">Revenue-share eligibility</span></div>
              <div class="flex items-center g12"><svg viewBox="0 0 24 24" width="20" height="20" style="color:var(--green-600);flex:none"><use href="#ico-check"/></svg><span style="font-weight:600">Public profile goes live</span></div>
            </div>
            <a href="/revenue-model/" class="link" style="margin-top:26px">See how the model works <svg class="ar" viewBox="0 0 24 24" width="18" height="18"><use href="#ico-arrow"/></svg></a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ============ FAQ ============ -->
  <section class="band">
    <div class="wrap">
      <div class="sec-head center">
        <p class="eyebrow">FAQ</p>
        <h2 class="h2 mt12">Questions, answered</h2>
      </div>
      <div class="faq mt32">
        {faqs.map((f, i) => (
          <details class="faq-item" open={i === 0}>
            <summary>{f.q}</summary>
            <p class="body-sm muted">{f.a}</p>
          </details>
        ))}
      </div>
    </div>
  </section>

  <style>
    /* Five benefit cards: a centered flex grid so the last row (2 cards) centers under the first (3 cards). */
    .perk-grid { display: flex; flex-wrap: wrap; justify-content: center; gap: 24px; }
    .perk-grid .cap-card { flex: 1 1 280px; max-width: 352px; margin: 0; }
    @media (max-width: 760px) { .perk-grid .cap-card { flex-basis: 100%; max-width: none; } }

    /* Pricing card */
    .price-card { max-width: 460px; margin: 0 auto; padding: 40px 36px; text-align: center; }
    .price-amount { display: flex; align-items: baseline; justify-content: center; gap: 8px; margin: 12px 0 6px; }
    .price-num { font-family: var(--f-display); font-weight: 800; font-size: 56px; line-height: 1; letter-spacing: -0.02em; color: var(--fg); }
    .price-per { font-family: var(--f-mono); font-size: 15px; color: var(--fg-mute); }
    .price-list { list-style: none; padding: 0; margin: 26px 0; display: flex; flex-direction: column; gap: 13px; text-align: left; }
    .price-list li { display: flex; align-items: flex-start; gap: 11px; font-size: 15px; line-height: 1.45; }
    .price-list .yes { color: var(--green-600); flex: none; margin-top: 1px; }

    /* Signup CTA: Turnstile widget centered above the trial button. */
    .signup-cta { display: flex; flex-direction: column; align-items: center; }
    .signup-cta .cf-turnstile { margin: 0 auto; min-height: 65px; }
    #signup-go:disabled { opacity: .55; cursor: not-allowed; }

    /* FAQ accordion (native details/summary, no JS) */
    .faq { max-width: 760px; margin-left: auto; margin-right: auto; }
    .faq-item { border-bottom: 1.5px solid var(--line); padding: 6px 0; }
    .faq-item summary { cursor: pointer; list-style: none; padding: 16px 0; font-family: var(--f-display); font-weight: 700; font-size: 18px; color: var(--fg); display: flex; align-items: center; justify-content: space-between; gap: 16px; }
    .faq-item summary::-webkit-details-marker { display: none; }
    .faq-item summary::after { content: '+'; font-family: var(--f-mono); font-weight: 400; font-size: 22px; color: var(--green-600); flex: none; transition: transform .15s ease; }
    .faq-item[open] summary::after { content: '\2212'; }
    .faq-item p { padding: 0 0 18px; max-width: 68ch; }
  </style>

  <script define:vars={{ cookie: REF_COOKIE, viaCookie: REF_VIA_COOKIE, days: REF_COOKIE_DAYS }}>
    // First-touch referral capture from ?ref (and ?via) when a reader arrives here from a member's
    // content CTA. Sets the cookie only if absent (first-touch wins). The signup flow reads this
    // cookie to seed ?ref at /signup/start; self-referral is rejected server-side at signup.
    (function () {
      try {
        var p = new URLSearchParams(location.search);
        var ref = p.get('ref');
        if (!ref) return;
        var has = document.cookie.split('; ').some(function (c) { return c.indexOf(cookie + '=') === 0; });
        if (has) return;
        var maxAge = 60 * 60 * 24 * days;
        document.cookie = cookie + '=' + encodeURIComponent(ref) + '; path=/; max-age=' + maxAge + '; SameSite=Lax';
        var via = p.get('via');
        if (via) document.cookie = viaCookie + '=' + encodeURIComponent(via) + '; path=/; max-age=' + maxAge + '; SameSite=Lax';
      } catch (e) { /* cookies disabled: no attribution persisted */ }
    })();
  </script>

  <!-- SOW-002 signup: Cloudflare Turnstile widget + the gated /signup/start navigation. -->
  <script is:inline src="https://challenges.cloudflare.com/turnstile/v0/api.js" async defer></script>
  <script define:vars={{ signupBase: SIGNUP_BASE, refCookie: REF_COOKIE, viaCookie: REF_VIA_COOKIE }}>
    // The Turnstile widget calls gbtiTurnstileOk(token) on solve; the button then navigates to the Worker's
    // /signup/start with the token + first-touch ref/via cookies. The Worker verifies the token server-side
    // (fail-closed) before any OAuth or registry work, so this is only the client half of the gate.
    (function () {
      function cookie(name) {
        var c = document.cookie.split('; ').find(function (x) { return x.indexOf(name + '=') === 0; });
        return c ? decodeURIComponent(c.split('=').slice(1).join('=')) : '';
      }
      var btn = document.getElementById('signup-go');
      window.gbtiTurnstileOk = function (token) { if (btn) { btn.disabled = false; btn.dataset.token = token; } };
      window.gbtiTurnstileReset = function () { if (btn) { btn.disabled = true; delete btn.dataset.token; } };
      if (btn) btn.addEventListener('click', function () {
        var token = btn.dataset.token;
        if (!token) return;
        var u = new URL(signupBase + '/signup/start');
        u.searchParams.set('cf-turnstile-response', token);
        var ref = cookie(refCookie); if (ref) u.searchParams.set('ref', ref);
        var via = cookie(viaCookie); if (via) u.searchParams.set('via', via);
        window.location.href = u.toString();
      });
    })();
  </script>
</BaseLayout>
