---
import BaseLayout from '../layouts/BaseLayout.astro';
import { MEMBERSHIP_PRICE_LABEL, BILLING_PERIOD, TRIAL_DAYS_SITE, REFERRAL_PCT, CONTRIBUTION_PCT, COMMENT_PCT, HOLD_DAYS } from '../lib/membership';

// SOW-007/008: the co-op revenue-share explainer. This is where the "share of the revenue" links across
// the site land. Every number is single-sourced from lib/membership so it tracks the real config. Design
// language mirrors the homepage / about / membership pages (V3 tokens: band, wrap, eyebrow, h2, cards).
const splits = [
  { pct: REFERRAL_PCT, who: 'the author', title: 'Referral share', body: `When someone joins the co-op because of work you published, you earn ${REFERRAL_PCT} of their membership revenue for the life of their membership.` },
  { pct: `up to ${CONTRIBUTION_PCT}`, who: 'contributors', title: 'Contribution pool', body: `The author can delegate up to ${CONTRIBUTION_PCT} of that share to the members who improved the work through accepted contributions.` },
  { pct: `up to ${COMMENT_PCT}`, who: 'commenters', title: 'Comment pool', body: `And up to ${COMMENT_PCT} to the members whose comments add to the discussion on a piece of work.` },
];

const flow = [
  { n: '01', icon: 'pencil', title: 'You propose an improvement', body: 'Open a pull request that improves another member’s article, product, or prompt, right from the GBTI client.' },
  { n: '02', icon: 'check', title: 'The owner reviews it', body: 'The content owner approves your change, or asks for edits. Nothing merges without their review.' },
  { n: '03', icon: 'git', title: 'It merges, and you’re credited', body: 'Your commit appears in that work’s contribution history, linked to you, as an accepted contribution.' },
  { n: '04', icon: 'coin', title: 'You share in the revenue', body: `You earn from the author’s delegated contribution pool. One accepted contribution claims the full pool; several split it by how much each member added.` },
];
---
<BaseLayout
  title="How the co-op works"
  description={`The GBTI co-op shares its revenue: the author earns ${REFERRAL_PCT} of every member their work brings in, and delegates up to ${CONTRIBUTION_PCT} to contributors and ${COMMENT_PCT} to commenters.`}
>
  <!-- ============ HERO ============ -->
  <section class="band tcenter">
    <div class="wrap">
      <div class="chip" style="display:inline-flex"><span class="chip-dot"></span> The co-op</div>
      <h1 class="h1 mt20">Publish and Earn</h1>
      <p class="lead" style="max-width:680px;margin:18px auto 0">
        GBTI is a developer co-op. Members publish their work, the network helps it get found, other members
        improve it, and the revenue it brings in is shared back with everyone who created the value.
      </p>
      <div class="hero-c-cta">
        <a href="/membership/" class="btn btn-primary btn-lg">Become a member</a>
        <span class="mono muted" style="font-size:13px">{MEMBERSHIP_PRICE_LABEL} a {BILLING_PERIOD}, {TRIAL_DAYS_SITE}-day no-card trial</span>
      </div>
    </div>
  </section>

  <!-- ============ WHERE THE MONEY GOES ============ -->
  <section class="band tint">
    <div class="wrap">
      <div class="sec-head center">
        <p class="eyebrow">Share the revenue</p>
        <h2 class="h2 mt12">Three ways the work pays back</h2>
        <p class="lead mt16" style="max-width:640px;margin-left:auto;margin-right:auto">A piece of work earns its author a referral share, and the author chooses how much of it to pass on to the members who helped.</p>
      </div>
      <div class="split-grid mt32">
        {splits.map((s) => (
          <div class="card split-card">
            <div class="split-pct">{s.pct}</div>
            <p class="split-who mono">to {s.who}</p>
            <h3 class="h4 mt8">{s.title}</h3>
            <p class="body-sm muted mt8">{s.body}</p>
          </div>
        ))}
      </div>
      <p class="body-sm muted tcenter mt24" style="max-width:640px;margin-left:auto;margin-right:auto">
        The shares are capped, so the original author always keeps the majority of what their work earns.
        Payouts run through Stripe Connect after a {HOLD_DAYS}-day hold, derived from real Stripe data, always
        auditable.
      </p>
    </div>
  </section>

  <!-- ============ HOW A CONTRIBUTION EARNS ============ -->
  <section class="band">
    <div class="wrap">
      <div class="sec-head center">
        <p class="eyebrow">Improve, and earn</p>
        <h2 class="h2 mt12">When you improve someone’s work, you share in it</h2>
        <p class="lead mt16" style="max-width:620px;margin-left:auto;margin-right:auto">Every article, product, and prompt is a file in a public Git repo. Improving one is a pull request, and an accepted one earns a cut.</p>
      </div>
      <ol class="flow mt32">
        {flow.map((s) => (
          <li class="card flow-step">
            <span class="itile"><svg viewBox="0 0 24 24"><use href={`#ico-${s.icon}`}/></svg></span>
            <span class="flow-num">{s.n}</span>
            <h3 class="h4 mt8">{s.title}</h3>
            <p class="body-sm muted mt8">{s.body}</p>
          </li>
        ))}
      </ol>
      <p class="body-sm muted tcenter mt24" style="max-width:640px;margin-left:auto;margin-right:auto">
        The author decides how much of their {REFERRAL_PCT} to delegate (up to {CONTRIBUTION_PCT} to contributors,
        {' '}{COMMENT_PCT} to commenters). Grammar-only fixes are a courtesy and earn no share; a meaningful
        correction or addition does.
      </p>
    </div>
  </section>

  <!-- ============ CTA ============ -->
  <section class="band dark tcenter">
    <div class="wrap">
      <h2 class="h2" style="color:#fff">Publish your work. Share in what it earns.</h2>
      <p class="lead" style="max-width:560px;margin:16px auto 0">Start with a {TRIAL_DAYS_SITE}-day, no-card trial of the community.</p>
      <div class="hero-c-cta">
        <a href="/membership/" class="btn btn-primary btn-lg">Become a member</a>
        <a href="/about/" class="btn btn-ghost btn-lg">About the network</a>
      </div>
    </div>
  </section>

  <style>
    .split-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px; }
    .split-card { padding: 30px; text-align: center; }
    .split-pct { font-family: var(--f-display); font-weight: 800; font-size: 44px; line-height: 1; letter-spacing: -0.02em; color: var(--green-600); }
    .dark .split-pct { color: var(--green-mint); }
    .split-who { font-size: 11px; letter-spacing: .08em; text-transform: uppercase; color: var(--fg-mute); margin-top: 6px; }
    @media (max-width: 760px) { .split-grid { grid-template-columns: 1fr; } }

    .flow { list-style: none; padding: 0; margin: 0; display: flex; flex-wrap: wrap; justify-content: center; gap: 20px; }
    .flow-step { flex: 1 1 220px; max-width: 252px; padding: 26px 22px; position: relative; }
    .flow-num { font-family: var(--f-mono); font-size: 12px; font-weight: 700; color: var(--green-600); position: absolute; top: 20px; right: 22px; }
    .dark .flow-num { color: var(--green-mint); }
    @media (max-width: 760px) { .flow-step { flex-basis: 100%; max-width: none; } }
  </style>
</BaseLayout>
