---
// SOW brand: the GBTI brand style guide, built from the DesignSync "GBTI Logo Package". It documents the mark,
// the lockups, the palette, app icons, favicons, clear space, misuse, and social banners, all from the real
// brand assets under /brand/logo/ (recolored PNG marks) and the favicon set. Light and dark aware via the V3
// tokens (src/styles/gbti-v3.css). The raw asset package lives in .product/brand/ for manual reuse.
import BaseLayout from '../../layouts/BaseLayout.astro';

const MARK = (variant: string) => `/brand/logo/mark-${variant}.png`;
// The three social banner grounds, reused per platform.
const grounds = [
  { key: 'ink', label: 'Ink' },
  { key: 'green', label: 'Brand green' },
  { key: 'ink-green', label: 'Ink, green glow' },
];
const platforms = [
  { name: 'X', dim: '1500 x 500' },
  { name: 'Bluesky', dim: '3000 x 1000' },
  { name: 'Mastodon', dim: '1500 x 500' },
  { name: 'Reddit', dim: '1920 x 384' },
  { name: 'LinkedIn', dim: '1584 x 396' },
  { name: 'YouTube', dim: '2560 x 1440' },
];
---

<BaseLayout
  title="Brand · GBTI Network"
  description="The GBTI Network brand style guide: the mark, lockups, palette, app icons, favicons, and usage rules, with the asset package."
>
  <main class="brand-wrap">
    <header class="b-head">
      <p class="b-eyebrow">Brand</p>
      <h1 class="b-title">GBTI logo package</h1>
      <p class="b-sub">Ink #25232b · brand green #1f9e5f · Baloo Da 2</p>
      <p class="b-note">The GBTI monogram, applied across the system in one palette and type. Every mark on this
        page is the same source art recolored, so the lockups, app icons, and favicons stay consistent. The raw
        files are packaged for download at the bottom.</p>
    </header>

    <!-- PALETTE -->
    <section class="b-sec">
      <div class="b-sect-t"><h2>Brand palette</h2><span class="n">the whole system</span></div>
      <div class="b-palette">
        <div class="pchip"><span class="sw" style="background:#25232b"></span><span class="t"><b>Ink</b>#25232b</span></div>
        <div class="pchip"><span class="sw" style="background:#1f9e5f"></span><span class="t"><b>Brand green</b>#1f9e5f</span></div>
        <div class="pchip"><span class="sw" style="background:#5fd49a"></span><span class="t"><b>Mint</b>#5fd49a</span></div>
        <div class="pchip"><span class="sw" style="background:#faf9f8;border:1px solid var(--line)"></span><span class="t"><b>Paper</b>#faf9f8</span></div>
      </div>
    </section>

    <!-- PRIMARY LOCKUPS -->
    <section class="b-sec">
      <div class="b-sect-t"><h2>Primary lockups</h2><span class="n">mark plus wordmark</span></div>
      <div class="b-grid g2">
        <div class="tile"><div class="stage bg-paper"><div class="lockup"><img class="mk" src={MARK('ink')} alt="GBTI mark" /><span class="word"><span class="wm">GBTI</span><span class="tag">Network</span></span></div></div><div class="cap"><span>Horizontal, primary</span><span class="sw">ink on paper</span></div></div>
        <div class="tile"><div class="stage bg-ink on-dark"><div class="lockup"><img class="mk" src={MARK('white')} alt="GBTI mark" /><span class="word"><span class="wm">GBTI</span><span class="tag">Network</span></span></div></div><div class="cap"><span>Horizontal, reversed</span><span class="sw">white on ink</span></div></div>
        <div class="tile"><div class="stage bg-paper"><div class="lockup stack"><img class="mk" src={MARK('ink')} alt="GBTI mark" /><span class="word"><span class="wm">GBTI</span><span class="tag">Network</span></span></div></div><div class="cap"><span>Stacked</span><span class="sw">ink on paper</span></div></div>
        <div class="tile"><div class="stage bg-green on-dark"><div class="lockup"><img class="mk" src={MARK('white')} alt="GBTI mark" /><span class="word"><span class="wm">GBTI</span><span class="tag">Network</span></span></div></div><div class="cap"><span>Horizontal, on green</span><span class="sw">white on brand</span></div></div>
      </div>
    </section>

    <!-- MARK TREATMENTS -->
    <section class="b-sec">
      <div class="b-sect-t"><h2>Mark treatments</h2><span class="n">the standalone symbol</span></div>
      <div class="b-grid g4">
        <div class="tile"><div class="stage bg-paper"><img class="sym" src={MARK('ink')} alt="GBTI mark, ink" /></div><div class="cap"><span>Ink</span><span class="sw">#25232b</span></div></div>
        <div class="tile"><div class="stage bg-paper"><img class="sym" src={MARK('green')} alt="GBTI mark, green" /></div><div class="cap"><span>Brand green</span><span class="sw">#1f9e5f</span></div></div>
        <div class="tile"><div class="stage bg-ink"><img class="sym" src={MARK('white')} alt="GBTI mark, white" /></div><div class="cap"><span>Reversed</span><span class="sw">white on ink</span></div></div>
        <div class="tile"><div class="stage bg-ink"><img class="sym" src={MARK('mint')} alt="GBTI mark, mint" /></div><div class="cap"><span>Mint on ink</span><span class="sw">#5fd49a</span></div></div>
      </div>
    </section>

    <!-- APP ICONS -->
    <section class="b-sec">
      <div class="b-sect-t"><h2>App icon and avatar tiles</h2><span class="n">rounded square and circle</span></div>
      <div class="b-grid g4">
        <div class="tile"><div class="stage bg-paper"><span class="ic sq" style="background:#25232b"><img src={MARK('white')} alt="" /></span></div><div class="cap"><span>Ink tile</span><span class="sw">white mark</span></div></div>
        <div class="tile"><div class="stage bg-paper"><span class="ic sq" style="background:#1f9e5f"><img src={MARK('white')} alt="" /></span></div><div class="cap"><span>Green tile</span><span class="sw">white mark</span></div></div>
        <div class="tile"><div class="stage bg-paper"><span class="ic sq" style="background:#fff;border:1px solid var(--line)"><img src={MARK('ink')} alt="" /></span></div><div class="cap"><span>White tile</span><span class="sw">ink mark</span></div></div>
        <div class="tile"><div class="stage bg-paper"><span class="ic rd" style="background:#25232b"><img src={MARK('white')} alt="" /></span></div><div class="cap"><span>Avatar circle</span><span class="sw">white on ink</span></div></div>
      </div>
    </section>

    <!-- FAVICONS -->
    <section class="b-sec">
      <div class="b-sect-t"><h2>Favicon scaling</h2><span class="n">legible at small sizes</span></div>
      <div class="tile"><div class="stage bg-paper" style="justify-content:flex-start;gap:22px;padding:34px 40px;flex-wrap:wrap;align-items:flex-end">
        <span class="fav"><img src="/favicon-512x512.png" width="96" height="96" alt="favicon 96" /><span class="fl">96</span></span>
        <span class="fav"><img src="/favicon-192x192.png" width="64" height="64" alt="favicon 64" /><span class="fl">64</span></span>
        <span class="fav"><img src="/favicon-48x48.png" width="48" height="48" alt="favicon 48" /><span class="fl">48</span></span>
        <span class="fav"><img src="/favicon-32x32.png" width="32" height="32" alt="favicon 32" /><span class="fl">32</span></span>
        <span class="fav"><img src="/favicon-16x16.png" width="16" height="16" alt="favicon 16" /><span class="fl">16</span></span>
      </div><div class="cap"><span>Ink tile, white mark</span><span class="sw">the favicon set</span></div></div>
    </section>

    <!-- CLEAR SPACE + MISUSE -->
    <section class="b-sec">
      <div class="b-sect-t"><h2>Clear space and misuse</h2><span class="n">usage guardrails</span></div>
      <div class="b-grid g3">
        <div class="tile"><div class="stage bg-paper"><span class="cs"><img class="sym" src={MARK('ink')} alt="GBTI mark" /></span></div><div class="cap"><span>Clear space</span><span class="sw">keep 25% of the mark</span></div></div>
        <div class="tile misuse"><div class="stage bg-paper"><span class="x">x</span><img class="sym stretch" src={MARK('green')} alt="stretched mark" /></div><div class="cap"><span>Do not stretch</span><span class="sw">keep the aspect</span></div></div>
        <div class="tile misuse"><div class="stage bg-tint"><span class="x">x</span><img class="sym" src={MARK('mint')} alt="low contrast mark" /></div><div class="cap"><span>Do not lower contrast</span><span class="sw">keep it legible</span></div></div>
      </div>
    </section>

    <!-- SOCIAL BANNERS -->
    <section class="b-sec">
      <div class="b-sect-t"><h2>Social profiles and banners</h2><span class="n">avatar plus header per platform</span></div>
      <p class="b-note" style="margin:0 0 20px">Each platform gets the round mark avatar and a banner in one of three grounds, all inside the GBTI palette so any choice reads as one system.</p>
      <div class="soc-list">
        {platforms.map((p) => (
          <div class="socblock">
            <div class="socblock-h"><span class="ic rd sm" style="background:#1f9e5f"><img src={MARK('white')} alt="" /></span><span class="socname">{p.name}</span><span class="socdim">{p.dim}</span></div>
            <div class="soc-variants">
              {grounds.map((g) => (
                <div class="socvar">
                  <div class={`socbanner ground-${g.key}`}><span class="socglow"></span><div class="soclock"><img src={MARK('white')} alt="" /><span class="socword"><span class="s1">GBTI</span><span class="s2">Network</span></span></div></div>
                  <span class="socvar-l">{g.label}</span>
                </div>
              ))}
            </div>
          </div>
        ))}
      </div>
    </section>

    <!-- DOWNLOAD -->
    <section class="b-sec">
      <div class="b-sect-t"><h2>Download the assets</h2><span class="n">marks and favicons</span></div>
      <p class="b-note" style="margin:0 0 18px">The full package (every mark, the favicon set, and a README) is versioned in the repository under
        <span class="mono">.product/brand/</span>. The site-served files link directly below.</p>
      <div class="dl-grid">
        <a class="dl" href={MARK('ink')} download><img src={MARK('ink')} alt="" /><span>Mark, ink</span></a>
        <a class="dl" href={MARK('green')} download><img src={MARK('green')} alt="" /><span>Mark, green</span></a>
        <a class="dl" href={MARK('white')} download><span class="dl-dark"><img src={MARK('white')} alt="" /></span><span>Mark, white</span></a>
        <a class="dl" href={MARK('mint')} download><span class="dl-dark"><img src={MARK('mint')} alt="" /></span><span>Mark, mint</span></a>
        <a class="dl" href="/favicon-512x512.png" download><img src="/favicon-512x512.png" alt="" /><span>Favicon 512</span></a>
        <a class="dl" href="/apple-touch-icon.png" download><img src="/apple-touch-icon.png" alt="" /><span>Apple touch icon</span></a>
      </div>
    </section>
  </main>
</BaseLayout>

<style>
  .brand-wrap { max-width: 1160px; margin: 0 auto; padding: 40px 24px 96px; }
  .b-head { margin-bottom: 12px; }
  .b-eyebrow { font-family: var(--f-mono); font-size: 12px; letter-spacing: .16em; text-transform: uppercase; color: var(--green-700); margin: 0 0 8px; }
  .b-title { font-family: var(--f-display); font-weight: 800; font-size: clamp(30px, 5vw, 40px); letter-spacing: -0.01em; color: var(--fg); margin: 0; }
  .b-sub { font-family: var(--f-mono); font-size: 13px; color: var(--fg-mute); margin: 8px 0 0; }
  .b-note { color: var(--fg-soft); font-size: 15px; line-height: 1.6; max-width: 720px; margin: 14px 0 0; }

  .b-sec { margin-top: 52px; }
  .b-sect-t { display: flex; align-items: baseline; gap: 12px; margin-bottom: 18px; }
  .b-sect-t h2 { font-family: var(--f-display); font-weight: 700; font-size: 21px; color: var(--fg); margin: 0; }
  .b-sect-t .n { font-family: var(--f-mono); font-size: 12px; color: var(--fg-mute); }

  .b-palette { display: flex; gap: 12px; flex-wrap: wrap; }
  .pchip { display: flex; align-items: center; gap: 10px; background: var(--paper); border: 1px solid var(--line); border-radius: 11px; padding: 8px 14px 8px 8px; }
  .pchip .sw { width: 36px; height: 36px; border-radius: 8px; flex: none; }
  .pchip .t { font-family: var(--f-mono); font-size: 11px; color: var(--fg-mute); }
  .pchip .t b { display: block; font-family: var(--f-sans); font-size: 13px; font-weight: 700; color: var(--fg); margin-bottom: 2px; }

  .b-grid { display: grid; gap: 16px; }
  .g2 { grid-template-columns: repeat(2, 1fr); }
  .g3 { grid-template-columns: repeat(3, 1fr); }
  .g4 { grid-template-columns: repeat(4, 1fr); }
  @media (max-width: 900px) { .g4 { grid-template-columns: repeat(2, 1fr); } .g3 { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 620px) { .g2, .g3, .g4 { grid-template-columns: 1fr; } }

  .tile { border-radius: 16px; border: 1px solid var(--line); background: var(--paper); box-shadow: var(--sh, 0 1px 3px rgba(0,0,0,.05)); overflow: hidden; display: flex; flex-direction: column; }
  .tile .stage { flex: 1; display: flex; align-items: center; justify-content: center; padding: 40px; min-height: 172px; }
  .tile .cap { border-top: 1px solid var(--line); padding: 11px 15px; display: flex; align-items: center; justify-content: space-between; gap: 10px; font-family: var(--f-mono); font-size: 12px; color: var(--fg-soft); }
  .tile .cap .sw { color: var(--fg-mute); }

  /* Showcase grounds are FIXED (not theme tokens): a style guide must show each ground as intended regardless of
     the viewer's light/dark theme, so an "ink on paper" demo stays on paper even in dark mode. */
  .bg-paper { background: #faf9f8; }
  .bg-ink { background: #25232b; }
  .bg-green { background: #1f9e5f; }
  .bg-tint { background: #e9f6ef; }
  /* The word/tag inside a fixed-paper stage must stay ink even in dark mode (the stage does not flip). */
  .bg-paper .word .wm { color: #25232b; }
  .bg-paper .word .tag { color: #6c6976; }

  .lockup { display: flex; align-items: center; gap: 14px; }
  .lockup .mk { height: 46px; width: auto; display: block; }
  .word { display: flex; flex-direction: column; line-height: 1; }
  .word .wm { font-family: var(--f-display); font-weight: 700; font-size: 34px; letter-spacing: -0.01em; color: var(--ink); }
  .word .tag { font-family: var(--f-mono); font-size: 10px; letter-spacing: .22em; text-transform: uppercase; color: var(--fg-mute); margin-top: 5px; }
  .on-dark .word .wm { color: #fff; }
  .on-dark .word .tag { color: rgba(255,255,255,.72); }
  .lockup.stack { flex-direction: column; gap: 14px; }
  .lockup.stack .mk { height: 64px; }
  .lockup.stack .word { align-items: center; }

  .sym { width: 96px; height: 96px; object-fit: contain; display: block; }
  .ic { display: flex; align-items: center; justify-content: center; box-shadow: 0 10px 26px rgba(37,35,43,.22); }
  .ic.sq { width: 118px; height: 118px; border-radius: 27px; }
  .ic.rd { width: 118px; height: 118px; border-radius: 50%; }
  .ic.sm { width: 40px; height: 40px; border-radius: 50%; box-shadow: none; }
  .ic img { width: 58%; height: 58%; object-fit: contain; }

  .fav { display: flex; flex-direction: column; align-items: center; gap: 8px; }
  .fav .fl { font-family: var(--f-mono); font-size: 10px; color: var(--fg-mute); }

  .cs { position: relative; padding: 26px; outline: 1.5px dashed var(--green); border-radius: 8px; }
  .cs .sym { width: 84px; height: 84px; }
  .misuse .stage { position: relative; }
  .misuse .x { position: absolute; top: 10px; right: 12px; width: 22px; height: 22px; border-radius: 50%; background: #d64b3f; color: #fff; display: flex; align-items: center; justify-content: center; font-size: 12px; font-weight: 700; text-transform: uppercase; }
  .stretch { transform: scaleX(1.6); }

  .soc-list { display: flex; flex-direction: column; gap: 30px; }
  .socblock-h { display: flex; align-items: center; gap: 12px; margin-bottom: 12px; }
  .socname { font-family: var(--f-display); font-weight: 700; font-size: 17px; color: var(--fg); }
  .socdim { font-family: var(--f-mono); font-size: 11px; color: var(--fg-mute); margin-left: auto; }
  .soc-variants { display: grid; grid-template-columns: repeat(3, 1fr); gap: 14px; }
  @media (max-width: 820px) { .soc-variants { grid-template-columns: 1fr; } }
  .socvar { display: flex; flex-direction: column; gap: 7px; }
  .socvar-l { font-family: var(--f-mono); font-size: 10.5px; color: var(--fg-mute); text-align: center; }
  .socbanner { position: relative; height: 118px; border-radius: 13px; overflow: hidden; display: flex; align-items: center; padding: 0 26px; box-shadow: var(--sh-lg, 0 12px 30px rgba(0,0,0,.16)); }
  .socbanner .soclock { position: relative; z-index: 2; display: flex; align-items: center; gap: 11px; }
  .socbanner .soclock img { height: 34px; width: auto; }
  .socword { display: flex; flex-direction: column; line-height: 1; }
  .socword .s1 { font-family: var(--f-display); font-weight: 700; font-size: 24px; letter-spacing: -0.01em; color: #fff; }
  .socword .s2 { font-family: var(--f-mono); font-size: 9px; letter-spacing: .22em; text-transform: uppercase; color: rgba(255,255,255,.72); margin-top: 5px; }
  .ground-ink { background: #25232b; }
  .ground-green { background: radial-gradient(120% 140% at 50% -30%, #2bb576 0%, #1f9e5f 65%); }
  .ground-ink-green { background: radial-gradient(130% 150% at 88% -20%, rgba(31,158,95,.55) 0%, rgba(31,158,95,0) 55%), #25232b; }
  .socbanner .socglow { position: absolute; inset: 0; z-index: 1; background: radial-gradient(60% 120% at 82% 0%, rgba(255,255,255,.14), transparent 60%); }

  .dl-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(150px, 1fr)); gap: 14px; }
  .dl { display: flex; flex-direction: column; align-items: center; gap: 10px; text-decoration: none; padding: 20px 14px; border: 1px solid var(--line); border-radius: 14px; background: var(--paper); transition: border-color .14s, transform .14s; }
  .dl:hover { border-color: var(--green); transform: translateY(-2px); }
  .dl img { width: 54px; height: 54px; object-fit: contain; }
  .dl .dl-dark { display: flex; align-items: center; justify-content: center; width: 74px; height: 74px; border-radius: 12px; background: #25232b; }
  .dl .dl-dark img { width: 54px; height: 54px; }
  .dl span:last-child { font-family: var(--f-mono); font-size: 12px; color: var(--fg-soft); }
  .mono { font-family: var(--f-mono); font-size: .92em; }
</style>
