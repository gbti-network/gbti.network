# Controller env for the SOW-005 reconcile + gate when run locally. Copy to .env and fill in.
# .env is GITIGNORED; .env.example is tracked. `npm run reconcile` loads .env automatically
# (node --env-file-if-exists=.env). In CI these are GitHub Actions secrets, not a file.
# The Worker has its own local env at workers/signup/.dev.vars (see .dev.vars.example there).

# Stripe restricted CONTROLLER key: Customers + Subscriptions READ only (the reconcile never writes Stripe).
STRIPE_SECRET_KEY="rk_..._controller_read_only"
GITHUB_CONTENT_REPO="gbti-network/gbti.network"
# Fine-grained gbtilabs PAT (contents + pull-requests + statuses on the content repo).
GITHUB_BOT_TOKEN="..."
DISCORD_BOT_TOKEN="..."
DISCORD_GUILD_ID="000000000000000000"
DISCORD_MEMBER_ROLE_ID="000000000000000000"
DISCORD_TRIAL_ROLE_ID="000000000000000000"
# The Locked role: reconcile assigns it to lapsed/banned accounts to lock them out (via the role's
# channel overwrites) without kicking them from the guild.
DISCORD_LOCKED_ROLE_ID="000000000000000000"
RESEND_API_KEY="..."
RESEND_FROM="noreply@gbti.network"
# BOT_GITHUB_ID intentionally unset: automation runs as the gbtilabs superadmin (exempt by role).
